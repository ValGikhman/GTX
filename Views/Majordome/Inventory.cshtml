    function getSortedIds() {
        return $("#sortable-gallery li").map(function () {
            return $(this).attr("id");
        }).get();
    }

    function safeText(value) {
        return value == null ? "" : String(value);
    }

    function escapeHtml(value) {
        return safeText(value)
            .replace(/&/g, "&amp;")
            .replace(/</g, "&lt;")
            .replace(/>/g, "&gt;")
            .replace(/"/g, "&quot;")
            .replace(/'/g, "&#39;");
    }

    function findMajordomeInventoryVehicle(stock) {
        const key = safeText(stock).trim().toUpperCase();
        if (!key) return null;

        return (inventoryVehiclesSource || [])
            .concat(inventoryVehicles || [])
            .find(function (vehicle) {
                return safeText(vehicle?.Stock).trim().toUpperCase() === key;
            }) || null;
    }

    function getMajordomeInventoryEditorInput(field) {
        return $(`#majordomeInventoryEditor${field}`);
    }

    function initMajordomeInventoryEditorDatepickers() {
        const $fields = $("#majordomeInventoryEditorPurchaseDate, #majordomeInventoryEditorArrivalDate");
        if (!$fields.length || typeof $.fn.datepicker !== "function") return;

        const notifyDateChanged = function (input) {
            $(input).trigger("input").trigger("change");
        };

        const isBootstrapDatepicker = !!$.fn.datepicker.Constructor;
        $fields.each(function () {
            const $field = $(this);
            if ($field.data("majordome-datepicker-ready")) return;

            if (isBootstrapDatepicker) {
                $field.datepicker({
                    autoclose: true,
                    todayHighlight: true,
                    format: "yyyy-mm-dd",
                    container: "#majordomeInventoryEditorModal"
                }).on("changeDate", function () {
                    notifyDateChanged(this);
                });
            } else {
                $field.datepicker({
                    showOn: "focus",
                    showOtherMonths: true,
                    selectOtherMonths: true,
                    dateFormat: "yy-mm-dd",
                    onSelect: function (dateText) {
                        $(this).val(dateText);
                        notifyDateChanged(this);
                    }
                });
            }

            $field.data("majordome-datepicker-ready", true);
        });
    }

    function canAddMajordomeInventoryEditorOption(field) {
        return getMajordomeInventoryEditorInput(field).attr("data-allow-new") === "true";
    }

    function ensureMajordomeInventoryEditorNewOption($select) {
        let $row = $select.next(".majordome-editor-new-option");
        if ($row.length) return $row;

        const field = $select.attr("data-inventory-field");
        const label = getMajordomeInventoryEditorFieldLabel(field).toLowerCase();
        const maxLength = majordomeInventoryEditorStringLimits[field];
        const inputMode = majordomeInventoryEditorNumberFields.indexOf(field) !== -1 ? "numeric" : "text";
        const maxLengthAttr = maxLength ? ` maxlength="${maxLength}"` : "";

        $row = $(`
            <div class="majordome-editor-new-option d-none">
                <div class="input-group">
                    <input type="text" class="form-control shadow-sm js-majordome-editor-new-option-value" inputmode="${inputMode}"${maxLengthAttr} placeholder="New ${escapeHtml(label)}" />
                    <button type="button" class="btn btn-gradient js-majordome-editor-add-option">Add</button>
                    <button type="button" class="btn btn-outline-secondary js-majordome-editor-cancel-option">Cancel</button>
                </div>
            </div>`);

        $select.after($row);
        return $row;
    }

    function showMajordomeInventoryEditorNewOption($select) {
        const field = $select.attr("data-inventory-field");
        if (!canAddMajordomeInventoryEditorOption(field)) return;

        const $row = ensureMajordomeInventoryEditorNewOption($select);
        $row.removeClass("d-none");
        $row.find(".js-majordome-editor-new-option-value").val("").trigger("focus");
    }

    function hideMajordomeInventoryEditorNewOption($select) {
        const $row = $select.next(".majordome-editor-new-option");
        if ($row.length) {
            $row.addClass("d-none");
            $row.find(".js-majordome-editor-new-option-value").val("");
        }
    }

    function addMajordomeInventoryEditorNewOption($select) {
        if (!$select.length) return;

        const field = $select.attr("data-inventory-field");
        const $row = ensureMajordomeInventoryEditorNewOption($select);
        const value = normalizeMajordomeInventoryEditorOptionValue($row.find(".js-majordome-editor-new-option-value").val());
        const maxLength = majordomeInventoryEditorStringLimits[field];

        if (!value) {
            setMajordomeInventoryEditorFieldError(field, "Enter a value to add.");
            return;
        }

        if (maxLength && value.length > maxLength) {
            setMajordomeInventoryEditorFieldError(field, `${getMajordomeInventoryEditorFieldLabel(field)} must be ${maxLength} characters or fewer.`);
            return;
        }

        if (majordomeInventoryEditorNumberFields.indexOf(field) !== -1 && !isMajordomeSqlInt(value)) {
            setMajordomeInventoryEditorFieldError(field, `${getMajordomeInventoryEditorFieldLabel(field)} must be a whole number inside the SQL int range.`);
            return;
        }

        clearMajordomeInventoryEditorFieldError($select);
        renderMajordomeInventoryEditorSelectOptions(field, value);
        hideMajordomeInventoryEditorNewOption($select);

        if (field === "Make") {
            renderMajordomeInventoryEditorSelectOptions("Model", "");
        }
    }

    function cancelMajordomeInventoryEditorNewOption($select) {
        if (!$select.length) return;

        const field = $select.attr("data-inventory-field");
        const previousValue = safeText($select.data("previous-value"));
        renderMajordomeInventoryEditorSelectOptions(field, previousValue);
        hideMajordomeInventoryEditorNewOption($select);

        if (field === "Make") {
            renderMajordomeInventoryEditorSelectOptions("Model", "");
        }
    }

    function getMajordomeInventoryEditorRows() {
        return Array.isArray(inventoryVehiclesSource) ? inventoryVehiclesSource : [];
    }

    function normalizeMajordomeInventoryEditorOptionValue(value) {
        return safeText(value).trim();
    }

    function getMajordomeInventoryEditorOptionLabel(field, value) {
        const text = normalizeMajordomeInventoryEditorOptionValue(value);
        if (field === "Transmission") {
            return getMajordomeTransmissionLabel(text);
        }

        return text;
    }

    function getMajordomeTransmissionLabel(value) {
        const code = safeText(value).trim().toUpperCase();
        switch (code) {
            case "A":
                return "Automatic";
            case "M":
                return "Manual";
            case "T":
                return "Transverse";
            case "C":
                return "Continuously variable";
            default:
                return code || "";
        }
    }

    function getMajordomeInventoryEditorSelectRows(field) {
        const rows = getMajordomeInventoryEditorRows();
        if (field !== "Model") {
            return rows;
        }

        const selectedMake = normalizeMajordomeInventoryEditorOptionValue(getMajordomeInventoryEditorInput("Make").val()).toUpperCase();
        if (!selectedMake) {
            return rows;
        }

        return rows.filter(function (vehicle) {
            return normalizeMajordomeInventoryEditorOptionValue(vehicle?.Make).toUpperCase() === selectedMake;
        });
    }

    function getMajordomeInventoryEditorSelectValues(field, selectedValue) {
        const selected = normalizeMajordomeInventoryEditorOptionValue(selectedValue);
        let values;

        if (field === "Transmission") {
            values = ["A", "M", "C", "T"];
        } else if (field === "SetToUpload") {
            values = ["Y", "N"];
        } else {
            values = getMajordomeInventoryEditorSelectRows(field)
                .map(function (vehicle) {
                    return normalizeMajordomeInventoryEditorOptionValue(vehicle && vehicle[field]);
                })
                .filter(function (value) {
                    if (!value) return false;
                    if ((field === "Cylinders" || field === "TransmissionSpeed") && value === "0") return false;
                    return true;
                });
        }

        if (selected
            && !values.some(function (value) { return value.toUpperCase() === selected.toUpperCase(); })
            && !((field === "Cylinders" || field === "TransmissionSpeed") && selected === "0")) {
            values.push(selected);
        }

        return values
            .filter(function (value, index, source) {
                return source.findIndex(function (item) {
                    return item.toUpperCase() === value.toUpperCase();
                }) === index;
            })
            .sort(function (left, right) {
                return getMajordomeInventoryEditorOptionLabel(field, left)
                    .localeCompare(getMajordomeInventoryEditorOptionLabel(field, right), undefined, { numeric: true, sensitivity: "base" });
            });
    }

    function renderMajordomeInventoryEditorSelectOptions(field, selectedValue) {
        const $select = getMajordomeInventoryEditorInput(field);
        if (!$select.length || !$select.is("select")) return;

        const selected = normalizeMajordomeInventoryEditorOptionValue(selectedValue);
        const options = getMajordomeInventoryEditorSelectValues(field, selected);
        const selectedOption = selected
            ? (options.find(function (value) {
                return value.toUpperCase() === selected.toUpperCase();
            }) || selected)
            : "";
        const fieldLabel = getMajordomeInventoryEditorFieldLabel(field);
        const html = [`<option value="">Select ${escapeHtml(fieldLabel)}</option>`];

        options.forEach(function (value) {
            const label = getMajordomeInventoryEditorOptionLabel(field, value);
            html.push(`<option value="${escapeHtml(value)}">${escapeHtml(label)}</option>`);
        });

        if (canAddMajordomeInventoryEditorOption(field)) {
            html.push(`<option value="${majordomeInventoryEditorNewOptionValue}">+ Add new ${escapeHtml(fieldLabel)}</option>`);
        }

        $select.html(html.join(""));
        $select.val(selectedOption);
        $select.data("previous-value", $select.val() || "");
        hideMajordomeInventoryEditorNewOption($select);
    }

    function renderMajordomeInventoryEditorSelects(vehicle) {
        const row = vehicle || {};
        majordomeInventoryEditorSelectFields.forEach(function (field) {
            renderMajordomeInventoryEditorSelectOptions(field, row[field]);
        });
    }

    function openMajordomeInventoryEditor(vehicle, mode) {
        const isEdit = mode === "edit" && vehicle;
        const row = isEdit ? normalizeVehicle(vehicle) : {};
        const modalEl = document.getElementById("majordomeInventoryEditorModal");
        const stock = safeText(row.Stock).trim();

        resetMajordomeInventoryEditor();
        $("#majordomeInventoryEditorMode").val(isEdit ? "edit" : "add");
        $("#majordomeInventoryEditorOriginalStock").val(isEdit ? stock : "");
        $("#majordomeInventoryEditorTitle").text(isEdit ? "Edit inventory" : "Add inventory");
        renderMajordomeInventoryEditorSelects(row);

        majordomeInventoryEditorFields.forEach(function (field) {
            const $input = getMajordomeInventoryEditorInput(field);
            let value = isEdit ? safeText(row[field]) : "";
            if (majordomeInventoryEditorNumberFields.indexOf(field) !== -1 && safeText(value).trim() === "0") {
                value = "";
            }
            if (field === "SetToUpload") {
                value = safeText(value).trim().toUpperCase() === "N" ? "N" : "Y";
            }

            if (majordomeInventoryEditorSelectFields.indexOf(field) !== -1) {
                renderMajordomeInventoryEditorSelectOptions(field, value);
                return;
            }

            $input.val(value);
            if (majordomeInventoryEditorCurrencyFields.indexOf(field) !== -1) {
                $input.val(formatMajordomeCurrency(value));
            } else if (majordomeInventoryEditorFormattedNumberFields.indexOf(field) !== -1) {
                $input.val(formatMajordomeNumber(value));
            }
        });

        getMajordomeInventoryEditorInput("Stock")
            .prop("readonly", isEdit)
            .toggleClass("majordome-editor-stock-locked", isEdit);

        bootstrap.Modal.getOrCreateInstance(modalEl).show();
        setTimeout(function () {
            const focusField = isEdit ? "VIN" : "Stock";
            getMajordomeInventoryEditorInput(focusField).trigger("focus");
        }, 180);
    }

    function resetMajordomeInventoryEditor() {
        $("#majordomeInventoryEditorForm")[0].reset();
        $("#majordomeInventoryEditorForm [data-inventory-field]").each(function () {
            clearMajordomeInventoryEditorFieldError($(this));
        });
        hideMajordomeInventoryEditorAlert();
        setMajordomeInventoryEditorBusy(false);
    }

    function getMajordomeInventoryEditorFeedback($field) {
        if (!$field || !$field.length) return $();
        const $gridField = $field.closest(".majordome-editor-grid > div");
        if ($gridField.length) {
            return $gridField.find(".invalid-feedback").first();
        }

        return $field.closest("div").find(".invalid-feedback").first();
    }

    function clearMajordomeInventoryEditorFieldError($field) {
        if (!$field || !$field.length) return;
        $field.removeClass("is-invalid");
        getMajordomeInventoryEditorFeedback($field).text("");
    }

    function setMajordomeInventoryEditorFieldError(field, message) {
        const $field = getMajordomeInventoryEditorInput(field);
        $field.addClass("is-invalid");
        getMajordomeInventoryEditorFeedback($field).text(message);
    }

    function showMajordomeInventoryEditorAlert(message) {
        $("#majordomeInventoryEditorAlert").removeClass("d-none").text(message);
    }

    function hideMajordomeInventoryEditorAlert() {
        $("#majordomeInventoryEditorAlert").addClass("d-none").text("");
    }

    function setMajordomeInventoryEditorBusy(isBusy) {
        const $button = $("#majordomeInventoryEditorSave");
        $button.prop("disabled", isBusy);
        $button.html(isBusy
            ? `<span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>Saving`
            : `<i class="bi bi-check2-circle me-1"></i>Save inventory`);
        $("#majordomeInventoryEditorForm [data-inventory-field]").prop("disabled", isBusy);
        $("#majordomeInventoryDecodeVin").prop("disabled", isBusy);
    }

    function setMajordomeInventoryEditorDecodeBusy(isBusy) {
        const $button = $("#majordomeInventoryDecodeVin");
        $button.prop("disabled", isBusy);
        $button.html(isBusy
            ? `<span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>`
            : `<i class="bi bi-search"></i>`);
        $("#majordomeInventoryEditorSave").prop("disabled", isBusy);
    }

    function getMajordomeInventoryEditorFieldLabel(field) {
        return safeText(field).replace(/([a-z])([A-Z])/g, "$1 $2");
    }

    function normalizeMajordomeCurrencyText(value) {
        const text = safeText(value).trim();
        if (!text) return "";
        return text.replace(/[$,\s]/g, "");
    }

    function normalizeMajordomeNumberText(value) {
        const text = safeText(value).trim();
        if (!text) return "";
        return text.replace(/[,\s]/g, "");
    }

    function formatMajordomeNumber(value) {
        const normalized = normalizeMajordomeNumberText(value);
        if (!normalized) return "";

        const parsed = Number(normalized);
        if (!Number.isFinite(parsed)) return safeText(value);

        return parsed.toLocaleString("en-US", {
            maximumFractionDigits: 0,
            minimumFractionDigits: 0
        });
    }

    function formatMajordomeCurrency(value) {
        const normalized = normalizeMajordomeCurrencyText(value);
        if (!normalized) return "";

        const parsed = Number(normalized);
        if (!Number.isFinite(parsed)) return safeText(value);

        return parsed.toLocaleString("en-US", {
            style: "currency",
            currency: "USD",
            maximumFractionDigits: 0,
            minimumFractionDigits: 0
        });
    }

    function normalizeMajordomeVin(value) {
        return safeText(value).trim().toUpperCase();
    }

    function getMajordomeVinValidationMessage(vin) {
        if (!vin) return "Enter a VIN first.";
        if (vin.length !== 17) return "VIN must be exactly 17 characters.";
        if (/[IOQ]/.test(vin)) return "VIN cannot contain I, O, or Q.";
        return "";
    }

    function applyMajordomeDecodedInventoryValue(field, value) {
        const text = safeText(value).trim();
        if (!text && field !== "SetToUpload") return;

        const $input = getMajordomeInventoryEditorInput(field);
        if (!$input.length) return;

        if (majordomeInventoryEditorSelectFields.indexOf(field) !== -1) {
            renderMajordomeInventoryEditorSelectOptions(field, text);
            return;
        }

        let formattedText = text;
        if (majordomeInventoryEditorCurrencyFields.indexOf(field) !== -1) {
            formattedText = formatMajordomeCurrency(text);
        } else if (majordomeInventoryEditorFormattedNumberFields.indexOf(field) !== -1) {
            formattedText = formatMajordomeNumber(text);
        }

        $input.val(formattedText);
    }

    function applyMajordomeDecodedInventoryValues(vehicle) {
        const decoded = vehicle || {};
        const orderedFields = [
            "VIN",
            "Year",
            "Make",
            "Model",
            "VehicleStyle",
            "VehicleType",
            "Body",
            "DriveTrain",
            "Engine",
            "FuelType",
            "Cylinders",
            "Transmission",
            "TransmissionSpeed",
            "RetailPrice"
        ];

        orderedFields.forEach(function (field) {
            applyMajordomeDecodedInventoryValue(field, decoded[field]);
        });

        $("#majordomeInventoryEditorForm [data-inventory-field]").each(function () {
            clearMajordomeInventoryEditorFieldError($(this));
        });
        hideMajordomeInventoryEditorAlert();
    }

    async function decodeMajordomeInventoryEditorVin() {
        const $vin = getMajordomeInventoryEditorInput("VIN");
        const vin = normalizeMajordomeVin($vin.val());
        $vin.val(vin);

        clearMajordomeInventoryEditorFieldError($vin);
        hideMajordomeInventoryEditorAlert();

        const validationMessage = getMajordomeVinValidationMessage(vin);
        if (validationMessage) {
            setMajordomeInventoryEditorFieldError("VIN", validationMessage);
            showMajordomeInventoryEditorAlert(validationMessage);
            return;
        }

        setMajordomeInventoryEditorDecodeBusy(true);

        try {
            const response = await $.getJSON(`${root}Majordome/DecodeInventoryVehicleByVin`, { vin: vin });
            if (!response || !response.success) {
                throw new Error((response && response.message) || "VIN decode failed.");
            }

            applyMajordomeDecodedInventoryValues(response.vehicle);
        } catch (error) {
            const message = (error && error.message) || "VIN decode failed.";
            setMajordomeInventoryEditorFieldError("VIN", message);
            showMajordomeInventoryEditorAlert(message);
        } finally {
            setMajordomeInventoryEditorDecodeBusy(false);
        }
    }

    function isMajordomeSqlInt(value) {
        const text = safeText(value).trim().replace(/[$,\s]/g, "");
        if (!text) return true;
        if (!/^-?\d+$/.test(text)) return false;

        const parsed = Number(text);
        return Number.isInteger(parsed) && parsed >= -2147483648 && parsed <= 2147483647;
    }

    function validateMajordomeInventoryEditor() {
        let isValid = true;
        const messages = [];

        $("#majordomeInventoryEditorForm [data-inventory-field]").each(function () {
            clearMajordomeInventoryEditorFieldError($(this));
        });
        hideMajordomeInventoryEditorAlert();

        const stock = getMajordomeInventoryEditorInput("Stock").val();
        if (!safeText(stock).trim()) {
            isValid = false;
            setMajordomeInventoryEditorFieldError("Stock", "Stock is required.");
            messages.push("Stock is required.");
        }

        majordomeInventoryEditorSelectFields.forEach(function (field) {
            if (getMajordomeInventoryEditorInput(field).val() === majordomeInventoryEditorNewOptionValue) {
                isValid = false;
                const message = `Add or cancel the new ${getMajordomeInventoryEditorFieldLabel(field).toLowerCase()} value.`;
                setMajordomeInventoryEditorFieldError(field, message);
                messages.push(message);
            }
        });

        Object.keys(majordomeInventoryEditorStringLimits).forEach(function (field) {
            const maxLength = majordomeInventoryEditorStringLimits[field];
            const value = safeText(getMajordomeInventoryEditorInput(field).val()).trim();
            if (value.length > maxLength) {
                isValid = false;
                const message = `${getMajordomeInventoryEditorFieldLabel(field)} must be ${maxLength} characters or fewer.`;
                setMajordomeInventoryEditorFieldError(field, message);
                messages.push(message);
            }
        });

        majordomeInventoryEditorNumberFields.forEach(function (field) {
            const value = getMajordomeInventoryEditorInput(field).val();
            if (!isMajordomeSqlInt(value)) {
                isValid = false;
                const message = `${getMajordomeInventoryEditorFieldLabel(field)} must be a whole number inside the SQL int range.`;
                setMajordomeInventoryEditorFieldError(field, message);
                messages.push(message);
            }
        });

        if (!isValid) {
            showMajordomeInventoryEditorAlert(messages[0] || "Check the highlighted fields.");
        }

        return isValid;
    }

    function collectMajordomeInventoryEditorPayload() {
        const payload = {
            OriginalStock: $("#majordomeInventoryEditorOriginalStock").val()
        };

        majordomeInventoryEditorFields.forEach(function (field) {
            let value = getMajordomeInventoryEditorInput(field).val();
            if (majordomeInventoryEditorCurrencyFields.indexOf(field) !== -1) {
                value = normalizeMajordomeCurrencyText(value);
            } else if (majordomeInventoryEditorFormattedNumberFields.indexOf(field) !== -1) {
                value = normalizeMajordomeNumberText(value);
            }
            payload[field] = value;
        });

        return payload;
    }

    async function saveMajordomeInventoryEditor() {
        if (!validateMajordomeInventoryEditor()) return;

        const payload = collectMajordomeInventoryEditorPayload();
        const mode = $("#majordomeInventoryEditorMode").val();
        setMajordomeInventoryEditorBusy(true);

        try {
            const response = await postMajordome(`${root}Majordome/SaveInventoryVehicle`, payload);
            if (!response || !response.success) {
                throw new Error((response && response.message) || "Inventory save failed.");
            }

            bootstrap.Modal.getOrCreateInstance(document.getElementById("majordomeInventoryEditorModal")).hide();

            const savedStock = safeText(payload.Stock).trim();
            if (mode === "add" && savedStock) {
                $("#filterTerm").val(savedStock);
            }

            if (savedStock) {
                selectedVehicleStock = savedStock;
                window.majordomeSelectedStock = savedStock;
            }

            if (response.vehicle) {
                mergeMajordomeInventoryVehicle(response.vehicle, payload.OriginalStock);
            } else if (Array.isArray(response.data)) {
                updateRow(response.data);
            } else {
                const refreshed = await $.getJSON(`${root}Majordome/GetUpdatedItems`);
                updateRow(refreshed);
            }
        } catch (error) {
            showMajordomeInventoryEditorAlert((error && error.message) || "Inventory save failed.");
        } finally {
            setMajordomeInventoryEditorBusy(false);
        }
    }

    function normalizeVehicle(vehicle) {
        const row = vehicle || {};
        row.Images = Array.isArray(row.Images) ? row.Images : [];
        return row;
    }

    function mergeMajordomeInventoryVehicle(vehicle, originalStock) {
        const incoming = normalizeVehicle(vehicle);
        const stockKey = safeText(incoming.Stock).trim().toUpperCase();
        const originalKey = safeText(originalStock).trim().toUpperCase();
        if (!stockKey) return;

        const rows = Array.isArray(inventoryVehiclesSource) ? inventoryVehiclesSource : [];
        const existingIndex = rows.findIndex(function (row) {
            const rowKey = safeText(row?.Stock).trim().toUpperCase();
            return rowKey === stockKey || (!!originalKey && rowKey === originalKey);
        });
        const existing = existingIndex >= 0 ? rows[existingIndex] : null;
        const merged = normalizeVehicle(Object.assign({}, existing || {}, incoming));

        if ((!Array.isArray(incoming.Images) || incoming.Images.length === 0) && existing && Array.isArray(existing.Images)) {
            merged.Images = existing.Images;
        }

        if (!incoming.Image && existing?.Image) {
            merged.Image = existing.Image;
        }

        if (incoming.Story == null && existing?.Story) {
            merged.Story = existing.Story;
        }

        if (incoming.DataOne == null && existing?.DataOne) {
            merged.DataOne = existing.DataOne;
        }

        if (existingIndex >= 0) {
            rows[existingIndex] = merged;
        } else {
            rows.push(merged);
        }

        inventoryVehiclesSource = rows;
        updateRow(inventoryVehiclesSource);
    }

    function hasStory(vehicle) {
        const title = safeText(vehicle?.Story?.Title).trim();
        return title.length > 0;
    }

    function hasStoryContent(title, storyHtml) {
        const titleText = safeText(title).trim();
        if (titleText.length > 0) return true;

        const parsedStory = new DOMParser().parseFromString(`<div>${safeText(storyHtml)}</div>`, "text/html");
        const plainStory = (parsedStory.body.textContent || "").replace(/\u00a0/g, " ").trim();
        return plainStory.length > 0;
    }

    function syncMajordomeStoryLocalState(stock, title, storyHtml) {
        const stockKey = safeText(stock).trim().toUpperCase();
        if (!stockKey) return;

        const normalizedTitle = safeText(title);
        const normalizedStory = safeText(storyHtml);
        const storyExists = hasStoryContent(normalizedTitle, normalizedStory);
        const storyValue = storyExists
            ? { Title: normalizedTitle, HtmlContent: normalizedStory }
            : null;

        const applyStory = function (vehicle) {
            if (!vehicle) return;
            vehicle.Story = storyValue;
        };

        if (selectedVehicle && safeText(selectedVehicle.Stock).trim().toUpperCase() === stockKey) {
            applyStory(selectedVehicle);
        }

        if (Array.isArray(inventoryVehiclesSource)) {
            inventoryVehiclesSource.forEach(function (vehicle) {
                if (safeText(vehicle?.Stock).trim().toUpperCase() === stockKey) {
                    applyStory(vehicle);
                }
            });
        }

        if (Array.isArray(inventoryVehicles)) {
            inventoryVehicles.forEach(function (vehicle) {
                if (safeText(vehicle?.Stock).trim().toUpperCase() === stockKey) {
                    applyStory(vehicle);
                }
            });
        }

        const $row = $("#majordomeInventoryBody .majordome-vehicle-row").filter(function () {
            return safeText($(this).attr("data-stock")).trim().toUpperCase() === stockKey;
        }).first();

        if ($row.length) {
            $row.find(".majordome-status-story")
                .text(storyExists ? "Y" : "N")
                .toggleClass("is-on", storyExists);
        }
    }

    function hasDataOne(vehicle) {
        return !!vehicle?.DataOne;
    }

    function getMajordomeBulkInventoryVehicles() {
        if (Array.isArray(inventoryVehiclesSource)) {
            return inventoryVehiclesSource;
        }

        if (Array.isArray(inventoryVehicles)) {
            return inventoryVehicles;
        }

        return [];
    }

    function needsMajordomeBulkStory(vehicle) {
        const story = vehicle?.Story;
        const storyHtml = safeText(story?.HtmlContent).toUpperCase();
        return !story || storyHtml.indexOf("ERROR") >= 0;
    }

    function needsMajordomeBulkDataOne(vehicle) {
        return !hasDataOne(vehicle) && safeText(vehicle?.VIN).trim().length > 0;
    }

    function getMajordomeImageCount(vehicle) {
        if (Array.isArray(vehicle?.Images)) {
            return vehicle.Images.length;
        }

        return hasMajordomeImage(vehicle) ? 1 : 0;
    }

    function hasMajordomeBulkImages(vehicle) {
        return getMajordomeImageCount(vehicle) > 0;
    }

    function getMajordomeBulkVehicleByStock(stock) {
        const stockKey = safeText(stock).trim().toUpperCase();
        if (!stockKey) return null;

        if (selectedVehicle && safeText(selectedVehicle.Stock).trim().toUpperCase() === stockKey) {
            return selectedVehicle;
        }

        const sources = [inventoryVehicles, inventoryVehiclesSource];
        for (let i = 0; i < sources.length; i++) {
            const source = sources[i];
            if (!Array.isArray(source)) continue;

            const vehicle = source.find(function (item) {
                return safeText(item?.Stock).trim().toUpperCase() === stockKey;
            });

            if (vehicle) {
                return vehicle;
            }
        }

        return null;
    }

    function recordMajordomeBulkUploadPayload(stock, payload, job) {
        if (!job || !payload || !Array.isArray(payload.images)) {
            return false;
        }

        const vehicle = getMajordomeBulkVehicleByStock(stock);
        const currentCount = getMajordomeImageCount(vehicle);
        if (payload.images.length < currentCount) {
            return false;
        }

        const currentPayload = job.latestUploadPayload;
        const currentPayloadCount = Array.isArray(currentPayload?.images) ? currentPayload.images.length : -1;
        if (payload.images.length < currentPayloadCount) {
            return false;
        }

        job.latestUploadPayload = {
            stock: stock,
            images: payload.images,
            image: payload.image
        };

        return true;
    }

    function applyMajordomeBulkStoredUploadPayload(job) {
        const payload = job?.latestUploadPayload;
        if (!payload || !Array.isArray(payload.images) || typeof applyUploadedImagesToMajordomeState !== "function") {
            return false;
        }

        const applied = applyUploadedImagesToMajordomeState(payload.stock, payload.images, {
            image: payload.image,
            selectVehicle: true,
            updateGallery: true,
            activateGallery: true
        });

        return applied;
    }

    function getMajordomeBulkImageDeleteItems(settings) {
        const stock = safeText(settings?.stock).trim();
        const buildItems = function (vehicle) {
            const targetStock = safeText(vehicle?.Stock || stock).trim();
            const images = Array.isArray(vehicle?.Images) ? vehicle.Images : [];

            return images.map(function (image, index) {
                const source = safeText(image?.Source).trim();
                const label = getMajordomeImageFileLabel(source) || `image ${index + 1}`;

                return {
                    Stock: targetStock,
                    Id: safeText(image?.Id).trim(),
                    Source: source,
                    Label: label
                };
            }).filter(function (item) {
                return item.Stock && (item.Id || item.Source);
            });
        };

        if (stock) {
            const stockKey = stock.toUpperCase();
            const vehicle = getMajordomeBulkInventoryVehicles().find(function (item) {
                return safeText(item?.Stock).trim().toUpperCase() === stockKey;
            });

            if (vehicle) {
                return buildItems(vehicle);
            }

            return [];
        }

        return getMajordomeBulkInventoryVehicles()
            .filter(hasMajordomeBulkImages)
            .reduce(function (items, vehicle) {
                return items.concat(buildItems(vehicle));
            }, []);
    }

    function getMajordomeBulkVehicleLabel(vehicle) {
        const stock = safeText(vehicle?.Stock).trim();
        const description = [
            safeText(vehicle?.Year).trim(),
            safeText(vehicle?.Make).trim(),
            safeText(vehicle?.Model).trim()
        ].filter(function (part) {
            return part.length > 0;
        }).join(" ");

        if (stock && description) return `${stock} - ${description}`;
        return stock || description || safeText(vehicle?.VIN).trim() || "vehicle";
    }

    function getMajordomeBulkFileLabel(file) {
        return safeText(file?.name).trim() || "image";
    }

    function getMajordomeImageFileLabel(file) {
        return getMajordomeFileNameOnly(safeText(file).trim()) || "image";
    }

    function getMajordomeImageUploadFiles(files) {
        return Array.from(files || []).filter(function (file) {
            const name = safeText(file?.name).toLowerCase();
            const type = safeText(file?.type).toLowerCase();
            return type.indexOf("image/") === 0 || /\.(heic|heif|jpg|jpeg|png|webp|gif|bmp|tiff)$/.test(name);
        });
    }

    function syncMajordomeDataOneBulkLocalState(stock) {
        const stockKey = safeText(stock).trim().toUpperCase();
        if (!stockKey) return;

        const markDataOne = function (vehicle) {
            if (!vehicle) return;
            vehicle.DataOne = vehicle.DataOne || {};
        };

        if (selectedVehicle && safeText(selectedVehicle.Stock).trim().toUpperCase() === stockKey) {
            markDataOne(selectedVehicle);
        }

        if (Array.isArray(inventoryVehiclesSource)) {
            inventoryVehiclesSource.forEach(function (vehicle) {
                if (safeText(vehicle?.Stock).trim().toUpperCase() === stockKey) {
                    markDataOne(vehicle);
                }
            });
        }

        if (Array.isArray(inventoryVehicles)) {
            inventoryVehicles.forEach(function (vehicle) {
                if (safeText(vehicle?.Stock).trim().toUpperCase() === stockKey) {
                    markDataOne(vehicle);
                }
            });
        }

        const $row = $("#majordomeInventoryBody .majordome-vehicle-row").filter(function () {
            return safeText($(this).attr("data-stock")).trim().toUpperCase() === stockKey;
        }).first();

        if ($row.length) {
            $row.find(".majordome-status-dataone")
                .text("Y")
                .addClass("is-on");
        }
    }

    function syncMajordomeDataOneDeletedLocalState(stock) {
        const stockKey = safeText(stock).trim().toUpperCase();
        if (!stockKey) return;

        const clearDataOne = function (vehicle) {
            if (!vehicle) return;
            vehicle.DataOne = null;
        };

        const isSelectedStock = selectedVehicle && safeText(selectedVehicle.Stock).trim().toUpperCase() === stockKey;
        if (isSelectedStock) {
            clearDataOne(selectedVehicle);
            $("#dataOneDetails").empty();
        }

        if (Array.isArray(inventoryVehiclesSource)) {
            inventoryVehiclesSource.forEach(function (vehicle) {
                if (safeText(vehicle?.Stock).trim().toUpperCase() === stockKey) {
                    clearDataOne(vehicle);
                }
            });
        }

        if (Array.isArray(inventoryVehicles)) {
            inventoryVehicles.forEach(function (vehicle) {
                if (safeText(vehicle?.Stock).trim().toUpperCase() === stockKey) {
                    clearDataOne(vehicle);
                }
            });
        }

        const $row = $("#majordomeInventoryBody .majordome-vehicle-row").filter(function () {
            return safeText($(this).attr("data-stock")).trim().toUpperCase() === stockKey;
        }).first();

        if ($row.length) {
            $row.find(".majordome-status-dataone")
                .text("N")
                .removeClass("is-on");
        }
    }

    function buildMajordomeUploadFormData(stock, file) {
        const formData = new FormData();
        formData.append("files", file, file.name);
        formData.append("stock", stock);
        return formData;
    }

    function getMajordomeBulkUploadErrorMessage(error) {
        const message = safeText(error?.message).trim();
        if (!message || /^failed to fetch$/i.test(message)) {
            return "Upload connection was interrupted. The server may have reset the HTTP/2 upload request.";
        }

        return message;
    }

    function isMajordomeTransientUploadError(error) {
        const message = safeText(error?.message).toLowerCase();
        return error?.name === "AbortError" ||
            message.indexOf("failed to fetch") >= 0 ||
            message.indexOf("network") >= 0 ||
            message.indexOf("protocol") >= 0 ||
            message.indexOf("connection") >= 0 ||
            message.indexOf("timeout") >= 0 ||
            message.indexOf("interrupted") >= 0;
    }

    function parseMajordomeUploadErrorResponse(xhr) {
        const responseText = safeText(xhr?.responseText).trim();
        if (!responseText) return "";

        try {
            const payload = JSON.parse(responseText);
            return safeText(payload?.message || payload?.Message || payload?.errors?.join("; ")).trim();
        } catch (error) {
            return responseText;
        }
    }

    function postMajordomeUploadFormData(url, formData, job) {
        return new Promise(function (resolve, reject) {
            const request = $.ajax({
                url: url,
                type: "POST",
                data: formData,
                processData: false,
                contentType: false,
                dataType: "json",
                timeout: majordomeUploadRequestTimeoutMs,
                cache: false
            });

            if (job) {
                job.abortRequests = job.abortRequests || new Set();
                job.abortRequests.add(request);
            }

            request
                .done(function (payload) {
                    resolve(payload);
                })
                .fail(function (xhr, textStatus, errorThrown) {
                    if (job && job.cancelRequested) {
                        reject(new Error("Canceled."));
                        return;
                    }

                    if (textStatus === "timeout") {
                        reject(new Error(`Upload timed out after ${Math.round(majordomeUploadRequestTimeoutMs / 1000)} seconds.`));
                        return;
                    }

                    const status = xhr && xhr.status ? xhr.status : 0;
                    const message = parseMajordomeUploadErrorResponse(xhr) ||
                        safeText(errorThrown).trim() ||
                        safeText(textStatus).trim() ||
                        "Upload connection was interrupted. The server may have reset the HTTP/2 upload request.";
                    const error = new Error(message);
                    error.isHttpError = status > 0;
                    reject(error);
                })
                .always(function () {
                    if (job && job.abortRequests) {
                        job.abortRequests.delete(request);
                    }
                });
        });
    }

    async function uploadMajordomeBulkImageFile(stock, file, job) {
        const label = getMajordomeBulkFileLabel(file);
        let lastError = null;

        for (let attempt = 1; attempt <= majordomeUploadMaxAttempts; attempt++) {
            if (job && job.cancelRequested) {
                throw new Error("Canceled.");
            }

            try {
                const payload = await postMajordomeUploadFormData(`${root}Majordome/UploadInventoryFiles`, buildMajordomeUploadFormData(stock, file), job);

                if (payload && payload.success === false) {
                    const errors = Array.isArray(payload.errors) && payload.errors.length
                        ? payload.errors.join("; ")
                        : "";
                    const error = new Error(errors || payload.message || "Upload failed.");
                    error.isHttpError = true;
                    throw error;
                }

                const retrySuffix = attempt > 1 ? ` after retry ${attempt - 1}` : "";
                const uploadPayloadRecorded = recordMajordomeBulkUploadPayload(stock, payload, job);
                if (payload && payload.uploaded > 0) {
                    return { status: "success", message: `${label} uploaded${retrySuffix}.`, uploadPayloadRecorded: uploadPayloadRecorded };
                }

                if (payload && payload.skipped > 0) {
                    return { status: "warning", message: `${label} skipped${retrySuffix}.`, uploadPayloadRecorded: uploadPayloadRecorded };
                }

                return { status: "success", message: `${label} completed${retrySuffix}.`, uploadPayloadRecorded: uploadPayloadRecorded };
            } catch (error) {
                lastError = error;

                if (job && job.cancelRequested) {
                    throw new Error("Canceled.");
                }

                const canRetry = attempt < majordomeUploadMaxAttempts &&
                    !error?.isHttpError &&
                    isMajordomeTransientUploadError(error);

                if (!canRetry) {
                    break;
                }

                const delayMs = 700 + (attempt * 900) + Math.floor(Math.random() * 600);
                appendMajordomeBulkLog(`${label}: upload connection interrupted, retrying ${attempt + 1} of ${majordomeUploadMaxAttempts}...`, "warning");
                await waitMajordomeBulkDelay(delayMs, job);
            }
        }

        throw new Error(getMajordomeBulkUploadErrorMessage(lastError));
    }

    async function deleteMajordomeBulkImageFile(item) {
        const stock = safeText(item?.Stock).trim();
        const id = safeText(item?.Id).trim() || "00000000-0000-0000-0000-000000000000";
        const file = safeText(item?.Source).trim();
        const label = safeText(item?.Label).trim() || getMajordomeImageFileLabel(file);

        if (!stock) {
            throw new Error("Stock is required.");
        }

        if (!file && id === "00000000-0000-0000-0000-000000000000") {
            throw new Error("Image is required.");
        }

        const response = await postMajordome(`${root}Majordome/DeleteImage`, { id: id, file: file, stock: stock });
        if (!response || !response.success) {
            throw new Error((response && response.message) || "Failed to delete image.");
        }

        if (Array.isArray(response.images) && typeof applyUploadedImagesToMajordomeState === "function") {
            applyUploadedImagesToMajordomeState(response.stock || stock, response.images, {
                image: response.image,
                selectVehicle: true,
                updateGallery: true,
                activateGallery: true
            });
        }

        return {
            status: "success",
            message: `${label} deleted.`
        };
    }

    function getMajordomeBulkConfig(actionKey, options) {
        const settings = options || {};

        if (actionKey === "restory") {
            return {
                title: "Re-story all vehicles",
                emptyText: "No vehicles need a re-story.",
                intro: function (count) {
                    return `Ready to create stories for ${count} vehicles missing a story.`;
                },
                delayAfterMs: 1100,
                getItems: function () {
                    return getMajordomeBulkInventoryVehicles().filter(needsMajordomeBulkStory);
                },
                run: async function (vehicle) {
                    const stock = safeText(vehicle?.Stock).trim();
                    const response = await postMajordome(`${root}Majordome/CreateStory`, { stock });
                    if (!response || !response.success) {
                        throw new Error((response && response.message) || "Story creation failed.");
                    }

                    syncMajordomeStoryLocalState(stock, response.Title, response.Story);
                }
            };
        }

        if (actionKey === "dataone") {
            return {
                title: "Decode DataOne for all vehicles",
                emptyText: "No vehicles need DataOne decoding.",
                intro: function (count) {
                    return `Ready to decode DataOne for ${count} vehicles without saved DataOne details.`;
                },
                delayAfterMs: 0,
                getItems: function () {
                    return getMajordomeBulkInventoryVehicles().filter(needsMajordomeBulkDataOne);
                },
                run: async function (vehicle) {
                    const vin = safeText(vehicle?.VIN).trim();
                    const response = await postMajordome(`${root}Majordome/DecodeDataOne`, { vin });
                    if (!response || !response.success) {
                        throw new Error((response && response.message) || "DataOne decoding failed.");
                    }

                    syncMajordomeDataOneBulkLocalState(vehicle?.Stock);
                }
            };
        }

        if (actionKey === "images") {
            const stock = safeText(settings.stock).trim();
            const files = getMajordomeImageUploadFiles(settings.files);

            return {
                title: `Upload images for Stock# ${stock}`,
                emptyText: "No image files were selected.",
                cancelMessage: "Cancel requested. The current upload will stop if possible, then the remaining files will stop.",
                intro: function (count) {
                    const suffix = count === 1 ? "1 image" : `${count} images`;
                    return `Ready to upload ${suffix} for Stock# ${stock}.`;
                },
                getItems: function () {
                    return files;
                },
                getLabel: getMajordomeBulkFileLabel,
                run: async function (file, job) {
                    return uploadMajordomeBulkImageFile(stock, file, job);
                },
                afterCompleteStatus: "Updating image counts...",
                afterComplete: async function (job) {
                    window.majordomeSelectedStock = stock;
                    window.majordomeForceActiveTab = "gallery-tab";

                    if (job && applyMajordomeBulkStoredUploadPayload(job)) {
                        syncMajordomeGalleryAvailability();
                        syncMajordomeEmptyState();
                        $("#gallery-tab").tab("show");
                        return;
                    }

                    if (typeof refreshMajordomeAfterImageMutation === "function") {
                        setMajordomeBulkStatus("Refreshing inventory list...");
                        await refreshMajordomeAfterImageMutation(stock, { keepGalleryTab: true });
                        return;
                    }

                    setMajordomeBulkStatus("Refreshing inventory list...");
                    const data = await getUpdatedItems();
                    updateRow(data);
                }
            };
        }

        if (actionKey === "delete-images") {
            const stock = safeText(settings.stock).trim();
            if (!stock) return null;

            const items = getMajordomeBulkImageDeleteItems(settings);

            return {
                title: `Delete images for Stock# ${stock}`,
                emptyText: `No images to delete for Stock# ${stock}.`,
                cancelMessage: "Cancel requested. The current deletion will finish, then the remaining images will stop.",
                intro: function (count) {
                    const suffix = count === 1 ? "1 image" : `${count} images`;
                    return `Ready to delete ${suffix} for Stock# ${stock}.`;
                },
                getItems: function () {
                    return items;
                },
                getLabel: function (item) {
                    return safeText(item?.Label).trim() || getMajordomeImageFileLabel(item?.Source);
                },
                run: async function (item) {
                    return deleteMajordomeBulkImageFile(item);
                },
                afterCompleteStatus: "Updating image counts...",
                afterComplete: async function () {
                    syncMajordomeGalleryAvailability();
                    syncMajordomeEmptyState();
                }
            };
        }

        return null;
    }

