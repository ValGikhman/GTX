@using Newtonsoft.Json
@model GTX.Models.BaseModel
<head>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jqueryui-touch-punch/0.2.3/jquery.ui.touch-punch.min.js"></script>
    <script src="~/Scripts/just-validate/just-validate.production.min.js"></script>
    <script src="~/Scripts/majordome.js?v=@(System.IO.File.GetLastWriteTimeUtc(Server.MapPath("~/Scripts/majordome.js")).Ticks)"></script>

    <!-- Lightbox2 JS -->
    <link href="https://cdn.jsdelivr.net/npm/lightbox2@2/dist/css/lightbox.min.css" rel="stylesheet" />
    <script src="https://cdn.jsdelivr.net/npm/lightbox2@2/dist/js/lightbox.min.js"></script>

    <script src="https://cdn.jsdelivr.net/npm/sortablejs@1.15.0/Sortable.min.js"></script>

    <!-- Include stylesheet -->
    <link href="https://cdn.jsdelivr.net/npm/quill@2.0.3/dist/quill.snow.css" rel="stylesheet" />
    <!-- Include the Quill library -->
    <script src="https://cdn.jsdelivr.net/npm/quill@2.0.3/dist/quill.js"></script>
</head>

<div id="inventoryOverlay" class="spinner-overlay spinner-hidden">
    <div class="spinner-border text-primary" role="status">
        <span class="visually-hidden">Working...</span>
    </div>
</div>

<!-- Modal -->
<div class="modal modal-xl" id="overlayModal" data-bs-keyboard="true" tabindex="-1" aria-labelledby="overlayModal" aria-hidden="true">
    <div class=" modal-dialog modal-dialog-centered">
        <div id="vehicle-overlay" class="modal-content">
        </div>
    </div>
</div>

<div class="modal fade" id="majordomeBulkProgressModal" tabindex="-1" aria-labelledby="majordomeBulkProgressTitle" aria-hidden="true" data-bs-backdrop="static" data-bs-keyboard="false">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <div class="modal-title" id="majordomeBulkProgressTitle">Bulk update</div>
            </div>
            <div class="modal-body">
                <p id="majordomeBulkProgressIntro" class="mb-2"></p>
                <div id="majordomeBulkProgressSummary" class="majordome-inventory-summary small mb-2 d-none" aria-live="polite"></div>
                <div class="d-flex justify-content-between small text-muted mb-1">
                    <span id="majordomeBulkProgressCounts">0 of 0</span>
                    <span id="majordomeBulkProgressPercent">0%</span>
                </div>
                <div id="majordomeBulkProgressTrack" class="progress" role="progressbar" aria-label="Bulk update progress" aria-valuemin="0" aria-valuemax="100" aria-valuenow="0">
                    <div id="majordomeBulkProgressBar" class="progress-bar progress-bar-striped"></div>
                </div>
                <div id="majordomeBulkProgressStatus" class="small mt-3"></div>
                <div id="majordomeBulkProgressLog" class="majordome-bulk-progress-log list-group small mt-3" aria-live="polite"></div>
            </div>
            <div class="modal-footer">
                <button type="button" id="majordomeBulkCancel" class="btn btn-outline-secondary">Cancel</button>
                <button type="button" id="majordomeBulkStart" class="btn btn-gradient">Start</button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade majordome-editor-modal" id="majordomeInventoryEditorModal" tabindex="-1" aria-labelledby="majordomeInventoryEditorTitle" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header majordome-editor-hero d-flex align-items-center justify-content-between border-0">
                <div class="d-flex align-items-center gap-3">
                    <div class="majordome-editor-icon">
                        <i class="bi bi-pencil-square"></i>
                    </div>
                    <div>
                        <div class="modal-title majordome-editor-title mb-0" id="majordomeInventoryEditorTitle">Inventory item</div>
                    </div>
                </div>
                <div class="d-flex align-items-center gap-2">
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
            </div>
            <form id="majordomeInventoryEditorForm" novalidate>
                <div class="modal-body majordome-editor-body">
                    <div id="majordomeInventoryEditorAlert" class="alert alert-danger d-none" role="alert"></div>
                    <input type="hidden" id="majordomeInventoryEditorOriginalStock" name="OriginalStock" />
                    <input type="hidden" id="majordomeInventoryEditorMode" />

                    <div class="majordome-editor-sections">
                    <div class="majordome-editor-section majordome-editor-section-identity">
                        <div class="majordome-editor-section-title">
                            <i class="bi bi-card-checklist"></i>Vehicle identity
                        </div>
                        <div class="majordome-editor-grid majordome-editor-identity-grid">
                            <div class="majordome-editor-id-stock">
                                <label class="form-label" for="majordomeInventoryEditorStock"><i class="bi bi-hash majordome-editor-label-icon" aria-hidden="true"></i>Stock</label>
                                <input type="text" class="form-control shadow-sm" id="majordomeInventoryEditorStock" name="Stock" data-inventory-field="Stock" maxlength="9" required />
                                <div class="invalid-feedback"></div>
                            </div>
                            <div class="majordome-editor-id-vin">
                                <label class="form-label" for="majordomeInventoryEditorVIN"><i class="bi bi-upc-scan majordome-editor-label-icon" aria-hidden="true"></i>VIN</label>
                                <div class="input-group">
                                    <input type="text" class="form-control shadow-sm" id="majordomeInventoryEditorVIN" name="VIN" data-inventory-field="VIN" maxlength="17" />
                                    <button type="button" id="majordomeInventoryDecodeVin" class="btn btn-gradient-grey border-dark" title="Decode VIN and fill inventory fields">
                                        <i class="bi bi-search"></i>
                                    </button>
                                </div>
                                <div class="invalid-feedback"></div>
                            </div>
                            <div class="majordome-editor-id-upload">
                                <label class="form-label" for="majordomeInventoryEditorSetToUpload"><i class="bi bi-cloud-arrow-up majordome-editor-label-icon" aria-hidden="true"></i>Upload</label>
                                <select class="form-select majordome-editor-select" id="majordomeInventoryEditorSetToUpload" name="SetToUpload" data-inventory-field="SetToUpload">
                                    <option value="Y">Y</option>
                                    <option value="N">N</option>
                                </select>
                                <div class="invalid-feedback"></div>
                            </div>
                            <div class="majordome-editor-id-gtx">
                                <label class="form-label" for="majordomeInventoryEditorLocationCode"><i class="bi bi-geo-alt majordome-editor-label-icon" aria-hidden="true"></i>GTX</label>
                                <select class="form-select majordome-editor-select" id="majordomeInventoryEditorLocationCode" name="LocationCode" data-inventory-field="LocationCode" data-allow-new="true" maxlength="1"></select>
                                <div class="invalid-feedback"></div>
                            </div>
                            <div class="majordome-editor-id-year">
                                <label class="form-label" for="majordomeInventoryEditorYear"><i class="bi bi-calendar2-event majordome-editor-label-icon" aria-hidden="true"></i>Year</label>
                                <input type="number" class="form-control shadow-sm" id="majordomeInventoryEditorYear" name="Year" data-inventory-field="Year" step="1" />
                                <div class="invalid-feedback"></div>
                            </div>
                            <div class="majordome-editor-id-make">
                                <label class="form-label" for="majordomeInventoryEditorMake"><i class="bi bi-building majordome-editor-label-icon" aria-hidden="true"></i>Make</label>
                                <select class="form-select majordome-editor-select" id="majordomeInventoryEditorMake" name="Make" data-inventory-field="Make" data-allow-new="true" maxlength="50"></select>
                                <div class="invalid-feedback"></div>
                            </div>
                            <div class="majordome-editor-id-model">
                                <label class="form-label" for="majordomeInventoryEditorModel"><i class="bi bi-car-front majordome-editor-label-icon" aria-hidden="true"></i>Model</label>
                                <select class="form-select majordome-editor-select" id="majordomeInventoryEditorModel" name="Model" data-inventory-field="Model" data-allow-new="true" maxlength="50"></select>
                                <div class="invalid-feedback"></div>
                            </div>
                            <div class="majordome-editor-id-style">
                                <label class="form-label" for="majordomeInventoryEditorVehicleStyle"><i class="bi bi-brush majordome-editor-label-icon" aria-hidden="true"></i>Style</label>
                                <input type="text" class="form-control shadow-sm" id="majordomeInventoryEditorVehicleStyle" name="VehicleStyle" data-inventory-field="VehicleStyle" maxlength="50" />
                                <div class="invalid-feedback"></div>
                            </div>
                            <div class="majordome-editor-id-type">
                                <label class="form-label" for="majordomeInventoryEditorVehicleType"><i class="bi bi-tags majordome-editor-label-icon" aria-hidden="true"></i>Type</label>
                                <select class="form-select majordome-editor-select" id="majordomeInventoryEditorVehicleType" name="VehicleType" data-inventory-field="VehicleType" data-allow-new="true" maxlength="50"></select>
                                <div class="invalid-feedback"></div>
                            </div>
                        </div>
                    </div>

                    <div class="majordome-editor-section majordome-editor-section-pricing">
                        <div class="majordome-editor-section-title">
                            <i class="bi bi-cash-stack"></i>Pricing &amp; mileage
                        </div>
                        <div class="majordome-editor-grid majordome-editor-pricing-grid">
                            <div>
                                <label class="form-label" for="majordomeInventoryEditorMileage"><i class="bi bi-speedometer2 majordome-editor-label-icon" aria-hidden="true"></i>Mileage</label>
                                <input type="text" class="form-control shadow-sm" id="majordomeInventoryEditorMileage" name="Mileage" data-inventory-field="Mileage" data-number-format-field="true" inputmode="numeric" />
                                <div class="invalid-feedback"></div>
                            </div>
                            <div>
                                <label class="form-label" for="majordomeInventoryEditorRetailPrice"><i class="bi bi-cash-coin majordome-editor-label-icon" aria-hidden="true"></i>Retail price</label>
                                <input type="text" class="form-control shadow-sm" id="majordomeInventoryEditorRetailPrice" name="RetailPrice" data-inventory-field="RetailPrice" data-currency-field="true" inputmode="numeric" />
                                <div class="invalid-feedback"></div>
                            </div>
                            <div>
                                <label class="form-label" for="majordomeInventoryEditorInternetPrice"><i class="bi bi-globe2 majordome-editor-label-icon" aria-hidden="true"></i>Internet price</label>
                                <input type="text" class="form-control shadow-sm" id="majordomeInventoryEditorInternetPrice" name="InternetPrice" data-inventory-field="InternetPrice" data-currency-field="true" inputmode="numeric" />
                                <div class="invalid-feedback"></div>
                            </div>
                        </div>
                    </div>

                    <div class="majordome-editor-section majordome-editor-section-mechanical">
                        <div class="majordome-editor-section-title">
                            <i class="bi bi-gear-fill"></i>Mechanical specifications
                        </div>
                        <div class="majordome-editor-grid majordome-editor-mechanical-grid">
                            <div>
                                <label class="form-label" for="majordomeInventoryEditorCylinders"><i class="bi bi-123 majordome-editor-label-icon" aria-hidden="true"></i>Cylinders</label>
                                <select class="form-select majordome-editor-select" id="majordomeInventoryEditorCylinders" name="Cylinders" data-inventory-field="Cylinders" data-allow-new="true"></select>
                                <div class="invalid-feedback"></div>
                            </div>
                            <div>
                                <label class="form-label" for="majordomeInventoryEditorWeight"><i class="bi bi-box-seam majordome-editor-label-icon" aria-hidden="true"></i>Weight</label>
                                <input type="number" class="form-control shadow-sm" id="majordomeInventoryEditorWeight" name="Weight" data-inventory-field="Weight" step="1" />
                                <div class="invalid-feedback"></div>
                            </div>
                            <div>
                                <label class="form-label" for="majordomeInventoryEditorTransmissionSpeed"><i class="bi bi-speedometer majordome-editor-label-icon" aria-hidden="true"></i>Speeds</label>
                                <select class="form-select majordome-editor-select" id="majordomeInventoryEditorTransmissionSpeed" name="TransmissionSpeed" data-inventory-field="TransmissionSpeed" data-allow-new="true"></select>
                                <div class="invalid-feedback"></div>
                            </div>
                            <div>
                                <label class="form-label" for="majordomeInventoryEditorTransmission"><i class="bi bi-diagram-3 majordome-editor-label-icon" aria-hidden="true"></i>Trans.</label>
                                <select class="form-select majordome-editor-select" id="majordomeInventoryEditorTransmission" name="Transmission" data-inventory-field="Transmission" data-allow-new="true" maxlength="1"></select>
                                <div class="invalid-feedback"></div>
                            </div>
                            <div>
                                <label class="form-label" for="majordomeInventoryEditorDriveTrain"><i class="bi bi-signpost-split majordome-editor-label-icon" aria-hidden="true"></i>Drive train</label>
                                <select class="form-select majordome-editor-select" id="majordomeInventoryEditorDriveTrain" name="DriveTrain" data-inventory-field="DriveTrain" data-allow-new="true" maxlength="50"></select>
                                <div class="invalid-feedback"></div>
                            </div>
                            <div>
                                <label class="form-label" for="majordomeInventoryEditorFuelType"><i class="bi bi-fuel-pump majordome-editor-label-icon" aria-hidden="true"></i>Fuel</label>
                                <select class="form-select majordome-editor-select" id="majordomeInventoryEditorFuelType" name="FuelType" data-inventory-field="FuelType" data-allow-new="true" maxlength="50"></select>
                                <div class="invalid-feedback"></div>
                            </div>
                            <div>
                                <label class="form-label" for="majordomeInventoryEditorBody"><i class="bi bi-car-front-fill majordome-editor-label-icon" aria-hidden="true"></i>Body</label>
                                <select class="form-select majordome-editor-select" id="majordomeInventoryEditorBody" name="Body" data-inventory-field="Body" data-allow-new="true" maxlength="50"></select>
                                <div class="invalid-feedback"></div>
                            </div>
                            <div>
                                <label class="form-label" for="majordomeInventoryEditorEngine"><i class="bi bi-gear-wide-connected majordome-editor-label-icon" aria-hidden="true"></i>Engine</label>
                                <select class="form-select majordome-editor-select" id="majordomeInventoryEditorEngine" name="Engine" data-inventory-field="Engine" data-allow-new="true" maxlength="50"></select>
                                <div class="invalid-feedback"></div>
                            </div>
                            <div>
                                <label class="form-label" for="majordomeInventoryEditorColor"><i class="bi bi-palette majordome-editor-label-icon" aria-hidden="true"></i>Color</label>
                                <input type="text" class="form-control shadow-sm" id="majordomeInventoryEditorColor" name="Color" data-inventory-field="Color" maxlength="50" />
                                <div class="invalid-feedback"></div>
                            </div>
                            <div>
                                <label class="form-label" for="majordomeInventoryEditorColor2"><i class="bi bi-palette majordome-editor-label-icon" aria-hidden="true"></i>Color 2</label>
                                <input type="text" class="form-control shadow-sm" id="majordomeInventoryEditorColor2" name="Color2" data-inventory-field="Color2" maxlength="50" />
                                <div class="invalid-feedback"></div>
                            </div>
                        </div>
                    </div>

                    <div class="majordome-editor-section majordome-editor-section-dates mb-0">
                        <div class="majordome-editor-section-title">
                            <i class="bi bi-calendar-week"></i>Dates &amp; features
                        </div>
                        <div class="majordome-editor-grid">
                            <div>
                                <label class="form-label" for="majordomeInventoryEditorPurchaseDate"><i class="bi bi-calendar-check majordome-editor-label-icon" aria-hidden="true"></i>Purchase date</label>
                                <input type="text" class="form-control shadow-sm majordome-editor-datepicker" id="majordomeInventoryEditorPurchaseDate" name="PurchaseDate" data-inventory-field="PurchaseDate" maxlength="50" autocomplete="off" />
                                <div class="invalid-feedback"></div>
                            </div>
                            <div>
                                <label class="form-label" for="majordomeInventoryEditorArrivalDate"><i class="bi bi-calendar-plus majordome-editor-label-icon" aria-hidden="true"></i>Arrival date</label>
                                <input type="text" class="form-control shadow-sm majordome-editor-datepicker" id="majordomeInventoryEditorArrivalDate" name="ArrivalDate" data-inventory-field="ArrivalDate" maxlength="50" autocomplete="off" />
                                <div class="invalid-feedback"></div>
                            </div>
                            <div class="majordome-editor-field-full">
                                <label class="form-label" for="majordomeInventoryEditorFeatures"><i class="bi bi-list-check majordome-editor-label-icon" aria-hidden="true"></i>Features</label>
                                <textarea class="form-control shadow-sm" id="majordomeInventoryEditorFeatures" name="Features" data-inventory-field="Features"></textarea>
                                <div class="invalid-feedback"></div>
                            </div>
                        </div>
                    </div>
                    </div>
                </div>
                <div class="modal-footer majordome-editor-footer">
                    <button type="button" class="btn btn-outline-secondary majordome-editor-cancel-btn" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-gradient shadow majordome-editor-save-btn" id="majordomeInventoryEditorSave">
                        <i class="bi bi-check2-circle me-1"></i>Save inventory
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="this-container container-fluid px-5 my-3">
    <nav class="nav nav-tabs no-wrap-group" id="myTab" role="tablist">
        <button class="btn btn-gradient-grey text-shadow-small active" id="inventory-tab" data-bs-toggle="tab" data-bs-target="#tab-inventory" type="button" role="tab">
            Inventory
        </button>
        <button class="btn btn-gradient-grey text-shadow-small" id="details-tab" data-bs-toggle="tab" data-bs-target="#tab-details" type="button" role="tab">
            Details
        </button>
        <button class="btn btn-gradient-grey text-shadow-small" id="gallery-tab" data-bs-toggle="tab" data-bs-target="#tab-gallery" type="button" role="tab">
            Photos
        </button>

        <button class="btn btn-gradient-grey text-shadow-small d-none" id="QR-code-tab" data-bs-toggle="tab" data-bs-target="#tab-qr-code" type="button" role="tab">
            QR Code
        </button>
        <div id="specials" class="d-none d-lg-block d-flex ms-auto"></div>
    </nav>

    <div class="tab-content border border-top-0 well " id="myTabContent">
        @Html.Partial("_Majordome-Inventory")
        @Html.Partial("_Majordome-Details")
        @Html.Partial("_Majordome-Gallery")
        @Html.Partial("_Majordome-QRCode")
    </div>
</div>
<template id="actions">
    <button type="button" id="btnAddInventory" class="btn btn-gradient shadow"><i class="bi bi-plus-circle me-1"></i>Add inventory</button>
    <button type="button" id="btnDecodeAll" class="btn btn-gradient shadow">Decode all</button>
    <button type="button" id="btnReStoryAll" class="btn btn-gradient shadow">Re-story all</button>
</template>

<input type="hidden" id="currentVehicle" />

@Html.Partial("_Majordome-VehicleCellsScript")

<script type="text/javascript">
    const $dropzone = $("#dropzone");
    const inventoryVehiclesSourceJson = "@Html.Raw(System.Web.HttpUtility.JavaScriptStringEncode(JsonConvert.SerializeObject(Model.Inventory.Vehicles ?? Array.Empty<GTX.Models.GTX>())))";
    let inventoryVehiclesSource = JSON.parse(inventoryVehiclesSourceJson);
    let inventoryVehicles = [];
    let selectedVehicleStock = null;
    let majordomeBulkJob = null;
    window.majordomeSelectedStock = "";
    const majordomeSortState = { key: "", direction: "" };
    const majordomeUploadMaxAttempts = 3;
    const majordomeUploadRequestTimeoutMs = 120000;
    const majordomeInventoryEditorFields = [
        "Stock",
        "Year",
        "Make",
        "Model",
        "VIN",
        "Mileage",
        "Cylinders",
        "Weight",
        "Color",
        "Color2",
        "Features",
        "RetailPrice",
        "InternetPrice",
        "DriveTrain",
        "LocationCode",
        "Body",
        "Engine",
        "Transmission",
        "PurchaseDate",
        "ArrivalDate",
        "FuelType",
        "TransmissionSpeed",
        "VehicleType",
        "VehicleStyle",
        "SetToUpload"
    ];
    const majordomeInventoryEditorStringLimits = {
        Stock: 9,
        Make: 50,
        Model: 50,
        VIN: 17,
        Color: 50,
        Color2: 50,
        DriveTrain: 50,
        LocationCode: 1,
        Body: 50,
        Engine: 50,
        Transmission: 1,
        PurchaseDate: 50,
        ArrivalDate: 50,
        FuelType: 50,
        VehicleType: 50,
        VehicleStyle: 50,
        SetToUpload: 1
    };
    const majordomeInventoryEditorNumberFields = [
        "Year",
        "Mileage",
        "Cylinders",
        "Weight",
        "RetailPrice",
        "InternetPrice",
        "TransmissionSpeed"
    ];
    const majordomeInventoryEditorSelectFields = [
        "Make",
        "Model",
        "LocationCode",
        "VehicleType",
        "Cylinders",
        "TransmissionSpeed",
        "Transmission",
        "DriveTrain",
        "FuelType",
        "Body",
        "Engine",
        "SetToUpload"
    ];
    const majordomeInventoryEditorNewOptionValue = "__majordome_new_option__";
    const majordomeInventoryEditorCurrencyFields = [
        "RetailPrice",
        "InternetPrice"
    ];
    const majordomeInventoryEditorFormattedNumberFields = [
        "Mileage"
    ];

    const toolbarOptions = [
        ['bold', 'italic', 'underline', 'strike'],        // toggled buttons
        //['blockquote', 'code-block'],
        ['link', 'image', 'video'],

        //[{ 'header': 1 }, { 'header': 2 }],               // custom button values
        //[{ 'list': 'ordered' }, { 'list': 'bullet' }, { 'list': 'check' }],
        //[{ 'script': 'sub' }, { 'script': 'super' }],      // superscript/subscript
        [{ 'indent': '-1' }, { 'indent': '+1' }],          // outdent/indent
        //[{ 'direction': 'rtl' }],                         // text direction

        [{ 'size': ['small', false, 'large', 'huge'] }],  // custom dropdown
        [{ 'header': [1, 2, 3, 4, 5, 6, false] }],

        [{ 'color': [] }, { 'background': [] }],          // dropdown with defaults from theme
        [{ 'font': [] }],
        [{ 'align': [] }]

        //['clean']                                         // remove formatting button
    ];

    const quill = new Quill('#story', {
        modules: {
            toolbar: toolbarOptions
        },
        theme: 'snow'
    });

    $(function () {
        renderMajordomeInventoryRows(inventoryVehiclesSource);
        selectFirstVisibleMajordomeVehicle();

        const initialStock = "@ViewBag.Stock";
        if (initialStock !== null && initialStock !== "") {
            $("#filterTerm").val(initialStock);
            applyFilterTerm(initialStock);
            selectFirstVisibleMajordomeVehicle(false);
        } else if (window.gtxInventorySearch) {
            const storedTerm = window.gtxInventorySearch.readStoredTerm();
            if (storedTerm) {
                $("#filterTerm").val(storedTerm);
                applyFilterTerm(storedTerm);
                selectFirstVisibleMajordomeVehicle(false);
            }
        }

        // Drag & drop events
        const prevent = e => { e.preventDefault(); e.stopPropagation(); };
            ["dragenter","dragover","dragleave","drop"].forEach(evt => {
            $dropzone.on(evt, prevent);
        });

        $dropzone.on("dragover", () => $dropzone.addClass("dragover"));
        $dropzone.on("dragleave drop", () => $dropzone.removeClass("dragover"));
        $dropzone.on("drop", (e) => {
            const dt = e.originalEvent.dataTransfer;
            if (dt && dt.files) handleFiles(dt.files);
        });

        $dropzone.on('paste', function (e) {
            const oe = e.originalEvent;
            const dt = oe.clipboardData;
            if (!dt) return;

            // Prefer actual files (screenshots, copied files)
            if (dt.files && dt.files.length) {
                e.preventDefault();
                handleFiles(dt.files);
                return;
            }

            // Fallback: items -> File
            const items = (dt.items ? Array.from(dt.items) : [])
                .filter(i => i.kind === 'file')
