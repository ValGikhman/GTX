@using Newtonsoft.Json
@model GTX.Models.BaseModel
<head>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jqueryui-touch-punch/0.2.3/jquery.ui.touch-punch.min.js"></script>
    <script src="~/Scripts/just-validate/just-validate.production.min.js"></script>
    <script src="~/Scripts/majordome.js?v=@(System.IO.File.GetLastWriteTimeUtc(Server.MapPath("~/Scripts/majordome.js")).Ticks)"></script>

    <style>
        #dataOneContainer {
            overflow-y: auto;
            height: 37rem;
        }

        .filterLiked, .filterLast, .filterHelp, .sort {
            display: none !important;
        }

        #filterWrapper {
            width: min(100%, 520px) !important;
        }

        .dropzone {
            --dz-label-size: clamp(26px, 2.4vw, 28px);
            transition: background-color .15s, border-color .15s;
        }

            .dropzone::after {
                content: "Drop your files here";
                position: absolute;
                inset: 0; /* top/right/bottom/left: 0 */
                display: grid; /* easy centering */
                place-items: center; /* center both axes */
                font-size: var(--dz-label-size);
                font-weight: 800;
                color: #333;
                opacity: 0;
                pointer-events: none; /* don't block drops */
                transition: opacity .15s;
            }

            .dropzone.dragover {
                background: #bbb;
                border: 3px dashed #727171;
            }

                .dropzone.dragover::after {
                    opacity: 1;
                }

        #sortable-gallery {
            margin: 0;
            padding: 0;
            gap: .85rem;
        }

            #sortable-gallery > li.majordome-photo-card {
                list-style: none;
                width: 320px;
                max-width: 100%;
                min-height: 0;
                display: flex;
                flex-direction: column;
                padding: 0;
                border: 1px solid rgba(15, 23, 42, .14);
                border-radius: .75rem;
                overflow: hidden;
                background: #fff;
                box-shadow: 0 .45rem 1rem rgba(15, 23, 42, .12);
            }

        .majordome-photo-link {
            display: block;
            text-decoration: none;
            color: inherit;
        }

        .majordome-photo-media {
            width: 100%;
            aspect-ratio: 4 / 3;
            display: flex;
            align-items: center;
            justify-content: center;
            background: #eef2f7;
            border-bottom: 1px solid rgba(15, 23, 42, .1);
            overflow: hidden;
        }

        .majordome-photo-image {
            width: 100%;
            height: 100%;
            display: block;
            object-fit: contain;
            object-position: center;
            background: #fff;
        }

        .majordome-photo-card.is-landscape .majordome-photo-media {
            padding: 0;
        }

        .majordome-photo-card.is-landscape .majordome-photo-image {
            object-fit: cover;
            background: transparent;
        }

        .majordome-photo-card.is-portrait .majordome-photo-image {
            object-fit: contain;
        }

        .majordome-photo-footer {
            margin-top: auto;
            display: flex;
            flex-direction: column;
            align-items: flex-start;
            justify-content: flex-start;
            gap: .45rem;
            padding: .5rem .55rem;
            background: #f8fafc;
            border-top: 1px solid rgba(15, 23, 42, .1);
        }

        .majordome-photo-title {
            width: 100%;
            font-size: .72rem;
            line-height: 1.2;
            font-weight: 600;
            color: #475569;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .majordome-photo-actions {
            width: 100%;
            display: flex;
            align-items: center;
            justify-content: flex-start;
            gap: .4rem;
        }

            .majordome-photo-actions .btn {
                width: 2rem;
                height: 2rem;
                padding: 0;
                display: inline-flex;
                align-items: center;
                justify-content: center;
                border-radius: .5rem;
            }

        .sortable-placeholder {
            border: 2px dashed #bbb;
            background: #f8f9fa;
            height: 160px;
            border-radius: .5rem;
        }

        #specials {
            margin-top: 0px;
        }

        #filterByTerm {
            position: relative !important;
            background: none;
            padding: unset;
            box-shadow: none
        }

        .majordome-inventory-shell {
            background: #fff;
            margin-top: .75rem;
            border-radius: 1rem;
            box-shadow: 0 .75rem 1.8rem rgba(15, 23, 42, .08);
        }

        .majordome-inventory-header {
            border-bottom: 1px solid rgba(15, 23, 42, .1);
            background: linear-gradient(180deg, #fff 0%, #f8fafc 100%);
        }

        .majordome-inventory-title {
            font-size: 1rem;
            font-weight: 700;
            letter-spacing: .02em;
            color: #0f172a;
        }

        #inventoryGridShell #filtersWrap {
            width: 100%;
            max-width: 540px;
        }

        #inventoryGridShell #filterByTerm {
            margin: 0;
            padding: 0 !important;
            justify-content: center;
            gap: .75rem;
        }

            #inventoryGridShell #filterByTerm .inventory-term-search {
                width: 100%;
                justify-content: center;
            }

            #inventoryGridShell #filterByTerm #filterWrapper {
                width: min(100%, 540px) !important;
                margin-left: auto;
                margin-right: auto;
            }

            #inventoryGridShell #filterByTerm #filterTerm {
                min-height: 2.5rem;
            }

        .majordome-inventory-table-wrap {
            max-height: 66vh;
        }

            .majordome-inventory-table-wrap thead th {
                position: sticky;
                top: 0;
                z-index: 2;
                font-size: .8rem;
                text-transform: uppercase;
                letter-spacing: .03em;
                border-bottom: 1px solid rgba(15, 23, 42, .16);
                white-space: nowrap;
            }

        .majordome-sortable-th {
            cursor: pointer;
            user-select: none;
        }

            .majordome-sortable-th .majordome-sort-indicator {
                display: inline-block;
                width: 1rem;
                margin-left: .3rem;
                font-size: .9rem;
                font-weight: 900;
                line-height: 1;
                text-align: center;
                vertical-align: middle;
                color: #0f172a;
                opacity: .45;
                transition: opacity .15s;
            }

            .majordome-sortable-th.is-active .majordome-sort-indicator {
                opacity: 1;
            }

        #majordomeInventoryBody .majordome-vehicle-row {
            cursor: pointer;
        }

            #majordomeInventoryBody .majordome-vehicle-row.is-selected {
                background: linear-gradient(180deg, rgba(21, 90, 150, .08) 0%, rgba(30, 115, 190, .1) 100%);
            }

        .majordome-thumb {
            width: 88px;
            height: 66px;
            object-fit: cover;
            border-radius: .5rem;
            border: 1px solid rgba(15, 23, 42, .16);
            box-shadow: 0 .3rem .9rem rgba(15, 23, 42, .18);
            background: #fff;
        }

        .majordome-row-details {
            max-width: 220px;
        }

        .majordome-vehicle-title {
            font-size: .95rem;
            font-weight: 700;
            line-height: 1.2;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .majordome-vehicle-meta {
            font-size: .8rem;
            color: #64748b;
            line-height: 1.25;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .majordome-status-pill {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            min-width: 1.45rem;
            min-height: 1.45rem;
            border-radius: 999px;
            border: 1px solid rgba(15, 23, 42, .18);
            font-size: .75rem;
            font-weight: 800;
            line-height: 1;
            background: #f8fafc;
            color: #0f172a;
        }

            .majordome-status-pill.is-on {
                border-color: rgba(22, 163, 74, .45);
                background: rgba(22, 163, 74, .12);
                color: #166534;
            }

            .majordome-status-pill.is-gtx-x {
                border-color: rgba(29, 78, 216, .5);
                background: rgba(37, 99, 235, .14);
                color: #1d4ed8;
            }

            .majordome-status-pill.is-gtx-t {
                border-color: rgba(185, 28, 28, .45);
                background: rgba(220, 38, 38, .14);
                color: #b91c1c;
            }

            .majordome-status-pill.is-gtx-g {
                border-color: rgba(22, 163, 74, .45);
                background: rgba(22, 163, 74, .12);
                color: #166534;
            }

        .majordome-actions {
            display: inline-grid;
            grid-template-columns: repeat(3, max-content);
            gap: .2rem;
            min-width: 0;
            width: auto;
            text-align: left;
        }

        .majordome-action-group {
            display: flex;
            flex-direction: column;
            align-items: flex-start;
            gap: .15rem;
            padding: .2rem .25rem;
            border: 1px solid rgba(15, 23, 42, .12);
            border-radius: .55rem;
            background: #f8fafc;
        }

        .majordome-action-title {
            font-size: .56rem;
            line-height: 1.1;
            letter-spacing: .02em;
            font-weight: 700;
            text-transform: uppercase;
            color: #475569;
        }

        .majordome-action-buttons {
            display: flex;
            align-items: center;
            justify-content: flex-start;
            gap: .2rem;
            flex-wrap: nowrap;
        }

            .majordome-actions .btn {
                width: 1.7rem;
                height: 1.7rem;
                display: inline-flex;
                align-items: center;
                justify-content: center;
                padding: 0;
                border-radius: .4rem;
            }

        #majordomeInventoryTable th.majordome-actions-col,
        #majordomeInventoryTable td.majordome-actions-cell {
            width: 1%;
            white-space: nowrap;
        }

        @@media (max-width: 991.98px) {
            .this-container {
                padding-left: 1rem !important;
                padding-right: 1rem !important;
            }

            .majordome-inventory-header .d-flex {
                align-items: stretch !important;
            }

            #inventoryGridShell #filterByTerm {
                justify-content: center;
            }

                #inventoryGridShell #filterByTerm .inventory-term-search {
                    justify-content: center;
                }

            .majordome-inventory-table-wrap {
                max-height: none;
            }
        }

        @@media (max-width: 767.98px) {
            .majordome-thumb {
                width: 76px;
                height: 56px;
            }

            .majordome-row-details {
                max-width: 170px;
            }

            .majordome-actions {
                grid-template-columns: 1fr;
                min-width: 0;
            }

                .majordome-actions .btn {
                    width: 1.85rem;
                    height: 1.85rem;
                }
        }

        #story .ql-editor {
            min-height: 480px;
            max-height: 480px;
            overflow-y: auto;
        }


            #story .ql-editor p {
                margin-top: 10px;
                margin-bottom: 10px;
                padding: 0;
                font-size: clamp(0.9rem, 2vw, 1rem);
                text-align: justify;
            }

            /*So I need to override them for Quill*/
            #story .ql-editor strong {
                margin-top: 10px;
                margin-bottom: 10px;
                padding: 0;
                font-size: clamp(0.9rem, 2vw, 1rem);
                text-align: justify;
            }

        /*Quill strips away p-story and strong-story classes*/
        .p-story {
            margin-top: 10px;
            margin-bottom: 10px;
            padding: 0;
            font-size: clamp(0.9rem, 2vw, 1rem);
            text-align: justify;
        }

        .strong-story {
            color: black;
        }

        .majordome-bulk-progress-log {
            max-height: 12rem;
            overflow-y: auto;
        }

            .majordome-bulk-progress-log .list-group-item {
                padding: .4rem .55rem;
            }

        #majordomeBulkProgressBar {
            background: var(--gtx-grad, var(--bs-primary, #0d6efd));
            color: #fff;
        }

    </style>

    <!-- Lightbox2 JS -->
    <link href="https://cdn.jsdelivr.net/npm/lightbox2@2/dist/css/lightbox.min.css" rel="stylesheet" />
    <script src="https://cdn.jsdelivr.net/npm/lightbox2@2/dist/js/lightbox.min.js"></script>

    <script src="https://cdn.jsdelivr.net/npm/sortablejs@1.15.0/Sortable.min.js"></script>

    <!-- Include stylesheet -->
    <link href="https://cdn.jsdelivr.net/npm/quill@2.0.3/dist/quill.snow.css" rel="stylesheet" />
    <!-- Include the Quill library -->
    <script src="https://cdn.jsdelivr.net/npm/quill@2.0.3/dist/quill.js"></script>
</head>

<div id="inventoryOverlay" class="spinner-overlay spinner-hidden">
    <div class="spinner-border text-primary" role="status">
        <span class="visually-hidden">Working...</span>
    </div>
</div>

<!-- Modal -->
<div class="modal modal-xl" id="overlayModal" data-bs-keyboard="true" tabindex="-1" aria-labelledby="overlayModal" aria-hidden="true">
    <div class=" modal-dialog modal-dialog-centered">
        <div id="vehicle-overlay" class="modal-content">
        </div>
    </div>
</div>

<div class="modal fade" id="majordomeBulkProgressModal" tabindex="-1" aria-labelledby="majordomeBulkProgressTitle" aria-hidden="true" data-bs-backdrop="static" data-bs-keyboard="false">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="majordomeBulkProgressTitle">Bulk update</h5>
            </div>
            <div class="modal-body">
                <p id="majordomeBulkProgressIntro" class="mb-2"></p>
                <div class="d-flex justify-content-between small text-muted mb-1">
                    <span id="majordomeBulkProgressCounts">0 of 0</span>
                    <span id="majordomeBulkProgressPercent">0%</span>
                </div>
                <div id="majordomeBulkProgressTrack" class="progress" role="progressbar" aria-label="Bulk update progress" aria-valuemin="0" aria-valuemax="100" aria-valuenow="0">
                    <div id="majordomeBulkProgressBar" class="progress-bar progress-bar-striped" style="width: 0%"></div>
                </div>
                <div id="majordomeBulkProgressStatus" class="small mt-3"></div>
                <div id="majordomeBulkProgressLog" class="majordome-bulk-progress-log list-group small mt-3" aria-live="polite"></div>
            </div>
            <div class="modal-footer">
                <button type="button" id="majordomeBulkCancel" class="btn btn-outline-secondary">Cancel</button>
                <button type="button" id="majordomeBulkStart" class="btn btn-gradient">Start</button>
            </div>
        </div>
    </div>
</div>

<div class="this-container container-fluid px-5 my-3">
    <nav class="nav nav-tabs no-wrap-group" id="myTab" role="tablist">
        <button class="btn btn-gradient-grey text-shadow-small active" id="inventory-tab" data-bs-toggle="tab" data-bs-target="#tab-inventory" type="button" role="tab">
            Inventory
        </button>
        <button class="btn btn-gradient-grey text-shadow-small" id="details-tab" data-bs-toggle="tab" data-bs-target="#tab-details" type="button" role="tab">
            Details
        </button>
        <button class="btn btn-gradient-grey text-shadow-small" id="gallery-tab" data-bs-toggle="tab" data-bs-target="#tab-gallery" type="button" role="tab">
            Photos
        </button>

        <button class="btn btn-gradient-grey text-shadow-small d-none" id="QR-code-tab" data-bs-toggle="tab" data-bs-target="#tab-qr-code" type="button" role="tab">
            QR Code
        </button>
        <div id="specials" class="d-none d-lg-block d-flex ms-auto"></div>
    </nav>

    <div class="tab-content border border-top-0 well " id="myTabContent">
        <!-- Inventory Tab -->
        <div class="tab-pane fade show active py-2" id="tab-inventory" role="tabpanel">
            <div class="container-fluid">
                <div id="inventoryGridShell" class="majordome-inventory-shell rounded-4 overflow-hidden border border-dark-subtle">
                    <div class="majordome-inventory-header p-3">
                        <div class="d-flex flex-column align-items-center gap-2">
                            <div id="filtersWrap">
                                @{ Html.RenderPartial("_FilterByTerm"); }
                            </div>
                        </div>
                    </div>
                    <div class="majordome-inventory-table-wrap table-responsive">
                        <table id="majordomeInventoryTable" class="table table-hover align-middle m-0">
                            <thead class="table-light">
                                <tr>
                                    <th class="majordome-sortable-th" data-sort-key="image" style="width:100px;">Image <i class="bi bi-arrow-down-up majordome-sort-indicator" aria-hidden="true"></i></th>
                                    <th class="majordome-sortable-th" data-sort-key="vehicle" style="min-width:220px;">Vehicle <i class="bi bi-arrow-down-up majordome-sort-indicator" aria-hidden="true"></i></th>
                                    <th class="d-none d-lg-table-cell majordome-sortable-th" data-sort-key="purchased" style="min-width:120px;">Purchased <i class="bi bi-arrow-down-up majordome-sort-indicator" aria-hidden="true"></i></th>
                                    <th class="majordome-sortable-th" data-sort-key="stock" style="min-width:110px;">Stock <i class="bi bi-arrow-down-up majordome-sort-indicator" aria-hidden="true"></i></th>
                                    <th class="text-center d-none d-xl-table-cell majordome-sortable-th" data-sort-key="gtx" style="min-width:120px;">GTX <i class="bi bi-arrow-down-up majordome-sort-indicator" aria-hidden="true"></i></th>
                                    <th class="text-center d-none d-md-table-cell majordome-sortable-th" data-sort-key="upload" style="width:80px;">Upload <i class="bi bi-arrow-down-up majordome-sort-indicator" aria-hidden="true"></i></th>
                                    <th class="text-center d-none d-md-table-cell majordome-sortable-th" data-sort-key="story" style="width:80px;">Story <i class="bi bi-arrow-down-up majordome-sort-indicator" aria-hidden="true"></i></th>
                                    <th class="text-center d-none d-md-table-cell majordome-sortable-th" data-sort-key="dataone" style="width:90px;">DataOne <i class="bi bi-arrow-down-up majordome-sort-indicator" aria-hidden="true"></i></th>
                                    <th class="text-center majordome-actions-col" style="min-width:250px;">Actions</th>
                                </tr>
                            </thead>
                            <tbody id="majordomeInventoryBody"></tbody>
                        </table>
                    </div>
                    <div id="majordomeInventoryEmpty" class="p-4 text-center text-muted d-none">
                        No vehicles match the current filter.
                    </div>
                </div>
            </div>
        </div>

        <!-- Details Tab -->
        <div class="tab-pane fade" id="tab-details" role="tabpanel">
            <div class="row">
                <!-- Left Column: Form -->
                <div class="col-lg-7">
                    <div id="dataOneDetails" class="row mt-3 d-flex justify-content-center">
                    </div>
                </div>
                <div class="col-lg-5 text-shadow-small">
                    <div class="row">
                        @Html.Label("Title", new { @class = "text-shadow" })
                        <div class="input-group mb-3">
                            <input id="storyTitle" class="form-control shadow pull-right" placeholder="Title" aria-label="Title" aria-describedby="storyTitle" />
                            <button id="createStory" class="btn btn-light bi bi-book input-group-text "></button>
                            <button id="deleteStory" class="btn btn-light bi bi-book-fill input-group-text"></button>
                            <button id="saveStory" class="btn btn-light bi bi-save input-group-text"></button>
                        </div>
                    </div>
                    <div class="row mt-2">
                        @Html.Label("Story", new { @class = "text-shadow" })
                        <div id="story" class="form-control shadow"></div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Gallery Tab -->
        <div class="tab-pane fade" id="tab-gallery" role="tabpanel">
            <div class="d-flex flex-column align-items-center">
                <div class="d-flex justify-content-center w-100 p-3">
                    <button id="upload" class="btn btn-light shadow mx-2 bi bi-upload">&nbsp;Upload stock images</button>
                    <button id="deleteAll" class="btn btn-light shadow bi bi-trash">&nbsp;Delete stock all images</button>
                    <input type="file" id="fileInput" class="d-none" multiple accept="image/*">
                </div>
                <div id="dropzone" class="dropzone w-100">
                    <div id="gallery-content" class="flex-grow-1 w-100 px-3 pb-3">
                        <ul id="sortable-gallery" class="row justify-content-center">
                        </ul>
                    </div>
                </div>
            </div>
        </div>

        <!-- QR Code Tab -->
        <div class="tab-pane fade" id="tab-qr-code" role="tabpanel">
            <div class="row">
                <div class="col-3 d-flex flex-column align-items-center text-center">
                    <div id="qrPrintArea" class="m-3" style="width:400px;">
                        <h3>ATTENTION</h3>
                        <h3>Car shoppers!</h3>
                        <div>Scan the code  with your mobile phone's camera app for more information about this vehicle</div>
                        <img id="qrImg" src="" alt="QR Code" style="width:300px;height:300px;" />
                        <div id="qrText" class="very-small-text"></div>
                    </div>
                    <div class="m-3">
                        <button type="button" class="btn btn-gradient shadow" onclick="printQrArea()">Print QR</button>
                    </div>
                </div>
            </div>
        </div>

    </div>
</div>
<template id="actions">
    <button type="button" id="btnDecodeAll" class="btn btn-gradient shadow">Decode all</button>
    <button type="button" id="btnReStoryAll" class="btn btn-gradient shadow">Re-story all</button>
    <button type="button" id="btnUploadInventory" class="btn btn-gradient shadow">Upload inventory</button>
    <button type="button" id="btnRestoreBackUpInventory" class="btn btn-gradient shadow">Restore back up</button>
    <input type="file" name="dataCsv" id="dataCsv" class="d-none" accept=".csv,text/csv" />
</template>

<input type="hidden" id="currentVehicle" />

<script type="text/javascript">
    const $dropzone = $("#dropzone");
    const inventoryVehiclesSourceJson = "@Html.Raw(System.Web.HttpUtility.JavaScriptStringEncode(JsonConvert.SerializeObject(Model.Inventory.Vehicles ?? Array.Empty<GTX.Models.GTX>())))";
    let inventoryVehiclesSource = JSON.parse(inventoryVehiclesSourceJson);
    let inventoryVehicles = [];
    let selectedVehicleStock = null;
    let majordomeBulkJob = null;
    window.majordomeSelectedStock = "";
    const majordomeSortState = { key: "", direction: "" };
    const majordomeUploadMaxAttempts = 3;
    const majordomeUploadRequestTimeoutMs = 120000;

    const toolbarOptions = [
        ['bold', 'italic', 'underline', 'strike'],        // toggled buttons
        //['blockquote', 'code-block'],
        ['link', 'image', 'video'],

        //[{ 'header': 1 }, { 'header': 2 }],               // custom button values
        //[{ 'list': 'ordered' }, { 'list': 'bullet' }, { 'list': 'check' }],
        //[{ 'script': 'sub' }, { 'script': 'super' }],      // superscript/subscript
        [{ 'indent': '-1' }, { 'indent': '+1' }],          // outdent/indent
        //[{ 'direction': 'rtl' }],                         // text direction

        [{ 'size': ['small', false, 'large', 'huge'] }],  // custom dropdown
        [{ 'header': [1, 2, 3, 4, 5, 6, false] }],

        [{ 'color': [] }, { 'background': [] }],          // dropdown with defaults from theme
        [{ 'font': [] }],
        [{ 'align': [] }]

        //['clean']                                         // remove formatting button
    ];

    const quill = new Quill('#story', {
        modules: {
