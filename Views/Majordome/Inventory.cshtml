    function getMajordomeBulkItemLabel(job, item) {
        if (job && job.config && typeof job.config.getLabel === "function") {
            return job.config.getLabel(item);
        }

        return getMajordomeBulkVehicleLabel(item);
    }

    function isMajordomeBulkCancelError(error) {
        return safeText(error?.message).trim().toLowerCase() === "canceled.";
    }

    function updateMajordomeBulkActiveStatus(job, label) {
        if (!job || job.cancelRequested) return;

        if (label) {
            setMajordomeBulkStatus(`Working on ${label}...`);
            return;
        }

        setMajordomeBulkStatus(`${getMajordomeBulkDisplayProcessed(job)} of ${getMajordomeBulkDisplayTotal(job)} done.`);
    }

    async function runMajordomeBulkItem(job, item) {
        const label = getMajordomeBulkItemLabel(job, item);
        let progressUnits = 0;
        updateMajordomeBulkActiveStatus(job, label);

        try {
            const result = await job.config.run(item, job);
            const status = result && result.status ? result.status : "success";
            const message = result && result.message ? result.message : `${label} completed.`;

            job.completed++;
            if (status === "warning") {
                job.warnings++;
            }
            if (result && result.uploadPayloadRecorded) {
                job.uploadPayloadRecorded = true;
            }
            progressUnits = getMajordomeBulkProgressUnits(job, result);
            if (!result || result.logResult !== false) {
                appendMajordomeBulkLog(message, status);
            }
        } catch (error) {
            if (job.cancelRequested && isMajordomeBulkCancelError(error)) {
                job.canceled++;
                appendMajordomeBulkLog(`${label} canceled.`, "warning");
                return;
            }

            job.failed++;
            appendMajordomeBulkLog(`${label} failed: ${(error && error.message) || "Unknown error."}`, "error");
            console.error("Majordome bulk update failed:", error);
        } finally {
            job.processed = job.completed + job.failed + job.canceled;
            job.progressProcessed = Math.min(job.progressTotal, job.progressProcessed + progressUnits);
            updateMajordomeBulkProgress(job.progressProcessed, job.progressTotal);
            updateMajordomeBulkActiveStatus(job);
        }
    }

    async function runMajordomeBulkSequential(job) {
        for (let index = 0; index < job.items.length; index++) {
            if (job.cancelRequested) break;

            await runMajordomeBulkItem(job, job.items[index]);

            if (job.cancelRequested) break;

            if (job.config.delayAfterMs > 0 && job.processed < job.items.length) {
                setMajordomeBulkStatus("Waiting before the next request...");
                await waitMajordomeBulkDelay(job.config.delayAfterMs, job);
            }
        }
    }

    async function startMajordomeBulkJob() {
        const job = majordomeBulkJob;
        if (!job || job.running || !job.items.length) return;

        job.running = true;
        setMajordomeBulkToolbarBusy(true);
        $("#majordomeBulkStart").prop("disabled", true);
        $("#majordomeBulkCancel").prop("disabled", false).text("Cancel");
        if (job.config.clearLogOnStart) {
            $("#majordomeBulkProgressLog").empty();
        }

        try {
            await runMajordomeBulkSequential(job);

            if (!job.cancelRequested && typeof job.config.afterComplete === "function" && job.processed > 0) {
                setMajordomeBulkStatus(job.config.afterCompleteStatus || "Refreshing inventory list...");
                if (job.config.allowCloseDuringAfterComplete) {
                    job.running = false;
                    showMajordomeBulkCloseButton();
                }
                try {
                    await job.config.afterComplete(job);
                } catch (error) {
                    appendMajordomeBulkLog(`Inventory refresh failed: ${(error && error.message) || "Unknown error."}`, "error");
                    console.error("Majordome bulk refresh failed:", error);
                }
            } else if (!job.cancelRequested && job.completed > 0) {
                setMajordomeBulkStatus("Refreshing inventory list...");
                try {
                    const data = await getUpdatedItems();
                    updateRow(data);
                } catch (error) {
                    appendMajordomeBulkLog(`Inventory refresh failed: ${(error && error.message) || "Unknown error."}`, "error");
                    console.error("Majordome bulk refresh failed:", error);
                }
            }

            const displayProcessed = getMajordomeBulkDisplayProcessed(job);
            const displayTotal = getMajordomeBulkDisplayTotal(job);

            if (job.cancelRequested) {
                setMajordomeBulkStatus(`Canceled after ${displayProcessed} of ${displayTotal}. Completed changes were kept.`);
            } else if (job.failed > 0) {
                setMajordomeBulkStatus(`Finished with ${job.failed} error${job.failed === 1 ? "" : "s"}.`);
            } else if (job.warnings > 0) {
                setMajordomeBulkStatus(`Completed ${displayProcessed} of ${displayTotal} with ${job.warnings} warning${job.warnings === 1 ? "" : "s"}.`);
            } else {
                setMajordomeBulkStatus(`Completed ${displayProcessed} of ${displayTotal}.`);
            }
        } finally {
            job.running = false;
            setMajordomeBulkToolbarBusy(false);
            showMajordomeBulkCloseButton();
        }
    }

    function cancelMajordomeBulkJob() {
        if (!majordomeBulkJob) {
            hideMajordomeBulkModal();
            return;
        }

        if (majordomeBulkJob.running) {
            majordomeBulkJob.cancelRequested = true;
            if (majordomeBulkJob.abortControllers) {
                majordomeBulkJob.abortControllers.forEach(function (controller) {
                    try {
                        controller.abort();
                    } catch (error) {
                    }
                });
                majordomeBulkJob.abortControllers.clear();
            }
            if (majordomeBulkJob.abortRequests) {
                majordomeBulkJob.abortRequests.forEach(function (request) {
                    try {
                        request.abort();
                    } catch (error) {
                    }
                });
                majordomeBulkJob.abortRequests.clear();
            }
            $("#majordomeBulkCancel").prop("disabled", true).text("Stopping...");
            setMajordomeBulkStatus(majordomeBulkJob.config.cancelMessage || "Cancel requested. The current item will finish, then the job will stop.");
            return;
        }

        hideMajordomeBulkModal();
    }

    function hasMajordomeImage(vehicle) {
        const image = safeText(vehicle?.Image).trim();
        if (!image) return false;
        return !/no[\s\-_]*image/i.test(image);
    }

    function toYnSortFlag(value) {
        return safeText(value).trim().toUpperCase() === "Y" ? 1 : 0;
    }

    function toMajordomeDateSortValue(value) {
        const text = safeText(value).trim();
        if (!text) return Number.NEGATIVE_INFINITY;
        const parsed = Date.parse(text);
        return Number.isNaN(parsed) ? Number.NEGATIVE_INFINITY : parsed;
    }

    function getMajordomeGtxBadgeInfo(value) {
        const label = safeText(value).trim();
        const normalized = label.toUpperCase();
        let toneClass = "";

        if (normalized.startsWith("X")) {
            toneClass = "is-gtx-x";
        } else if (normalized.startsWith("T")) {
            toneClass = "is-gtx-t";
        } else if (normalized.startsWith("G")) {
            toneClass = "is-gtx-g";
        }

        return {
            label: label || "-",
            toneClass: toneClass
        };
    }

    function normalizeMajordomeGtxFilterValue(value) {
        return safeText(value).trim().toUpperCase();
    }

    function getSelectedMajordomeGtxFilter() {
        return normalizeMajordomeGtxFilterValue($("#majordomeGtxFilter").val());
    }

    function getMajordomeGtxFilterOptions(sourceRows) {
        const optionsByValue = {};

        (Array.isArray(sourceRows) ? sourceRows : []).forEach(function (vehicle) {
            const label = safeText(vehicle?.LocationCode).trim();
            const value = normalizeMajordomeGtxFilterValue(label);
            if (!value || optionsByValue[value]) return;

            optionsByValue[value] = label;
        });

        return Object.keys(optionsByValue)
            .sort(function (left, right) {
                return compareMajordomeText(optionsByValue[left], optionsByValue[right]);
            })
            .map(function (value) {
                return {
                    value: value,
                    label: optionsByValue[value]
                };
            });
    }

    function renderMajordomeGtxFilterOptions(sourceRows) {
        const $select = $("#majordomeGtxFilter");
        if (!$select.length) return;

        const currentValue = getSelectedMajordomeGtxFilter();
        const options = getMajordomeGtxFilterOptions(sourceRows);
        const hasCurrentValue = options.some(function (option) {
            return option.value === currentValue;
        });
        const optionsHtml = ['<option value="">All</option>'];

        options.forEach(function (option) {
            optionsHtml.push(`<option value="${escapeHtml(option.value)}">${escapeHtml(option.label)}</option>`);
        });

        $select.html(optionsHtml.join(""));
        $select.val(hasCurrentValue ? currentValue : "");
    }

    function compareMajordomeText(left, right) {
        return safeText(left).localeCompare(safeText(right), undefined, { numeric: true, sensitivity: "base" });
    }

    function compareMajordomeVehicles(left, right, key) {
        switch (key) {
            case "image": {
                const imagePresence = (hasMajordomeImage(left) ? 1 : 0) - (hasMajordomeImage(right) ? 1 : 0);
                if (imagePresence !== 0) return imagePresence;
                return compareMajordomeText(left?.Image, right?.Image);
            }
            case "vehicle": {
                const makeDiff = compareMajordomeText(left?.Make, right?.Make);
                if (makeDiff !== 0) return makeDiff;

                const yearLeft = Number.parseInt(safeText(left?.Year), 10);
                const yearRight = Number.parseInt(safeText(right?.Year), 10);
                const safeYearLeft = Number.isNaN(yearLeft) ? -1 : yearLeft;
                const safeYearRight = Number.isNaN(yearRight) ? -1 : yearRight;
                if (safeYearLeft !== safeYearRight) return safeYearLeft - safeYearRight;

                const modelDiff = compareMajordomeText(left?.Model, right?.Model);
                if (modelDiff !== 0) return modelDiff;

                return compareMajordomeText(left?.VehicleStyle, right?.VehicleStyle);
            }
            case "purchased":
                return toMajordomeDateSortValue(left?.PurchaseDate) - toMajordomeDateSortValue(right?.PurchaseDate);
            case "stock":
                return compareMajordomeText(left?.Stock, right?.Stock);
            case "gtx":
                return compareMajordomeText(left?.LocationCode, right?.LocationCode);
            case "upload":
                return toYnSortFlag(left?.SetToUpload) - toYnSortFlag(right?.SetToUpload);
            case "story":
                return (hasStory(left) ? 1 : 0) - (hasStory(right) ? 1 : 0);
            case "dataone":
                return (hasDataOne(left) ? 1 : 0) - (hasDataOne(right) ? 1 : 0);
            default:
                return 0;
        }
    }

    function sortMajordomeVehicles(sourceRows) {
        const rows = Array.isArray(sourceRows) ? sourceRows.slice() : [];

        if (!majordomeSortState.key || !majordomeSortState.direction) {
            return rows;
        }

        const directionMultiplier = majordomeSortState.direction === "desc" ? -1 : 1;

        return rows
            .map(function (row, index) { return { row: row, index: index }; })
            .sort(function (left, right) {
                const diff = compareMajordomeVehicles(left.row, right.row, majordomeSortState.key);
                if (diff !== 0) return diff * directionMultiplier;
                return left.index - right.index;
            })
            .map(function (entry) { return entry.row; });
    }

    function updateMajordomeSortHeaders() {
        $("#majordomeInventoryTable th.majordome-sortable-th").each(function () {
            const $header = $(this);
            const key = safeText($header.attr("data-sort-key")).toLowerCase();
            const $icon = $header.find(".majordome-sort-indicator");
            const isActive = key === majordomeSortState.key && !!majordomeSortState.direction;

            $header.toggleClass("is-active", isActive);
            $icon.removeClass("bi-arrow-down-up bi-arrow-up bi-arrow-down");
            $icon.addClass(!isActive ? "bi-arrow-down-up" : (majordomeSortState.direction === "asc" ? "bi-arrow-up" : "bi-arrow-down"));
            $header.attr("aria-sort", !isActive ? "none" : (majordomeSortState.direction === "asc" ? "ascending" : "descending"));
        });
    }

    function toggleMajordomeSort(key) {
        const normalizedKey = safeText(key).toLowerCase();
        if (!normalizedKey) return;

        if (majordomeSortState.key !== normalizedKey) {
            majordomeSortState.key = normalizedKey;
            majordomeSortState.direction = "asc";
            return;
        }

        if (majordomeSortState.direction === "asc") {
            majordomeSortState.direction = "desc";
            return;
        }

        if (majordomeSortState.direction === "desc") {
            majordomeSortState.key = "";
            majordomeSortState.direction = "";
            return;
        }

        majordomeSortState.direction = "asc";
    }

    function buildMajordomeVehicleSearchObject(vehicle) {
        if (window.gtxInventorySearch) {
            return window.gtxInventorySearch.vehicleObject(vehicle);
        }

        return vehicle || {};
    }

    function buildVehicleSearch(vehicle) {
        const searchObject = buildMajordomeVehicleSearchObject(vehicle);

        if (window.gtxInventorySearch) {
            return window.gtxInventorySearch.buildVehicleSearch(searchObject).text;
        }

        return [
            searchObject?.Stock,
            searchObject?.VIN,
            searchObject?.Year,
            searchObject?.Make,
            searchObject?.Model,
            searchObject?.Trim,
            searchObject?.VehicleStyle,
            searchObject?.VehicleType,
            searchObject?.Transmission,
            searchObject?.Cylinders,
            searchObject?.FuelType,
            searchObject?.DriveTrain,
            searchObject?.Body,
            searchObject?.Engine,
            searchObject?.Color,
            searchObject?.Color2,
            searchObject?.LocationCode
        ].map(safeText).join(" ").toUpperCase();
    }

    function buildVehicleTokenSearch(vehicle) {
        const searchObject = buildMajordomeVehicleSearchObject(vehicle);

        if (window.gtxInventorySearch) {
            return window.gtxInventorySearch.buildVehicleSearch(searchObject).tokens;
        }

        return [
            `@@YR ${safeText(searchObject?.Year)}`,
            `@@MK ${safeText(searchObject?.Make)}`,
            `@@MD ${safeText(searchObject?.Model)}`,
            `@@TR ${safeText(searchObject?.Transmission)}`,
            `@@CY ${safeText(searchObject?.Cylinders)}`,
            `@@OW ${safeText(searchObject?.LocationCode)}`
        ].join(" ").toUpperCase();
    }

    function formatPurchaseDate(value) {
        if (!value) return "";
        const dt = new Date(value);
        if (isNaN(dt.getTime())) return "";
        return dt.toLocaleDateString("en-US");
    }

    function syncMajordomeEmptyState() {
        const matchedRows = getMajordomeFilterMatchedRows().length;
        $("#majordomeInventoryEmpty").toggleClass("d-none", matchedRows > 0);
    }

    function getMajordomeFilterMatchedRows() {
        return $("#majordomeInventoryBody .majordome-vehicle-row").filter(function () {
            return !$(this).hasClass("is-filter-hidden");
        });
    }

    function syncMajordomeInventoryCount() {
        const matchedRows = getMajordomeFilterMatchedRows().length;
        $("#majordomeShownVehiclesCount").text(matchedRows);
    }

    function renderMajordomeActionButtons(vehicle) {
        const stock = escapeHtml(vehicle.Stock);
        const vin = escapeHtml(vehicle.VIN);
        const imagesCount = vehicle.Images ? vehicle.Images.length : 0;
        const canDeleteImages = imagesCount > 0;
        const deleteImagesTitle = canDeleteImages
            ? `Delete all ${imagesCount} pictures for Stock# ${stock}`
            : `No images to delete for Stock# ${stock}`;

        return `
            <div class="majordome-actions">
                <div class="majordome-action-group">
                    <div class="majordome-action-title">Edit</div>
                    <div class="majordome-action-buttons">
                        <button type="button" class="btn btn-gradient border-dark shadow-sm js-amm-edit-inventory" data-stock="${stock}" title="Edit inventory for Stock# ${stock}">
                            <i class="bi bi-pencil-square"></i>
                        </button>
                    </div>
                </div>
                <div class="majordome-action-group">
                    <div class="majordome-action-title">Images</div>
                    <div class="majordome-action-buttons">
                        <button type="button" class="btn btn-gradient-grey border-dark shadow-sm js-amm-upload-trigger" title="Upload images for Stock# ${stock}">
                            <i class="bi bi-upload"></i>
                        </button>
                        <button type="button" class="btn btn-gradient-grey border-dark shadow-sm js-amm-delete-images" data-stock="${stock}" data-images-count="${imagesCount}" title="${deleteImagesTitle}" ${canDeleteImages ? "" : "disabled"}>
                            <i class="bi bi-trash"></i>
                        </button>
                    </div>
                    <input type="file" class="js-amm-upload-input d-none" data-stock="${stock}" multiple accept="image/*" />
                </div>
                <div class="majordome-action-group">
                    <div class="majordome-action-title">Story</div>
                    <div class="majordome-action-buttons">
                        <button type="button" class="btn btn-gradient-grey border-dark shadow-sm js-amm-create-story" data-stock="${stock}" title="Create story for Stock# ${stock}">
                            <i class="bi bi-book"></i>
                        </button>
                        <button type="button" class="btn btn-gradient-grey border-dark shadow-sm js-amm-delete-story" data-stock="${stock}" title="Delete story for Stock# ${stock}">
                            <i class="bi bi-book-fill"></i>
                        </button>
                    </div>
                </div>
                <div class="majordome-action-group">
                    <div class="majordome-action-title">DataOne</div>
                    <div class="majordome-action-buttons">
                        <button type="button" class="btn btn-gradient-grey border-dark shadow-sm js-amm-decode-dataone" data-vin="${vin}" title="Decode and override for VIN# ${vin}">
                            <i class="bi bi-car-front"></i>
                        </button>
                        <button type="button" class="btn btn-gradient-grey border-dark shadow-sm js-amm-delete-dataone" data-stock="${stock}" title="Delete DataOne for stock# ${stock}">
                            <i class="bi bi-car-front-fill"></i>
                        </button>
                    </div>
                </div>
            </div>
        `;
    }

    function renderMajordomeInventoryRow(vehicle) {
        const row = normalizeVehicle(vehicle);
        const searchObject = buildMajordomeVehicleSearchObject(row);
        const stock = safeText(row.Stock);
        const search = escapeHtml(buildVehicleSearch(searchObject));
        const tokenSearch = escapeHtml(buildVehicleTokenSearch(searchObject));
        const vin = safeText(row.VIN);
        const purchaseDate = formatPurchaseDate(row.PurchaseDate);
        const upload = safeText(row.SetToUpload).toUpperCase() === "Y";
        const story = hasStory(row);
        const dataOne = hasDataOne(row);
        const gtxBadge = getMajordomeGtxBadgeInfo(row.LocationCode);
        const gtxValue = normalizeMajordomeGtxFilterValue(row.LocationCode);

        return `
            <tr class="majordome-vehicle-row" data-stock="${escapeHtml(stock)}" data-search="${search}" data-search-tokens="${tokenSearch}" data-gtx="${escapeHtml(gtxValue)}">
                ${window.renderMajordomeVehicleImageCell(row)}
                ${window.renderMajordomeVehicleDetailsCell(row)}
                <td class="d-none d-lg-table-cell majordome-date-cell">${escapeHtml(purchaseDate)}</td>
                <td class="text-center"><span class="shadow majordome-status-pill majordome-status-location ${escapeHtml(gtxBadge.toneClass)} px-2">${escapeHtml(stock)}</span></td>
                <td class="text-center d-none d-xl-table-cell">
                    <span class="majordome-status-pill majordome-status-location ${escapeHtml(gtxBadge.toneClass)} shadow">${escapeHtml(gtxBadge.label)}</span>
                </td>
                <td class="text-center d-none d-md-table-cell">
                    <span class="shadow majordome-status-pill majordome-status-upload ${upload ? "is-on" : ""}">${upload ? "Y" : "N"}</span>
                </td>
                <td class="text-center d-none d-md-table-cell">
                    <span class="shadow majordome-status-pill majordome-status-story ${story ? "is-on" : ""}">${story ? "Y" : "N"}</span>
                </td>
                <td class="text-center d-none d-md-table-cell">
                    <span class="shadow majordome-status-pill majordome-status-dataone ${dataOne ? "is-on" : ""}">${dataOne ? "Y" : "N"}</span>
                </td>
                <td class="shadow text-start majordome-actions-cell">${renderMajordomeActionButtons(row)}</td>
            </tr>
        `;
    }

    function markSelectedRow(stock) {
        const key = safeText(stock).trim().toUpperCase();

        $("#majordomeInventoryBody .majordome-vehicle-row").each(function () {
            const rowKey = safeText($(this).attr("data-stock")).trim().toUpperCase();
            $(this).toggleClass("is-selected", rowKey === key);
        });
    }

    function syncMajordomeGalleryAvailability() {
        const hasSelectedStock = safeText(selectedVehicleStock || selectedVehicle?.Stock || window.majordomeSelectedStock || "").trim().length > 0;
        const $galleryTab = $("#gallery-tab");
        const $galleryPane = $("#tab-gallery");
        const $uploadBtn = $("#upload");
        const $deleteAllBtn = $("#deleteAll");
        const selectedImageCount = Array.isArray(selectedVehicle?.Images) ? selectedVehicle.Images.length : 0;

        if (hasSelectedStock) {
            $galleryTab.removeClass("d-none");
            $galleryPane.removeClass("d-none");
            $uploadBtn.prop("disabled", false);
            $deleteAllBtn.prop("disabled", selectedImageCount === 0);
            $dropzone.removeClass("opacity-50");
            return;
        }

        $galleryTab.addClass("d-none").removeClass("active");
        $galleryPane.addClass("d-none").removeClass("show active");
        $uploadBtn.prop("disabled", true);
        $deleteAllBtn.prop("disabled", true);
        $dropzone.removeClass("dragover").addClass("opacity-50");
        $("#sortable-gallery").empty();
        $galleryTab.text("Photos");
    }

    function renderMajordomeInventoryRows(data) {
        if (Array.isArray(data)) {
            inventoryVehiclesSource = data.map(normalizeVehicle);
        }

        inventoryVehicles = sortMajordomeVehicles(inventoryVehiclesSource);
        renderMajordomeGtxFilterOptions(inventoryVehiclesSource);
        const rowsHtml = inventoryVehicles.map(renderMajordomeInventoryRow).join("");
        if (window.gtxSecurity && typeof window.gtxSecurity.setSafeHtml === "function") {
            window.gtxSecurity.setSafeHtml($("#majordomeInventoryBody"), rowsHtml);
        } else {
            const bodyElement = document.getElementById("majordomeInventoryBody");
            if (bodyElement) {
                bodyElement.innerHTML = rowsHtml;
            }
        }
        updateMajordomeSortHeaders();
        syncMajordomeEmptyState();
        syncMajordomeInventoryCount();
        markSelectedRow(selectedVehicleStock);
        syncMajordomeGalleryAvailability();
    }

    function selectMajordomeVehicle(stock) {
        const stockKey = safeText(stock).trim().toUpperCase();
        if (!stockKey) return;

        const vehicle = inventoryVehicles.find(function (item) {
            return safeText(item.Stock).trim().toUpperCase() === stockKey;
        });

        if (!vehicle) return;

        selectedVehicle = vehicle;
        selectedVehicleStock = safeText(vehicle.Stock).trim();
        window.majordomeSelectedStock = selectedVehicleStock;
        markSelectedRow(selectedVehicleStock);

        showVehicleDetails(selectedVehicle);
        loadGallery(selectedVehicle);
        syncMajordomeQrCode(selectedVehicle);
        syncMajordomeGalleryAvailability();
    }

    function selectFirstVisibleMajordomeVehicle(keepCurrent) {
        const keep = keepCurrent !== false;
        const $rows = getMajordomeFilterMatchedRows();

        if ($rows.length === 0) {
            selectedVehicle = null;
            selectedVehicleStock = null;
            window.majordomeSelectedStock = "";
            markSelectedRow("");
            syncMajordomeGalleryAvailability();
            return;
        }

        if (keep && selectedVehicleStock) {
            const currentKey = safeText(selectedVehicleStock).trim().toUpperCase();
            const $current = $rows.filter(function () {
                return safeText($(this).attr("data-stock")).trim().toUpperCase() === currentKey;
            }).first();

            if ($current.length) {
                const currentVehicle = inventoryVehicles.find(function (item) {
                    return safeText(item.Stock).trim().toUpperCase() === currentKey;
                });

                if (currentVehicle) {
                    selectedVehicle = currentVehicle;
                    selectedVehicleStock = safeText(currentVehicle.Stock).trim();
                    window.majordomeSelectedStock = selectedVehicleStock;
                }

                markSelectedRow(selectedVehicleStock);
                syncMajordomeGalleryAvailability();
                return;
            }
        }

        const firstStock = $rows.first().attr("data-stock");
        selectMajordomeVehicle(firstStock);
    }

    function applyFilterTerm(term) {
        const raw = safeText(term);
        const normalized = raw.trim().toUpperCase();
        const terms = normalized.split(/\s+/).filter(Boolean);
        const selectedGtx = getSelectedMajordomeGtxFilter();
        const search = window.gtxInventorySearch;

        if (search) {
            search.writeStoredTerm(raw);
        } else if (!normalized) {
            sessionStorage.removeItem("term");
        }

        $("#majordomeInventoryBody .majordome-vehicle-row").each(function () {
            const haystack = safeText($(this).data("search")).toUpperCase();
            const tokenHaystack = safeText($(this).data("search-tokens")).toUpperCase();
            const matchedTerm = search
                ? search.matches(haystack, raw, tokenHaystack)
                : terms.length === 0 || terms.every(function (t) { return haystack.includes(t); });
            const rowGtx = normalizeMajordomeGtxFilterValue($(this).attr("data-gtx"));
            const matchedGtx = !selectedGtx || rowGtx === selectedGtx;
            const matched = matchedTerm && matchedGtx;
            $(this).toggleClass("is-filter-hidden", !matched);
            $(this).toggle(matched);
        });

        const stocks = getMajordomeFilterMatchedRows().map(function () {
            return $(this).attr("data-stock");
        }).get();

        if (stocks.length > 0) {
            localStorage.setItem("matchedStocks", JSON.stringify(stocks));
        } else {
            localStorage.removeItem("matchedStocks");
        }

        if (!search && normalized) {
            sessionStorage.setItem("term", raw);
        }
        syncMajordomeEmptyState();
        syncMajordomeInventoryCount();
    }

    function syncMajordomeQrCode(vehicle) {
        if (!vehicle) return;
        const qrUrl = "/Majordome/Qr?stock=" + encodeURIComponent(vehicle.Stock || "") + "&vin=" + encodeURIComponent(vehicle.VIN || "");
        $("#qrImg").attr("src", qrUrl);
        $("#qrText").text(`${vehicle.Year} ${vehicle.Make} ${vehicle.Model} Stock# ${vehicle.Stock}`);
        $("#QR-code-tab").removeClass("d-none");
    }

    function getSelectedVehicleStockOrWarn() {
        const stock = safeText(selectedVehicle?.Stock || selectedVehicleStock || window.majordomeSelectedStock || "").trim();
        if (!stock) {
            alert("Please select a vehicle first.");
            return "";
        }

        if (!selectedVehicle || safeText(selectedVehicle.Stock).trim().toUpperCase() !== stock.toUpperCase()) {
            const current = inventoryVehicles.find(function (item) {
                return safeText(item.Stock).trim().toUpperCase() === stock.toUpperCase();
            });

            if (current) {
                selectedVehicle = current;
            }
        }

        return stock;
    }

    function updateRow(data) {
        const preferredStock = safeText(selectedVehicleStock || selectedVehicle?.Stock || window.majordomeSelectedStock || "").trim();
        const forcedTabId = safeText(window.majordomeForceActiveTab || "").trim();
        const activeTabId = forcedTabId || $("#myTab button.active").attr("id") || "inventory-tab";
        const currentFilter = $("#filterTerm").val() || "";

        if (preferredStock) {
            window.majordomeSelectedStock = preferredStock;
        }

        renderMajordomeInventoryRows(data);
        applyFilterTerm(currentFilter);

        let hasSelectedVehicle = false;
        if (preferredStock) {
            const isVisible = getMajordomeFilterMatchedRows().filter(function () {
                return safeText($(this).attr("data-stock")).trim().toUpperCase() === safeText(preferredStock).trim().toUpperCase();
            }).length > 0;

            if (isVisible) {
                selectMajordomeVehicle(preferredStock);
                hasSelectedVehicle = true;
            } else {
                selectFirstVisibleMajordomeVehicle(false);
            }
        } else {
            selectFirstVisibleMajordomeVehicle(false);
        }

        if (!hasSelectedVehicle && safeText(selectedVehicleStock || selectedVehicle?.Stock || "").trim()) {
            hasSelectedVehicle = true;
        }

        if (hasSelectedVehicle && activeTabId === "gallery-tab") {
            $("#gallery-tab").tab("show");
        } else if (hasSelectedVehicle && activeTabId === "details-tab") {
            $("#details-tab").tab("show");
        } else if (hasSelectedVehicle && activeTabId === "QR-code-tab") {
            $("#QR-code-tab").tab("show");
        }

        syncMajordomeGalleryAvailability();
        if (window.majordomeForceActiveTab) {
            window.majordomeForceActiveTab = "";
        }
        hideSpinner($("#inventoryOverlay"));
    }

    window.applyMajordomeInventoryFilter = applyFilterTerm;
    window.onMajordomeInventoryDataUpdated = updateRow;

    const sortable = new Sortable(document.getElementById("sortable-gallery"), {
        scroll: true,
        scrollSensitivity: 30,
        scrollSpeed: 20,
        animation: 150,
        ghostClass: "sortable-gallery-ghost",
        chosenClass: "sortable-gallery-chosen",
        dragClass: "sortable-gallery-drag",
        delay: 100,
        touchStartThreshold: 5,
        onEnd: function (event) {
            if (event && event.oldIndex === event.newIndex) {
                return;
            }

            let sorted = $("#sortable-gallery li").map(function () {
                return $(this).attr("id")
            }).get();
            saveOrder(sorted, { fastMode: true });
            updateGalleryDisplay();
        }
    });

    // Show Bootstrap modal with images
    function showOverlayModal(id) {
        const stock = safeText(selectedVehicle?.Stock || selectedVehicleStock || window.majordomeSelectedStock || "").trim();
        if (!stock) return;

        showSpinner($("#inventoryOverlay"));
        $.get(`${root}Majordome/OverlayModal`, { id })
            .done(function (html) {
                $("#vehicle-overlay").html(html);
                $("#overlayModal").modal("show");
            })
            .fail(function (xhr, status, error) {
                console.error("OverlayModal failed:", status, error, xhr && xhr.responseText);
                alert("Failed to load overlay editor.");
            })
            .always(function () {
                hideSpinner($("#inventoryOverlay"));
            });
    }

    function showVehicleDetails(vehicle) {
        const activeElement = document.activeElement;
        const shouldRestoreFilterFocus = activeElement && activeElement.id === "filterTerm";
        const restoreStart = shouldRestoreFilterFocus && typeof activeElement.selectionStart === "number" ? activeElement.selectionStart : null;
        const restoreEnd = shouldRestoreFilterFocus && typeof activeElement.selectionEnd === "number" ? activeElement.selectionEnd : null;

        $('#vin').val(vehicle.VIN);
        $('#storyTitle').val(vehicle.Story?.Title);
        quill.setContents([]);
        quill.clipboard.dangerouslyPasteHTML(0, vehicle?.Story?.HtmlContent || "", "api");

        if (shouldRestoreFilterFocus) {
            activeElement.focus({ preventScroll: true });
            if (restoreStart !== null && restoreEnd !== null && typeof activeElement.setSelectionRange === "function") {
                activeElement.setSelectionRange(restoreStart, restoreEnd);
            }
        }

        if (vehicle.Stock) {
            $.ajax({
                url: `${root}Majordome/GetDataOneDetails`,
                type: 'GET',
                data: { stock: vehicle.Stock },
                success: function (html) {
                    // Replace or inject the partial view HTML
                    if (window.gtxSecurity && typeof window.gtxSecurity.setSafeHtml === "function") {
                        window.gtxSecurity.setSafeHtml($('#dataOneDetails'), html);
                    } else {
                        $('#dataOneDetails').text(html);
                    }
                },
                error: function (xhr) {
                    if (xhr && xhr.status === 404) {
                        $("#dataOneDetails").empty();
                        return;
                    }

                    console.error("Error loading DataOne details", xhr);
                }
            });
        }

        $("#gallery-tab").text(`Photos (${vehicle.Images.length})`);
        $("#QR-code-tab").removeClass("d-none");
    }

    function handleFiles(fileList) {
        const files = Array.from(fileList || []).filter(f => {
            const n = (f.name || '').toLowerCase();
            return f.type.startsWith('image/') || /\.(heic|heif|jpg|jpeg|png|webp|gif|bmp|tiff)$/.test(n);
        });
        const stock = safeText(selectedVehicle?.Stock || selectedVehicleStock || window.majordomeSelectedStock || "").trim();
        if (!files.length) return;
        if (!stock) return;
        uploadDroppedFiles(stock, files);
    }

</script>
