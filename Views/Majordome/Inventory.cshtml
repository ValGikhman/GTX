    function renderMajordomeActionButtons(vehicle) {
        const stock = escapeHtml(vehicle.Stock);
        const vin = escapeHtml(vehicle.VIN);
        const imagesCount = vehicle.Images ? vehicle.Images.length : 0;
        const canDeleteImages = imagesCount > 0;
        const deleteImagesTitle = canDeleteImages
            ? `Delete all ${imagesCount} pictures for Stock# ${stock}`
            : `No images to delete for Stock# ${stock}`;

        return `
            <div class="majordome-actions">
                <div class="majordome-action-group">
                    <div class="majordome-action-title">Images</div>
                    <div class="majordome-action-buttons">
                        <button type="button" class="btn btn-gradient-grey border-dark shadow-sm js-amm-upload-trigger" title="Upload images for Stock# ${stock}">
                            <i class="bi bi-upload"></i>
                        </button>
                        <button type="button" class="btn btn-gradient-grey border-dark shadow-sm js-amm-delete-images" data-stock="${stock}" data-images-count="${imagesCount}" title="${deleteImagesTitle}" ${canDeleteImages ? "" : "disabled"}>
                            <i class="bi bi-trash"></i>
                        </button>
                    </div>
                    <input type="file" class="js-amm-upload-input d-none" data-stock="${stock}" multiple accept="image/*" />
                </div>
                <div class="majordome-action-group">
                    <div class="majordome-action-title">Story</div>
                    <div class="majordome-action-buttons">
                        <button type="button" class="btn btn-gradient-grey border-dark shadow-sm js-amm-create-story" data-stock="${stock}" title="Create story for Stock# ${stock}">
                            <i class="bi bi-book"></i>
                        </button>
                        <button type="button" class="btn btn-gradient-grey border-dark shadow-sm js-amm-delete-story" data-stock="${stock}" title="Delete story for Stock# ${stock}">
                            <i class="bi bi-book-fill"></i>
                        </button>
                    </div>
                </div>
                <div class="majordome-action-group">
                    <div class="majordome-action-title">DataOne</div>
                    <div class="majordome-action-buttons">
                        <button type="button" class="btn btn-gradient-grey border-dark shadow-sm js-amm-decode-dataone" data-vin="${vin}" title="Decode and override for VIN# ${vin}">
                            <i class="bi bi-car-front"></i>
                        </button>
                        <button type="button" class="btn btn-gradient-grey border-dark shadow-sm js-amm-delete-dataone" data-stock="${stock}" title="Delete DataOne for stock# ${stock}">
                            <i class="bi bi-car-front-fill"></i>
                        </button>
                    </div>
                </div>
            </div>
        `;
    }

    function renderMajordomeInventoryRow(vehicle) {
        const row = normalizeVehicle(vehicle);
        const stock = safeText(row.Stock);
        const search = escapeHtml(buildVehicleSearch(row));
        const image = escapeHtml(toInventoryImageUrl(row.Image));
        const yearMake = `${safeText(row.Year)} ${safeText(row.Make)}`.trim();
        const modelStyle = `${safeText(row.Model)} ${safeText(row.VehicleStyle)}`.trim();
        const vin = safeText(row.VIN);
        const purchaseDate = formatPurchaseDate(row.PurchaseDate);
        const upload = safeText(row.SetToUpload).toUpperCase() === "Y";
        const story = hasStory(row);
        const dataOne = hasDataOne(row);
        const gtxBadge = getMajordomeGtxBadgeInfo(row.LocationCode);

        return `
            <tr class="majordome-vehicle-row" data-stock="${escapeHtml(stock)}" data-search="${search}">
                <td>
                    <img src="${image}" alt="${escapeHtml(stock)}" class="majordome-thumb majordome-row-image" />
                </td>
                <td class="majordome-row-details">
                    <div class="majordome-vehicle-title">${escapeHtml(yearMake)}</div>
                    <div class="majordome-vehicle-meta">${escapeHtml(modelStyle)}</div>
                    <div class="majordome-vehicle-meta">VIN: ${escapeHtml(vin)}</div>
                </td>
                <td class="d-none d-lg-table-cell">${escapeHtml(purchaseDate)}</td>
                <td><span class="fw-semibold">${escapeHtml(stock)}</span></td>
                <td class="text-center d-none d-xl-table-cell">
                    <span class="majordome-status-pill majordome-status-location ${escapeHtml(gtxBadge.toneClass)}">${escapeHtml(gtxBadge.label)}</span>
                </td>
                <td class="text-center d-none d-md-table-cell">
                    <span class="majordome-status-pill majordome-status-upload ${upload ? "is-on" : ""}">${upload ? "Y" : "N"}</span>
                </td>
                <td class="text-center d-none d-md-table-cell">
                    <span class="majordome-status-pill majordome-status-story ${story ? "is-on" : ""}">${story ? "Y" : "N"}</span>
                </td>
                <td class="text-center d-none d-md-table-cell">
                    <span class="majordome-status-pill majordome-status-dataone ${dataOne ? "is-on" : ""}">${dataOne ? "Y" : "N"}</span>
                </td>
                <td class="text-start majordome-actions-cell">${renderMajordomeActionButtons(row)}</td>
            </tr>
        `;
    }

    function markSelectedRow(stock) {
        const key = safeText(stock).trim().toUpperCase();

        $("#majordomeInventoryBody .majordome-vehicle-row").each(function () {
            const rowKey = safeText($(this).attr("data-stock")).trim().toUpperCase();
            $(this).toggleClass("is-selected", rowKey === key);
        });
    }

    function syncMajordomeGalleryAvailability() {
        const hasSelectedStock = safeText(selectedVehicleStock || selectedVehicle?.Stock || window.majordomeSelectedStock || "").trim().length > 0;
        const $galleryTab = $("#gallery-tab");
        const $galleryPane = $("#tab-gallery");
        const $uploadBtn = $("#upload");
        const $deleteAllBtn = $("#deleteAll");
        const selectedImageCount = Array.isArray(selectedVehicle?.Images) ? selectedVehicle.Images.length : 0;

        if (hasSelectedStock) {
            $galleryTab.removeClass("d-none");
            $galleryPane.removeClass("d-none");
            $uploadBtn.prop("disabled", false);
            $deleteAllBtn.prop("disabled", selectedImageCount === 0);
            $dropzone.removeClass("opacity-50");
            return;
        }

        $galleryTab.addClass("d-none").removeClass("active");
        $galleryPane.addClass("d-none").removeClass("show active");
        $uploadBtn.prop("disabled", true);
        $deleteAllBtn.prop("disabled", true);
        $dropzone.removeClass("dragover").addClass("opacity-50");
        $("#sortable-gallery").empty();
        $galleryTab.text("Photos");
    }

    function renderMajordomeInventoryRows(data) {
        if (Array.isArray(data)) {
            inventoryVehiclesSource = data.map(normalizeVehicle);
        }

        inventoryVehicles = sortMajordomeVehicles(inventoryVehiclesSource);
        const rowsHtml = inventoryVehicles.map(renderMajordomeInventoryRow).join("");
        if (window.gtxSecurity && typeof window.gtxSecurity.setSafeHtml === "function") {
            window.gtxSecurity.setSafeHtml($("#majordomeInventoryBody"), rowsHtml);
        } else {
            const bodyElement = document.getElementById("majordomeInventoryBody");
            if (bodyElement) {
                bodyElement.innerHTML = rowsHtml;
            }
        }
        updateMajordomeSortHeaders();
        syncMajordomeEmptyState();
        markSelectedRow(selectedVehicleStock);
        syncMajordomeGalleryAvailability();
    }

    function selectMajordomeVehicle(stock) {
        const stockKey = safeText(stock).trim().toUpperCase();
        if (!stockKey) return;

        const vehicle = inventoryVehicles.find(function (item) {
            return safeText(item.Stock).trim().toUpperCase() === stockKey;
        });

        if (!vehicle) return;

        selectedVehicle = vehicle;
        selectedVehicleStock = safeText(vehicle.Stock).trim();
        window.majordomeSelectedStock = selectedVehicleStock;
        markSelectedRow(selectedVehicleStock);

        showVehicleDetails(selectedVehicle);
        loadGallery(selectedVehicle);
        syncMajordomeQrCode(selectedVehicle);
        syncMajordomeGalleryAvailability();
    }

    function selectFirstVisibleMajordomeVehicle(keepCurrent) {
        const keep = keepCurrent !== false;
        const $rows = getMajordomeFilterMatchedRows();

        if ($rows.length === 0) {
            selectedVehicle = null;
            selectedVehicleStock = null;
            window.majordomeSelectedStock = "";
            markSelectedRow("");
            syncMajordomeGalleryAvailability();
            return;
        }

        if (keep && selectedVehicleStock) {
            const currentKey = safeText(selectedVehicleStock).trim().toUpperCase();
            const $current = $rows.filter(function () {
                return safeText($(this).attr("data-stock")).trim().toUpperCase() === currentKey;
            }).first();

            if ($current.length) {
                const currentVehicle = inventoryVehicles.find(function (item) {
                    return safeText(item.Stock).trim().toUpperCase() === currentKey;
                });

                if (currentVehicle) {
                    selectedVehicle = currentVehicle;
                    selectedVehicleStock = safeText(currentVehicle.Stock).trim();
                    window.majordomeSelectedStock = selectedVehicleStock;
                }

                markSelectedRow(selectedVehicleStock);
                syncMajordomeGalleryAvailability();
                return;
            }
        }

        const firstStock = $rows.first().attr("data-stock");
        selectMajordomeVehicle(firstStock);
    }

    function applyFilterTerm(term) {
        const raw = safeText(term);
        const normalized = raw.trim().toUpperCase();
        const terms = normalized.split(/\s+/).filter(Boolean);

        if (!normalized) {
            sessionStorage.removeItem("term");
        }

        $("#majordomeInventoryBody .majordome-vehicle-row").each(function () {
            const haystack = safeText($(this).data("search")).toUpperCase();
            const matched = terms.length === 0 || terms.every(function (t) { return haystack.includes(t); });
            $(this).toggleClass("is-filter-hidden", !matched);
            $(this).toggle(matched);
        });

        const stocks = getMajordomeFilterMatchedRows().map(function () {
            return $(this).attr("data-stock");
        }).get();

        if (stocks.length > 0) {
            localStorage.setItem("matchedStocks", JSON.stringify(stocks));
        } else {
            localStorage.removeItem("matchedStocks");
        }

        sessionStorage.setItem("term", raw);
        syncMajordomeEmptyState();
    }

    function syncMajordomeQrCode(vehicle) {
        if (!vehicle) return;
        const qrUrl = "/Majordome/Qr?stock=" + encodeURIComponent(vehicle.Stock || "") + "&vin=" + encodeURIComponent(vehicle.VIN || "");
        $("#qrImg").attr("src", qrUrl);
        $("#qrText").text(`${vehicle.Year} ${vehicle.Make} ${vehicle.Model} Stock# ${vehicle.Stock}`);
        $("#QR-code-tab").removeClass("d-none");
    }

    function getSelectedVehicleStockOrWarn() {
        const stock = safeText(selectedVehicle?.Stock || selectedVehicleStock || window.majordomeSelectedStock || "").trim();
        if (!stock) {
            alert("Please select a vehicle first.");
            return "";
        }

        if (!selectedVehicle || safeText(selectedVehicle.Stock).trim().toUpperCase() !== stock.toUpperCase()) {
            const current = inventoryVehicles.find(function (item) {
                return safeText(item.Stock).trim().toUpperCase() === stock.toUpperCase();
            });

            if (current) {
                selectedVehicle = current;
            }
        }

        return stock;
    }

    function updateRow(data) {
        const preferredStock = safeText(selectedVehicleStock || selectedVehicle?.Stock || window.majordomeSelectedStock || "").trim();
        const forcedTabId = safeText(window.majordomeForceActiveTab || "").trim();
        const activeTabId = forcedTabId || $("#myTab button.active").attr("id") || "inventory-tab";
        const currentFilter = $("#filterTerm").val() || "";

        if (preferredStock) {
            window.majordomeSelectedStock = preferredStock;
        }

        renderMajordomeInventoryRows(data);
        applyFilterTerm(currentFilter);

        let hasSelectedVehicle = false;
        if (preferredStock) {
            const isVisible = getMajordomeFilterMatchedRows().filter(function () {
                return safeText($(this).attr("data-stock")).trim().toUpperCase() === safeText(preferredStock).trim().toUpperCase();
            }).length > 0;

            if (isVisible) {
                selectMajordomeVehicle(preferredStock);
                hasSelectedVehicle = true;
            } else {
                selectFirstVisibleMajordomeVehicle(false);
            }
        } else {
            selectFirstVisibleMajordomeVehicle(false);
        }

        if (!hasSelectedVehicle && safeText(selectedVehicleStock || selectedVehicle?.Stock || "").trim()) {
            hasSelectedVehicle = true;
        }

        if (hasSelectedVehicle && activeTabId === "gallery-tab") {
            $("#gallery-tab").tab("show");
        } else if (hasSelectedVehicle && activeTabId === "details-tab") {
            $("#details-tab").tab("show");
        } else if (hasSelectedVehicle && activeTabId === "QR-code-tab") {
            $("#QR-code-tab").tab("show");
        }

        syncMajordomeGalleryAvailability();
        if (window.majordomeForceActiveTab) {
            window.majordomeForceActiveTab = "";
        }
        hideSpinner($("#inventoryOverlay"));
    }

    window.applyMajordomeInventoryFilter = applyFilterTerm;
    window.onMajordomeInventoryDataUpdated = updateRow;

    const sortable = new Sortable(document.getElementById("sortable-gallery"), {
        scroll: true,
        scrollSensitivity: 30,
        scrollSpeed: 20,
        animation: 150,
        ghostClass: "sortable-gallery-ghost",
        chosenClass: "sortable-gallery-chosen",
        dragClass: "sortable-gallery-drag",
        delay: 100,
        touchStartThreshold: 5,
        onEnd: function (event) {
            if (event && event.oldIndex === event.newIndex) {
                return;
            }

            let sorted = $("#sortable-gallery li").map(function () {
                return $(this).attr("id")
            }).get();
            saveOrder(sorted, { fastMode: true });
            updateGalleryDisplay();
        }
    });

    // Show Bootstrap modal with images
    function showOverlayModal(id) {
        const stock = safeText(selectedVehicle?.Stock || selectedVehicleStock || window.majordomeSelectedStock || "").trim();
        if (!stock) return;

        showSpinner($("#inventoryOverlay"));
        $.get(`${root}Majordome/OverlayModal`, { id })
            .done(function (html) {
                $("#vehicle-overlay").html(html);
                $("#overlayModal").modal("show");
            })
            .fail(function (xhr, status, error) {
                console.error("OverlayModal failed:", status, error, xhr && xhr.responseText);
                alert("Failed to load overlay editor.");
            })
            .always(function () {
                hideSpinner($("#inventoryOverlay"));
            });
    }

    function showVehicleDetails(vehicle) {
        const activeElement = document.activeElement;
        const shouldRestoreFilterFocus = activeElement && activeElement.id === "filterTerm";
        const restoreStart = shouldRestoreFilterFocus && typeof activeElement.selectionStart === "number" ? activeElement.selectionStart : null;
        const restoreEnd = shouldRestoreFilterFocus && typeof activeElement.selectionEnd === "number" ? activeElement.selectionEnd : null;

        $('#vin').val(vehicle.VIN);
        $('#storyTitle').val(vehicle.Story?.Title);
        quill.setContents([]);
        quill.clipboard.dangerouslyPasteHTML(0, vehicle?.Story?.HtmlContent || "", "api");

        if (shouldRestoreFilterFocus) {
            activeElement.focus({ preventScroll: true });
            if (restoreStart !== null && restoreEnd !== null && typeof activeElement.setSelectionRange === "function") {
                activeElement.setSelectionRange(restoreStart, restoreEnd);
            }
        }

        if (vehicle.Stock) {
            $.ajax({
                url: '/Majordome/GetDataOneDetails',
                type: 'GET',
                data: { stock: vehicle.Stock },
                success: function (html) {
                    // Replace or inject the partial view HTML
                    if (window.gtxSecurity && typeof window.gtxSecurity.setSafeHtml === "function") {
                        window.gtxSecurity.setSafeHtml($('#dataOneDetails'), html);
                    } else {
                        $('#dataOneDetails').text(html);
                    }
                },
                error: function () {
                    alert("Error loading vehicle details");
                }
            });
        }

        $("#gallery-tab").text(`Photos (${vehicle.Images.length})`);
        $("#QR-code-tab").removeClass("d-none");
    }

    function handleFiles(fileList) {
        const files = Array.from(fileList || []).filter(f => {
            const n = (f.name || '').toLowerCase();
            return f.type.startsWith('image/') || /\.(heic|heif|jpg|jpeg|png|webp|gif|bmp|tiff)$/.test(n);
        });
        const stock = safeText(selectedVehicle?.Stock || selectedVehicleStock || window.majordomeSelectedStock || "").trim();
        if (!files.length) return;
        if (!stock) return;
        uploadDroppedFiles(stock, files);
    }

</script>
