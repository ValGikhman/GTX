    function updateMajordomeBulkProgress(processed, total) {
        const percent = total > 0 ? Math.round((processed / total) * 100) : 0;
        $("#majordomeBulkProgressCounts").text(`${processed} of ${total}`);
        $("#majordomeBulkProgressPercent").text(`${percent}%`);
        $("#majordomeBulkProgressTrack").attr("aria-valuenow", percent);
        $("#majordomeBulkProgressBar")
            .css("width", `${percent}%`)
            .text(percent > 0 ? `${percent}%` : "");
    }

    function getMajordomeBulkProgressTotal(config, items) {
        const configuredTotal = parseInt(config?.progressTotal, 10) || 0;
        return configuredTotal > 0 ? configuredTotal : items.length;
    }

    function getMajordomeBulkProgressUnits(job, result) {
        const configuredTotal = parseInt(job?.config?.progressTotal, 10) || 0;
        if (configuredTotal > 0) {
            const units = parseInt(result?.progressUnits, 10) || 0;
            return units > 0 ? units : 0;
        }

        return 1;
    }

    function getMajordomeBulkDisplayProcessed(job) {
        const configuredTotal = parseInt(job?.config?.progressTotal, 10) || 0;
        return configuredTotal > 0 ? job.progressProcessed : job.processed;
    }

    function getMajordomeBulkDisplayTotal(job) {
        const configuredTotal = parseInt(job?.config?.progressTotal, 10) || 0;
        return configuredTotal > 0 ? job.progressTotal : job.items.length;
    }

    function setMajordomeBulkStatus(message) {
        $("#majordomeBulkProgressStatus").text(message || "");
    }

    function appendMajordomeBulkLog(message, status) {
        const statusClass = status === "success"
            ? "list-group-item-success"
            : status === "error"
                ? "list-group-item-danger"
                : status === "warning"
                    ? "list-group-item-warning"
                    : "list-group-item-light";

        const $log = $("#majordomeBulkProgressLog");
        const $item = $("<div></div>")
            .addClass(`list-group-item ${statusClass}`)
            .text(message);
        $log.append($item);
        $log.scrollTop($log.prop("scrollHeight"));
    }

    function waitMajordomeBulkDelay(ms, job) {
        return new Promise(function (resolve) {
            const started = Date.now();
            const tick = function () {
                if (!job || job.cancelRequested || Date.now() - started >= ms) {
                    resolve();
                    return;
                }

                setTimeout(tick, Math.min(200, ms));
            };

            tick();
        });
    }

    function openMajordomeBulkProgressModal(actionKey, options) {
        if (majordomeBulkJob && majordomeBulkJob.running) return;

        const config = getMajordomeBulkConfig(actionKey, options);
        if (!config) return;

        const items = config.getItems();
        const progressTotal = getMajordomeBulkProgressTotal(config, items);
        majordomeBulkJob = {
            config: config,
            items: items,
            processed: 0,
            progressProcessed: 0,
            progressTotal: progressTotal,
            completed: 0,
            canceled: 0,
            failed: 0,
            warnings: 0,
            running: false,
            cancelRequested: false
        };

        $("#majordomeBulkProgressTitle").text(config.title);
        $("#majordomeBulkProgressIntro").text(items.length > 0 ? config.intro(items.length) : config.emptyText);
        $("#majordomeBulkProgressLog").empty();
        setMajordomeBulkStatus(items.length > 0 ? "Review the job, then press Start." : "Nothing to update.");
        updateMajordomeBulkProgress(0, progressTotal);

        $("#majordomeBulkStart")
            .removeClass("d-none")
            .prop("disabled", items.length === 0)
            .text("Start");
        $("#majordomeBulkCancel")
            .prop("disabled", false)
            .text(items.length > 0 ? "Cancel" : "Close");

        showMajordomeBulkModal();
    }

