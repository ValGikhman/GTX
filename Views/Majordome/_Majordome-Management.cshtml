@using Newtonsoft.Json
@{
    var managementLogsJson = System.Web.HttpUtility.JavaScriptStringEncode(
        JsonConvert.SerializeObject(ViewBag.InventoryManagementLogs ?? Array.Empty<object>()));
}

<style>
    .majordome-management-shell {
        --inventory-border: var(--bs-border-color-translucent, rgba(30, 41, 59, .12));
        --inventory-line: var(--bs-border-color-translucent, rgba(148, 163, 184, .22));
        --inventory-muted: var(--bs-secondary-color, #64748b);
        --inventory-ink: var(--bs-body-color, #172033);
        --inventory-surface: var(--bs-body-bg, #fff);
        --inventory-surface-alt: var(--bs-tertiary-bg, #f8fafc);
        --inventory-header-bg: var(--gtx-grad, var(--bs-primary-bg-subtle, #f8fafc));
        --inventory-header-color: #fff;
        --inventory-header-border: rgba(255, 255, 255, .24);
        background: var(--inventory-surface);
        margin-top: .75rem;
        border-radius: .85rem;
        border: 1px solid var(--inventory-border);
        box-shadow: 0 .8rem 2rem rgba(15, 23, 42, .09);
        overflow: hidden;
    }

    html.theme-silver .majordome-management-shell {
        --inventory-header-color: #111827;
        --inventory-header-border: rgba(15, 23, 42, .16);
    }

    .majordome-management-toolbar {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        justify-content: flex-start;
        gap: .75rem;
        padding: .75rem .85rem;
        background: linear-gradient(180deg, var(--inventory-surface) 0%, var(--inventory-surface-alt) 100%);
        border-bottom: 1px solid var(--inventory-line);
    }

    .inventory-management-upload-button {
        flex: 0 0 auto;
        min-height: 2.5rem;
    }

    .majordome-management-log-picker {
        flex: 0 1 36rem;
        min-width: min(100%, 24rem);
        max-width: 42rem;
    }

    .majordome-management-log-select {
        height: 2.5rem;
        min-height: 2.5rem;
        display: inline-flex;
        align-items: center;
        justify-content: space-between;
        gap: .75rem;
        border-radius: .65rem;
        border-color: var(--inventory-border);
        box-shadow: 0 .25rem .75rem rgba(15, 23, 42, .06);
        font-weight: 650;
    }

    .majordome-management-search {
        flex: 0 1 340px;
        margin-left: auto;
        max-width: 265px;
        min-width: 260px;
        position: relative;
        border-radius: .65rem;
    }

        .majordome-management-search .form-control {
            height: 2.5rem;
            min-height: 2.5rem;
            border-color: var(--inventory-border);
            border-radius: .65rem;
            box-shadow: 0 .25rem .75rem rgba(15, 23, 42, .06);
            font-weight: 600;
            padding-right: 2.55rem;
        }

        .majordome-management-search-clear {
            position: absolute;
            top: 50%;
            right: .25rem;
            z-index: 4;
            width: 2rem;
            height: 2rem;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            border: 0;
            border-radius: .5rem;
            background: transparent;
            color: var(--inventory-muted);
            transform: translateY(-50%);
        }

            .majordome-management-search-clear:hover,
            .majordome-management-search-clear:focus {
                color: var(--inventory-ink);
                background: rgba(148, 163, 184, .14);
            }

    .majordome-management-status-filter,
    .majordome-management-location-filter {
        flex: 0 0 130px;
        width: 130px;
        height: 2.5rem;
        min-height: 2.5rem;
        border-color: var(--inventory-border);
        border-radius: .65rem;
        box-shadow: 0 .25rem .75rem rgba(15, 23, 42, .06);
        font-size: .88rem;
        font-weight: 700;
    }

    .majordome-management-include-skipped {
        flex: 0 0 auto;
        min-height: 2.5rem;
        display: inline-flex;
        align-items: center;
        gap: .45rem;
        padding: .35rem .75rem;
        border: 1px solid var(--inventory-border);
        border-radius: .65rem;
        background: linear-gradient(180deg, #fff 0%, var(--inventory-surface-alt) 100%);
        color: var(--inventory-ink);
        box-shadow: 0 .25rem .75rem rgba(15, 23, 42, .06);
        white-space: nowrap;
    }

        .majordome-management-include-skipped .form-check-input {
            margin: 0;
        }

        .majordome-management-include-skipped .form-check-label {
            color: var(--inventory-muted);
            font-size: .72rem;
            font-weight: 800;
            letter-spacing: .03em;
            text-transform: uppercase;
        }

        .majordome-management-log-select:focus,
        .majordome-management-search .form-control:focus,
        .majordome-management-status-filter:focus,
