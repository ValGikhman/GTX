            border-color: rgba(22, 163, 74, .45);
            background: rgba(22, 163, 74, .12);
            color: #166534;
        }

    .majordome-management-detail-cell {
        padding: 0 !important;
    }

    .majordome-management-detail-panel {
        padding: .9rem 1rem 1rem;
        border-top: 1px solid var(--inventory-line);
        background: rgba(248, 250, 252, .82);
    }

    .majordome-management-change-table {
        margin: 0 0 0 3rem;
        font-size: .88rem;
        max-width: calc(100% - 3rem);
        min-width: min(420px, calc(100% - 3rem));
        table-layout: auto;
        width: auto;
    }

        .majordome-management-change-table th:nth-child(1),
        .majordome-management-change-table td:nth-child(1) {
            min-width: 9rem;
            white-space: nowrap;
        }

        .majordome-management-change-table th:nth-child(2),
        .majordome-management-change-table td:nth-child(2),
        .majordome-management-change-table th:nth-child(3),
        .majordome-management-change-table td:nth-child(3) {
