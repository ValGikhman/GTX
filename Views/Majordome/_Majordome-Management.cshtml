    }

    .majordome-vehicle-meta {
        font-size: .78rem;
        color: var(--inventory-muted);
        line-height: 1.25;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .majordome-vin-line {
        font-family: var(--bs-font-monospace);
        letter-spacing: .01em;
    }

    @@media (max-width: 767.98px) {
        .majordome-management-toolbar {
            align-items: stretch;
