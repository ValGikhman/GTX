            width: auto;
        }

        .majordome-management-change-table th {
            background: linear-gradient(180deg, rgb(255 255 255), #AAAAB3) !important;
            border-bottom: 1px solid rgba(15, 23, 42, .18);
            color: #111827;
            font-size: .72rem;
            font-weight: 800;
            letter-spacing: .03em;
            line-height: 1.15;
            padding-bottom: .4rem !important;
            padding-top: .4rem !important;
            text-transform: uppercase;
        }

        .majordome-management-change-table td {
            background: #fff !important;
            max-width: 34rem;
            overflow-wrap: anywhere;
        }

        .majordome-management-change-table td.majordome-management-change-number {
            font-variant-numeric: tabular-nums;
            text-align: right;
            white-space: nowrap;
        }

        .majordome-management-change-table .majordome-management-change-spacer-cell {
            padding-left: 0 !important;
            padding-right: 0 !important;
        }

    .majordome-thumb {
        width: 88px;
        height: 66px;
        object-fit: cover;
        border-radius: .55rem;
        border: 1px solid rgba(15, 23, 42, .12);
        box-shadow: 0 .35rem .8rem rgba(15, 23, 42, .15);
        background: #fff;
        transition: box-shadow .15s, transform .15s;
    }

    #majordomeManagementTable .majordome-row-details {
        width: 170px;
        min-width: 170px;
        max-width: 170px;
    }

    .majordome-vehicle-title {
        color: var(--inventory-ink);
        font-size: .98rem;
        font-weight: 800;
        line-height: 1.2;
        white-space: nowrap;
