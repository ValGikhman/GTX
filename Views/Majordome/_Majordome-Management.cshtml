@using Newtonsoft.Json
@{
    var managementLogsJson = System.Web.HttpUtility.JavaScriptStringEncode(
        JsonConvert.SerializeObject(ViewBag.InventoryManagementLogs ?? Array.Empty<object>()));
}

<style>
    .majordome-management-shell {
        --majordome-management-scroll-height: 78vh;
        --inventory-border: var(--bs-border-color-translucent, rgba(30, 41, 59, .12));
        --inventory-line: var(--bs-border-color-translucent, rgba(148, 163, 184, .22));
        --inventory-muted: var(--bs-secondary-color, #64748b);
        --inventory-ink: var(--bs-body-color, #172033);
        --inventory-surface: var(--bs-body-bg, #fff);
        --inventory-surface-alt: var(--bs-tertiary-bg, #f8fafc);
        --inventory-header-bg: var(--gtx-grad, var(--bs-primary-bg-subtle, #f8fafc));
        --inventory-header-color: #fff;
        --inventory-header-border: rgba(255, 255, 255, .24);
        --inventory-selected-accent: var(--bs-primary, #2563eb);
        --inventory-selected-bg: rgba(var(--bs-primary-rgb, 37, 99, 235), .1);
        background: var(--inventory-surface);
        margin-top: .75rem;
        border-radius: .85rem;
        border: 1px solid var(--inventory-border);
        box-shadow: 0 .8rem 2rem rgba(15, 23, 42, .09);
        overflow: hidden;
    }

    html.theme-silver .majordome-management-shell {
        --inventory-header-color: #111827;
        --inventory-header-border: rgba(15, 23, 42, .16);
        --inventory-selected-accent: #8f98a3;
        --inventory-selected-bg: rgba(143, 152, 163, .16);
    }

    html.theme-blue .majordome-management-shell {
        --inventory-selected-accent: #1e73be;
        --inventory-selected-bg: rgba(30, 115, 190, .14);
    }

    html.theme-grey .majordome-management-shell,
    html.theme-dark .majordome-management-shell {
        --inventory-selected-accent: darkgray;
        --inventory-selected-bg: rgba(169, 169, 169, .18);
    }

    html.theme-pink .majordome-management-shell {
        --inventory-selected-accent: #c2185b;
        --inventory-selected-bg: rgba(194, 24, 91, .14);
    }

    html.theme-deep-purple .majordome-management-shell {
        --inventory-selected-accent: #6a1bb1;
        --inventory-selected-bg: rgba(106, 27, 177, .14);
    }

    html.theme-metallica .majordome-management-shell {
        --inventory-selected-accent: #9aa0a8;
        --inventory-selected-bg: rgba(154, 160, 168, .18);
    }

    .majordome-management-toolbar {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        justify-content: flex-start;
        gap: .75rem;
        padding: .75rem .85rem;
        background: linear-gradient(180deg, var(--inventory-surface) 0%, var(--inventory-surface-alt) 100%);
        border-bottom: 1px solid var(--inventory-line);
    }

    .majordome-management-workspace {
        display: flex;
        align-items: stretch;
        min-height: 0;
    }

    .majordome-management-sidebar-pane {
        flex: 0 0 320px;
        width: 320px;
        min-width: 280px;
        max-width: 380px;
        max-height: var(--majordome-management-scroll-height);
        overflow-x: hidden;
        overflow-y: auto;
        background: #f8fafc;
        border-right: 1px solid var(--inventory-line);
        scrollbar-color: rgba(71, 85, 105, .45) transparent;
        scrollbar-width: thin;
    }

        .majordome-management-sidebar-pane::-webkit-scrollbar {
            width: .55rem;
        }

        .majordome-management-sidebar-pane::-webkit-scrollbar-thumb {
            background: rgba(71, 85, 105, .35);
            border-radius: 999px;
        }

    .majordome-management-results {
        flex: 1 1 auto;
        min-width: 0;
        display: flex;
        flex-direction: column;
    }

    .inventory-management-upload-button {
        flex: 0 0 auto;
        min-height: 2.5rem;
    }

    .majordome-management-log-picker {
        height: 100%;
        display: flex;
        flex-direction: column;
        padding: .75rem;
    }

    .majordome-management-log-tree {
        flex: 1 1 auto;
        min-height: 0;
        overflow-y: auto;
        padding-right: .15rem;
        scrollbar-color: rgba(71, 85, 105, .45) transparent;
        scrollbar-width: thin;
    }

        .majordome-management-log-tree::-webkit-scrollbar {
            width: .55rem;
        }

        .majordome-management-log-tree::-webkit-scrollbar-thumb {
            background: rgba(71, 85, 105, .35);
            border-radius: 999px;
        }

    .majordome-management-log-date {
        border: 1px solid var(--inventory-border);
        border-radius: .65rem;
        background: #fff;
        box-shadow: 0 .3rem .9rem rgba(15, 23, 42, .05);
        overflow: hidden;
    }

        .majordome-management-log-date + .majordome-management-log-date {
            margin-top: .6rem;
        }

    .majordome-management-log-date-toggle {
        width: 100%;
        min-height: 3rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: .55rem;
        padding: .55rem .65rem;
        border: 0;
        background: linear-gradient(180deg, #fff 0%, var(--inventory-surface-alt) 100%);
        color: var(--inventory-ink);
        text-align: left;
    }

        .majordome-management-log-date-toggle:hover,
        .majordome-management-log-date-toggle:focus {
            background: #eef2f7;
            outline: none;
        }

        .majordome-management-log-date-toggle.is-selected {
            background: var(--inventory-header-bg);
            color: var(--inventory-header-color);
            box-shadow: inset .28rem 0 var(--inventory-header-border), 0 .35rem .8rem rgba(15, 23, 42, .12);
        }

            .majordome-management-log-date-toggle.is-selected:hover,
            .majordome-management-log-date-toggle.is-selected:focus {
                background: var(--inventory-header-bg);
                color: var(--inventory-header-color);
            }

            .majordome-management-log-date-toggle.is-selected .majordome-management-log-option-date,
            .majordome-management-log-date-toggle.is-selected .majordome-management-log-date-chevron {
                color: var(--inventory-header-color);
            }

            .majordome-management-log-date-toggle.is-selected .majordome-management-log-date-count {
                background: rgba(255, 255, 255, .22) !important;
                border: 1px solid var(--inventory-header-border);
                color: var(--inventory-header-color);
            }

    html.theme-silver .majordome-management-log-date-toggle.is-selected .majordome-management-log-date-count {
        background: rgba(15, 23, 42, .12) !important;
        border-color: rgba(15, 23, 42, .18);
        color: #111827;
    }

    html.theme-silver .majordome-management-log-date-toggle.is-selected .majordome-management-log-date-chevron,
    html.theme-silver .majordome-management-log-date-toggle.is-selected .majordome-management-log-option-date {
        color: #111827;
    }

    .majordome-management-log-date-toggle.is-selected.collapsed,
    .majordome-management-log-date-toggle.is-selected[aria-expanded="false"] {
        background: var(--inventory-header-bg);
        color: var(--inventory-header-color);
    }

        html.theme-silver .majordome-management-log-date-toggle.is-selected.collapsed,
        html.theme-silver .majordome-management-log-date-toggle.is-selected[aria-expanded="false"] {
            color: #111827;
        }

    .majordome-management-log-date-main {
        min-width: 0;
        display: flex;
        align-items: center;
        gap: .45rem;
    }

    .majordome-management-log-date-chevron {
