        }

    .majordome-management-log-menu {
        width: min(42rem, calc(100vw - 2rem));
        max-height: 22rem;
        overflow-y: auto;
        padding: .35rem;
    }

    .majordome-management-log-option {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: .75rem;
        min-height: 2.5rem;
