        }

        .majordome-sortable-th.is-active .majordome-sort-indicator {
            opacity: 1;
            transform: translateY(-1px);
        }

    #majordomeManagementTable {
        --bs-table-bg: transparent;
        --bs-table-hover-bg: rgba(37, 99, 235, .045);
        --bs-table-color: var(--inventory-ink);
