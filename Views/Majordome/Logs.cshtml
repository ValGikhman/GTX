@using System.Linq
@model Services.Log[]
@{
    var logs = Model ?? System.Array.Empty<Services.Log>();
    var levels = logs
        .Select(l => (l?.LogLevel ?? string.Empty).Trim())
        .Where(l => !string.IsNullOrWhiteSpace(l))
        .Distinct(System.StringComparer.OrdinalIgnoreCase)
        .OrderBy(l => l)
        .ToList();
}

<div class="majordome-logs-page container-fluid px-4 py-3">
    <div class="majordome-logs-shell shadow rounded-4 overflow-hidden border border-dark-subtle">
        <div class="majordome-logs-header p-3">
            <div class="d-flex flex-column align-items-center gap-2">
                <h5 class="majordome-logs-title mb-0 text-center">Application logs</h5>
                <div class="majordome-logs-tools d-flex align-items-center gap-2 flex-wrap">
                    <div class="input-group majordome-logs-search">
                        <span class="input-group-text bg-white">
                            <i class="bi bi-search"></i>
                        </span>
                        <input id="logsSearch" type="search" class="form-control" placeholder="Search logs..." aria-label="Search logs">
                    </div>
                    <select id="logsLevelFilter" class="form-select">
                        <option value="all" selected>All levels</option>
                        @foreach (var level in levels)
                        {
                            <option value="@level.ToUpperInvariant()">@level</option>
                        }
                    </select>
                    <select id="logsPageSize" class="form-select">
                        <option value="20" selected>20</option>
                        <option value="50">50</option>
                        <option value="100">100</option>
                    </select>
                </div>
            </div>
        </div>

        <div class="majordome-logs-table-wrap table-responsive">
            <table id="logsTable" class="table table-hover align-middle m-0">
                <thead class="table-light">
                    <tr>
                        <th class="logs-sort logs-col-level" data-sort-key="loglevel">Level <i class="bi bi-arrow-down-up logs-sort-icon ms-1"></i></th>
                        <th class="logs-sort logs-col-message" data-sort-key="message">Message <i class="bi bi-arrow-down-up logs-sort-icon ms-1"></i></th>
                        <th class="logs-sort logs-col-exception d-none d-xl-table-cell" data-sort-key="exception">Exception <i class="bi bi-arrow-down-up logs-sort-icon ms-1"></i></th>
                        <th class="logs-sort logs-col-url d-none d-lg-table-cell" data-sort-key="url">Url <i class="bi bi-arrow-down-up logs-sort-icon ms-1"></i></th>
                        <th class="logs-sort logs-col-method text-center d-none d-md-table-cell" data-sort-key="method">Method <i class="bi bi-arrow-down-up logs-sort-icon ms-1"></i></th>
                        <th class="logs-sort logs-col-ip text-center d-none d-lg-table-cell" data-sort-key="ip">IP Address <i class="bi bi-arrow-down-up logs-sort-icon ms-1"></i></th>
                        <th class="logs-sort logs-col-created" data-sort-key="created">Created <i class="bi bi-arrow-down-up logs-sort-icon ms-1"></i></th>
                    </tr>
                </thead>
                <tbody id="logsTableBody">
                    @foreach (var log in logs)
                    {
                        System.DateTime? createdRaw = null;
                        if (log != null)
                        {
                            createdRaw = log.DateCreated;
                        }
                        var createdDisplay = createdRaw.HasValue ? createdRaw.Value.ToString("MM/dd/yyyy HH:mm:ss") : string.Empty;
                        var createdSort = createdRaw.HasValue ? createdRaw.Value.ToString("o") : string.Empty;
                        var level = log?.LogLevel ?? string.Empty;
                        var message = log?.Message ?? string.Empty;
                        var exception = log?.Exception ?? string.Empty;
                        var url = log?.Url ?? string.Empty;
                        var method = log?.HttpMethod ?? string.Empty;
                        var ipAddress = log?.IPAddress ?? string.Empty;
                        var searchBlob = string.Join(" ", new[] { level, message, exception, url, method, ipAddress, createdDisplay });
                        var levelUpper = level.ToUpperInvariant();
                        var badgeClass = levelUpper.Contains("ERROR") || levelUpper.Contains("FATAL")
                            ? "bg-danger-subtle text-danger border border-danger-subtle"
                            : levelUpper.Contains("WARN")
                                ? "bg-warning-subtle text-warning-emphasis border border-warning-subtle"
                                : "bg-secondary-subtle text-secondary border border-secondary-subtle";

                        <tr class="logs-row"
                            data-loglevel="@levelUpper"
                            data-search="@searchBlob.ToUpperInvariant()"
                            data-created="@createdSort">
                            <td data-col="loglevel" class="log-cell">
                                <span class="badge rounded-pill log-level-badge @badgeClass">@level</span>
                            </td>
                            <td data-col="message" class="log-cell log-cell-message" title="@message">@message</td>
                            <td data-col="exception" class="log-cell log-cell-exception d-none d-xl-table-cell" title="@exception">@exception</td>
                            <td data-col="url" class="log-cell log-cell-url d-none d-lg-table-cell" title="@url">@url</td>
                            <td data-col="method" class="log-cell text-center d-none d-md-table-cell">@method</td>
                            <td data-col="ip" class="log-cell text-center d-none d-lg-table-cell">@ipAddress</td>
                            <td data-col="created" class="log-cell text-nowrap">@createdDisplay</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="d-flex align-items-center justify-content-between flex-wrap gap-2 p-3 border-top">
            <div id="logsResultInfo" class="small text-muted">Loading...</div>
            <div class="d-flex align-items-center gap-2">
                <button id="logsPrev" type="button" class="btn btn-sm btn-gradient-grey border-dark-subtle">Prev</button>
                <span id="logsPageInfo" class="small fw-semibold px-2">0 / 0</span>
                <button id="logsNext" type="button" class="btn btn-sm btn-gradient-grey border-dark-subtle">Next</button>
            </div>
        </div>
    </div>
</div>

<script type="text/javascript">
    $(function () {
        const $tbody = $("#logsTableBody");
        const $search = $("#logsSearch");
        const $level = $("#logsLevelFilter");
        const $pageSize = $("#logsPageSize");
        const $prev = $("#logsPrev");
        const $next = $("#logsNext");
        const $pageInfo = $("#logsPageInfo");
        const $resultInfo = $("#logsResultInfo");
        const $sortHeaders = $("#logsTable thead th.logs-sort");

        const rows = $tbody.find("tr.logs-row").toArray().map(function (row) {
            const $row = $(row);
            return {
                row: row,
                loglevel: ($row.data("loglevel") || "").toString(),
                search: ($row.data("search") || "").toString(),
                createdTicks: Date.parse(($row.data("created") || "").toString()) || 0,
                message: ($row.find('[data-col="message"]').text() || "").trim().toLowerCase(),
                exception: ($row.find('[data-col="exception"]').text() || "").trim().toLowerCase(),
                url: ($row.find('[data-col="url"]').text() || "").trim().toLowerCase(),
                method: ($row.find('[data-col="method"]').text() || "").trim().toLowerCase(),
                ip: ($row.find('[data-col="ip"]').text() || "").trim().toLowerCase(),
                created: ($row.find('[data-col="created"]').text() || "").trim().toLowerCase()
            };
        });

        const state = {
            term: "",
            level: "all",
            page: 1,
            pageSize: parseInt($pageSize.val(), 10) || 20,
            sortKey: "created",
            sortDir: "desc"
        };

        function compareValues(a, b) {
            if (a === b) return 0;
            return a > b ? 1 : -1;
        }

        function sortRows(filteredRows) {
            const sorted = filteredRows.slice();
            const key = state.sortKey;
            const dir = state.sortDir === "asc" ? 1 : -1;

            sorted.sort(function (a, b) {
                let valA;
                let valB;

                if (key === "created") {
                    valA = a.createdTicks;
                    valB = b.createdTicks;
                    return compareValues(valA, valB) * dir;
                }

                if (key === "loglevel") {
                    valA = (a.loglevel || "").toLowerCase();
                    valB = (b.loglevel || "").toLowerCase();
                } else {
                    valA = (a[key] || "").toLowerCase();
                    valB = (b[key] || "").toLowerCase();
                }

                return valA.localeCompare(valB, undefined, { numeric: true, sensitivity: "base" }) * dir;
            });

            return sorted;
        }

        function applyFilters() {
            const termUpper = (state.term || "").toUpperCase();
            const filterLevel = (state.level || "all").toUpperCase();

            return rows.filter(function (row) {
                const termMatch = !termUpper || row.search.includes(termUpper);
                const levelMatch = filterLevel === "ALL" || row.loglevel === filterLevel;
                return termMatch && levelMatch;
            });
        }

        function syncSortIndicators() {
            $sortHeaders.each(function () {
                const $header = $(this);
                const key = ($header.data("sortKey") || "").toString();
                const $icon = $header.find(".logs-sort-icon");
                const isActive = key === state.sortKey;

                $header.toggleClass("is-active", isActive);
                $icon.removeClass("bi-arrow-down-up bi-arrow-up bi-arrow-down");

                if (!isActive) {
                    $icon.addClass("bi-arrow-down-up");
                    return;
                }

                $icon.addClass(state.sortDir === "asc" ? "bi-arrow-up" : "bi-arrow-down");
            });
        }

        function render() {
            const filtered = sortRows(applyFilters());
            const total = filtered.length;
            const totalPages = total === 0 ? 0 : Math.ceil(total / state.pageSize);

            if (totalPages === 0) {
                state.page = 1;
            } else if (state.page > totalPages) {
                state.page = totalPages;
            } else if (state.page < 1) {
                state.page = 1;
            }

            const startIndex = total === 0 ? 0 : (state.page - 1) * state.pageSize;
            const endIndex = total === 0 ? 0 : Math.min(startIndex + state.pageSize, total);
            const pageRows = filtered.slice(startIndex, endIndex);

            $tbody.empty();

            if (pageRows.length === 0) {
                $tbody.append('<tr><td colspan="7" class="text-center p-4 text-muted">No logs match the current filter.</td></tr>');
            } else {
                $tbody.append(pageRows.map(function (entry) { return entry.row; }));
            }

            if (total === 0) {
                $resultInfo.text("No matching logs");
                $pageInfo.text("0 / 0");
            } else {
                $resultInfo.text("Showing " + (startIndex + 1) + "-" + endIndex + " of " + total + " logs");
                $pageInfo.text(state.page + " / " + totalPages);
            }

            $prev.prop("disabled", totalPages <= 1 || state.page <= 1);
            $next.prop("disabled", totalPages <= 1 || state.page >= totalPages);

            syncSortIndicators();
        }

        $search.on("input", function () {
            state.term = ($(this).val() || "").trim();
            state.page = 1;
            render();
        });

        $level.on("change", function () {
            state.level = ($(this).val() || "all").toString();
            state.page = 1;
            render();
        });

        $pageSize.on("change", function () {
            state.pageSize = parseInt($(this).val(), 10) || 20;
            state.page = 1;
            render();
        });

        $prev.on("click", function () {
            state.page -= 1;
            render();
        });

        $next.on("click", function () {
            state.page += 1;
            render();
        });

        $sortHeaders.on("click", function () {
            const key = ($(this).data("sortKey") || "").toString();
            if (!key) return;

            if (state.sortKey === key) {
                state.sortDir = state.sortDir === "asc" ? "desc" : "asc";
            } else {
                state.sortKey = key;
                state.sortDir = key === "created" ? "desc" : "asc";
            }

            state.page = 1;
            render();
        });

        render();
    });
</script>
