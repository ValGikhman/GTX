@model GTX.Models.BaseModel
<head>
    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-L828PN8ET1"></script>
    <script>
        window.dataLayer = window.dataLayer || [];
        function gtag() { dataLayer.push(arguments); }
        gtag('js', new Date());

        gtag('config', 'G-L828PN8ET1');
    </script>
</head>
<style>
    .body-content {
        overflow-y: hidden !important;
    }

    #inventorySplit {
        margin-top: 0 !important;
    }

    .inventory-contact-strip {
        margin: 0;
        padding: .55rem .8rem;
        border: 1px solid rgba(0, 0, 0, .16);
        border-radius: .55rem;
        background: linear-gradient(180deg, #ffffff 0%, #edf2f8 100%);
        display: flex;
        align-items: center;
        justify-content: center;
        gap: .9rem;
        flex-wrap: wrap;
        font-weight: 700;
        color: #1f2937;
    }

    .inventory-contact-address {
        display: inline-flex;
        align-items: center;
        gap: .35rem;
        font-weight: 800;
        color: #1f2937;
        text-decoration: underline;
        text-underline-offset: 2px;
        cursor: pointer;
    }

    .inventory-contact-address.copied {
        color: #0b7a2f;
        text-decoration-color: #0b7a2f;
    }

    .inventory-contact-map-btn {
        white-space: nowrap;
        padding: .25rem .55rem;
        font-size: .85rem;
        line-height: 1.1;
    }

    @@media only screen and (min-width: 768px) and (max-width: 991px) {
        #title {
            margin-left: -160px !important;
        }
    }
</style>



<!-- Scrollable wrapper -->
<script>
    (function () {
        var root = document.documentElement;
        root.classList.add("inventory-page-loading");

        // Failsafe: never keep the page hidden if an init script errors out.
        window.addEventListener("load", function () {
            root.classList.remove("inventory-page-loading");
        }, { once: true });
    })();
</script>
@{
    var inventoryAction = (ViewContext.RouteData.Values["action"] ?? string.Empty).ToString();
    var inventoryRouteType = string.Empty;

    switch (inventoryAction)
    {
        case "Suvs":
            inventoryRouteType = "SUV";
            break;
        case "Sedans":
            inventoryRouteType = "SEDAN";
            break;
        case "Wagons":
            inventoryRouteType = "WAGON";
            break;
        case "Trucks":
            inventoryRouteType = "TRUCK";
            break;
        case "Vans":
            inventoryRouteType = "VAN";
            break;
        case "Convertibles":
            inventoryRouteType = "CONVERTIBLE";
            break;
    }
}
<div class="inventory-contact-strip shadow-sm d-lg-none">
    <span id="inventoryAddressCopy"
          class="inventory-contact-address"
          role="button"
          tabindex="0"
          data-address="9516 Princeton Glendale Rd, West Chester, OH 45011"
          title="Click to copy address">
        <i class="bi bi-geo-alt-fill"></i>9516 Princeton Glendale Rd, West Chester, OH 45011
    </span>
    <a href="https://www.google.com/maps/search/?api=1&query=9516+Princeton+Glendale+Rd%2C+West+Chester+Township%2C+OH+45011" target="_blank" rel="noopener noreferrer" class="btn btn-sm btn-gradient-grey border-dark rounded-3 shadow-sm inventory-contact-map-btn">
        <i class="bi bi-map"></i> <strong> Map </strong>
    </a>
</div>
<div id="inventorySplit" class="inventory-wrapper inventory-split" data-route-type-filter="@inventoryRouteType" data-all-inventory-url="@Url.Action("All", "Inventory")">
    <div id="inventorySidebarPane" class="inventory-sidebar-pane offcanvas offcanvas-top inventory-filter-offcanvas" tabindex="-1" aria-labelledby="inventoryFiltersLabel">
        <div class="offcanvas-header inventory-filter-offcanvas-header d-lg-none">
            <button type="button"
                    id="inventoryClearFilters"
                    class="btn btn-sm btn-gradient-grey border-dark rounded-3 shadow text-black fw-bold inventory-clear-btn inventory-filter-offcanvas-clear-btn"
                    title="Clear filters"
                    aria-label="Clear filters">
                <i class="bi bi-eraser-fill"></i>
                <span>Clear</span>
            </button>
            <div class="inventory-filter-offcanvas-title-wrap">
                <h5 class="offcanvas-title" id="inventoryFiltersLabel">
                    <i class="bi bi-sliders2 me-2"></i>
                    <span id="inventoryMobileFilterCount">0</span>
                    <span>active filter(s)</span>
                </h5>
            </div>
            <button type="button"
                    class="btn btn-sm btn-gradient-grey border-dark rounded-3 shadow text-black fw-bold inventory-clear-btn inventory-filter-offcanvas-close-btn"
                    data-bs-dismiss="offcanvas"
                    aria-label="Close filters">
                <i class="bi bi-x-lg"></i>
                <span>Close</span>
            </button>
        </div>
        <div class="offcanvas-body inventory-filter-offcanvas-body">
            @Html.Partial("_InventoryCheckboxFilters", Model)
        </div>
    </div>

    <div id="inventorySplitDivider" class="inventory-split-divider" role="separator" aria-orientation="vertical" title="Drag to resize filters">
        <button type="button" id="inventorySidebarToggle" class="inventory-sidebar-toggle btn btn-sm btn-gradient-grey border-dark shadow" title="Collapse filters">
            <i class="bi bi-chevron-left"></i>
        </button>
    </div>

    <div class="inventory-results-zone">
        @if (Model.Inventory?.Vehicles.Count() > 0)
        {
            <div class="inventory-mobile-filter-bar d-lg-none">
                <div id="inventoryMobileFilterToggle"
                     class="btn inventory-mobile-filter-btn"
                     role="button"
                     tabindex="0"
                     aria-controls="inventorySidebarPane"
                     aria-label="Open filters">
                    <span class="inventory-mobile-filter-title">
                        <i class="bi bi-sliders2"></i>
                        <span>Filters</span>
                    </span>
                    <span class="inventory-mobile-filter-meta">
                        <span id="inventoryMobileMatchCount">0</span> vehicles
                        <span id="inventoryMobileActiveBadge" class="inventory-mobile-active-badge">0</span>
                    </span>
                    <button type="button"
                            id="inventoryMobileClearFilters"
                            class="btn btn-gradient-grey border-black shadow rounded-4 inventory-mobile-filter-action-btn inventory-mobile-clear-btn"
                            title="Clear filters"
                            aria-label="Clear filters">
                        <i class="bi bi-eraser-fill"></i>
                    </button>
                </div>
            </div>
            @Html.Partial("_FilterByTerm")
        }

        <div class="inventory-empty-filter shadow-sm p-4 mb-3 text-center">
            No vehicles match the selected filters.
        </div>

        <ul id="inventory" class="d-flex flex-wrap justify-content-center gap-3">
            @{
                if (Model.Inventory?.Vehicles != null)
                {
                    var inventoryCardIndex = 0;
                    foreach (var vehicle in Model.Inventory.Vehicles)
                    {
                        @Html.Partial("_Card", vehicle, new ViewDataDictionary(ViewData) { { "InventoryCardIndex", inventoryCardIndex } })
                        inventoryCardIndex++;
                    }
                }
                else
                {
                    <li>
                        <h6 class="well shadow-lg p-3">No vehicles found....</h6>
                    </li>
                }
            }
        </ul>
    </div>
</div>

<script type="text/javascript">
    $(function () {
        $("#filterTerm").removeClass("rounded-end-4");

        function markAddressCopied($address) {
            if (!$address || !$address.length) return;

            $address.addClass("copied");
            $address.attr("title", "Copied to clipboard");
            setTimeout(function () {
                $address.removeClass("copied");
                $address.attr("title", "Click to copy address");
            }, 1200);
        }

        function fallbackCopyAddress(text, $address) {
            const $temp = $("<textarea readonly></textarea>").val(text).css({
                position: "fixed",
                top: "-9999px",
                left: "-9999px"
            });

            $("body").append($temp);
            $temp[0].focus();
            $temp[0].select();

            try {
                document.execCommand("copy");
            } finally {
                $temp.remove();
                markAddressCopied($address);
            }
        }

        function copyAddress(text, $address) {
            if (!text) return;

            if (navigator.clipboard && window.isSecureContext) {
                navigator.clipboard.writeText(text)
                    .then(function () {
                        markAddressCopied($address);
                    })
                    .catch(function () {
                        fallbackCopyAddress(text, $address);
                    });
                return;
            }

            fallbackCopyAddress(text, $address);
        }

        $("#inventoryAddressCopy, #pageTitleInventoryAddressCopy").on("click keydown", function (e) {
            const key = e.key || "";
            const keyCode = e.keyCode || 0;
            const isKeyboardActivate = e.type === "keydown" && (key === "Enter" || key === " " || keyCode === 13 || keyCode === 32);

            if (e.type === "keydown" && !isKeyboardActivate) return;
            if (isKeyboardActivate) e.preventDefault();

            copyAddress($(this).data("address"), $(this));
        });

        const term = sessionStorage.getItem("term");
        if (term === undefined || term === "" || term === null) {
            sessionStorage.removeItem("term");
        }
        else {
            $("#filterTerm").val(term);
            applyFilterTerm(term);
        }

        // For navivation on details page
        let stocks = $(".card:visible").map(function () {
            return $(this).data("stock");
        }).get();

        if (stocks.length > 0) {
            localStorage.setItem("matchedStocks", JSON.stringify(stocks));
            sessionStorage.setItem("lastVisitedPage", window.location.href);
        } else {
            localStorage.removeItem("matchedStocks"); // Clear old if none matched
            sessionStorage.removeItem("lastVisitedPage");

        }

        let detailsNavigationStarted = false;
        $(window).on('pageshow', function (event) {
            detailsNavigationStarted = false;
            if (typeof hideSpinner === "function") {
                hideSpinner("#loadingOverlay");
            }

            loadLastCars();
            loadLikedCars();
            refreshCarLikes();
        });

        $(document).on("visibilitychange", function () {
            if (document.visibilityState === "visible") {
                detailsNavigationStarted = false;
            }
        });

        $("#inventory").on("click", ".card", function () {
            if (detailsNavigationStarted) return;

            const url = $(this).data("url");
            const stock = $(this).data("stock");
            const fallbackUrl = stock ? `${root}Inventory/Details?stock=${encodeURIComponent(stock)}` : "";

            if (url || fallbackUrl) {
                detailsNavigationStarted = true;
                window.location.href = url || fallbackUrl;
            }
        });

        $(".no-click").on("click", function (e) {
            e.stopPropagation();
        });

        refreshCarLikes();

        $('#sortField, #sortDirection').on('change', function () {
            updateSortDirectionLabel();
            sortInventory();
        });

        updateSortDirectionLabel();

        if (window.applyInventoryPanelFilters) {
            window.applyInventoryPanelFilters();
        }
    })

    function refreshCarLikes() {
        $(".card").each(function () {
            var stock = $(this).data("stock");
            if (isCarLiked(stock)) {
                $(this).find(".liked").show();
            }
            else {
                $(this).find(".liked").hide();
            }
        });
    }

    function updateSortDirectionLabel() {
        var isDesc = $('#sortDirection').is(':checked');
        $('#sortDirectionLabel').text(isDesc ? 'Z-a' : 'A-z');
    }

    function sortInventory() {
        var field = $('#sortField').val();
        var desc = $('#sortDirection').is(':checked');
        var $container = $('#inventory');

        if (!field) return; // Do nothing if no field selected

        var $items = $container.find('.card').get();
        var isTextField = (field === 'make');
        var collator = new Intl.Collator(undefined, { sensitivity: 'base', numeric: true });

        $items.sort(function (a, b) {
            var rawA = $(a).data(field);
            var rawB = $(b).data(field);

            if (isTextField) {
                var valA = (rawA == null ? '' : String(rawA));
                var valB = (rawB == null ? '' : String(rawB));
                var cmp = collator.compare(valA, valB);
                return desc ? -cmp : cmp;
            } else {
                // Clean numbers like "$12,345.00" -> 12345.00
                var numA = parseFloat(String(rawA).replace(/[^0-9.\-]/g, '')) || 0;
                var numB = parseFloat(String(rawB).replace(/[^0-9.\-]/g, '')) || 0;
                var cmp = numA - numB;
                return desc ? -cmp : cmp;
            }
        });

        $container.append($items);
    }
</script>
