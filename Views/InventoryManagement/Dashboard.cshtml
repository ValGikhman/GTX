                        @Html.Partial("~/Views/Shared/_FilterByTerm.cshtml", new GTX.Models.BaseModel())
                    </div>
                </div>
                <div class="inventory-dashboard-grid-wrap table-responsive">
                    <table id="inventoryDashboardStatusTable" class="table align-middle m-0">
                        <thead>
                            <tr>
                                <th style="width:52px;" aria-label="Expand"></th>
                                <th style="width:100px;">Image</th>
                                <th style="min-width:220px;" data-dashboard-sort-column="vehicle" aria-sort="none">
                                    <button type="button" class="inventory-dashboard-sort-button" data-dashboard-sort="vehicle">
                                        <span>Vehicle</span>
                                        <i class="bi bi-arrow-down-up" aria-hidden="true"></i>
                                    </button>
                                </th>
                                <th style="width:110px;" class="text-center">Status</th>
                                <th style="width:120px;" class="text-center" data-dashboard-sort-column="location" aria-sort="none">
                                    <button type="button" class="inventory-dashboard-sort-button" data-dashboard-sort="location">
                                        <span>Location</span>
                                        <i class="bi bi-arrow-down-up" aria-hidden="true"></i>
                                    </button>
                                </th>
                                <th style="width:120px;" class="text-end" data-dashboard-sort-column="days" aria-sort="none">
                                    <button type="button" class="inventory-dashboard-sort-button" data-dashboard-sort="days">
                                        <span>Days</span>
                                        <i class="bi bi-arrow-down-up" aria-hidden="true"></i>
                                    </button>
                                </th>
                                <th style="width:88px;" class="text-center">Details</th>
                            </tr>
                        </thead>
                        <tbody id="inventoryDashboardStatusBody"></tbody>
                    </table>
                </div>
                <div id="inventoryDashboardStatusEmpty" class="p-4 text-center text-muted d-none">
                    No vehicles match the selected filter.
                </div>
            </article>
        </div>
    </div>
</section>

