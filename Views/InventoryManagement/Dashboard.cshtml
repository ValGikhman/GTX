@using Newtonsoft.Json
@model System.Collections.Generic.IDictionary<int, Services.InventoryDashboardSummary>

@{
    var dashboards = Model ?? new System.Collections.Generic.Dictionary<int, Services.InventoryDashboardSummary>();
    var dashboardsJson = JsonConvert.SerializeObject(
        dashboards,
        new JsonSerializerSettings { StringEscapeHandling = StringEscapeHandling.EscapeHtml });
}

<style>
    .inventory-dashboard {
