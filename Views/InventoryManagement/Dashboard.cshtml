@using Newtonsoft.Json
@model System.Collections.Generic.IDictionary<int, Services.InventoryDashboardSummary>

@{
    var dashboards = Model ?? new System.Collections.Generic.Dictionary<int, Services.InventoryDashboardSummary>();
    var dashboardsJson = JsonConvert.SerializeObject(
        dashboards,
        new JsonSerializerSettings { StringEscapeHandling = StringEscapeHandling.EscapeHtml });
}

<section class="inventory-dashboard container-fluid">
    <div class="inventory-dashboard-toolbar">
        <div class="inventory-dashboard-toolbar-heading">
            <span class="inventory-dashboard-toolbar-icon" aria-hidden="true">
                <i class="bi bi-speedometer2"></i>
            </span>
            <div class="inventory-dashboard-toolbar-copy">
                <h1 class="inventory-dashboard-heading">Inventory Dashboard</h1>
                <div id="inventoryDashboardRange" class="inventory-dashboard-subtitle"></div>
            </div>
        </div>
    </div>

    <div class="row g-2 inventory-dashboard-layout-row">
        <div class="col-12 inventory-dashboard-graphs-column">
            <div class="inventory-dashboard-graph-grid">
                <div class="inventory-dashboard-period-control d-flex gap-2">
                    <div class="flex-grow-1">
                        <select id="inventoryDashboardPeriod" class="form-select" aria-label="Inventory dashboard period">
                            <option value="7">Last 7 days</option>
                            <option value="30">Last 30 days</option>
                            <option value="60">Last 60 days</option>
                        </select>
                    </div>
                    <button type="button" id="inventoryDashboardClearStatus" class="btn btn-outline-secondary btn-sm shadow-sm rounded-pill d-none align-self-end">
                        <i class="bi bi-x-circle me-1" aria-hidden="true"></i>
                        Clear filters
                    </button>
                </div>
                <article class="inventory-dashboard-card inventory-dashboard-graph-card" aria-labelledby="inventoryDashboardStatusTitle">
                    <div class="inventory-dashboard-card-header">
                        <div>
                            <h3 id="inventoryDashboardStatusTitle" class="inventory-dashboard-title">Inventory By Status</h3>
                        </div>
                        <span class="inventory-dashboard-icon inventory-dashboard-accent-status" aria-hidden="true"><i class="bi bi-pie-chart"></i></span>
                    </div>
                    <div class="inventory-dashboard-location-layout">
                        <div id="inventoryDashboardStatusDonut" class="inventory-dashboard-donut inventory-dashboard-location-donut inventory-dashboard-accent-status">
                            <canvas id="inventoryDashboardStatusCanvas" aria-hidden="true"></canvas>
                            <div class="inventory-dashboard-donut-center">
                                <span id="inventoryDashboardStatusTotal" class="inventory-dashboard-number">0</span>
                                <span id="inventoryDashboardStatusCenterLabel" class="inventory-dashboard-center-label">Vehicles</span>
                            </div>
                        </div>
                        <div id="inventoryDashboardStatusLegend" class="inventory-dashboard-legend"></div>
                    </div>
                </article>

                <article class="inventory-dashboard-card inventory-dashboard-graph-card" aria-labelledby="inventoryDashboardLocationTitle">
                    <div class="inventory-dashboard-card-header">
                        <div>
                            <h3 id="inventoryDashboardLocationTitle" class="inventory-dashboard-title">Inventory By Location Code</h3>
                        </div>
                        <span class="inventory-dashboard-icon inventory-dashboard-accent-location" aria-hidden="true"><i class="bi bi-geo-alt"></i></span>
                    </div>
                    <div class="inventory-dashboard-location-layout">
                        <div id="inventoryDashboardLocationDonut" class="inventory-dashboard-donut inventory-dashboard-location-donut inventory-dashboard-accent-location">
                            <canvas id="inventoryDashboardLocationCanvas" aria-hidden="true"></canvas>
                            <div class="inventory-dashboard-donut-center">
                                <span id="inventoryDashboardLocationTotal" class="inventory-dashboard-number">0</span>
                                <span id="inventoryDashboardLocationCenterLabel" class="inventory-dashboard-center-label">Vehicles</span>
                            </div>
                        </div>
                        <div id="inventoryDashboardLocationLegend" class="inventory-dashboard-legend"></div>
                    </div>
                </article>

                <article class="inventory-dashboard-card inventory-dashboard-graph-card" aria-labelledby="inventoryDashboardTimeTermsTitle">
                    <div class="inventory-dashboard-card-header">
                        <div>
                            <h3 id="inventoryDashboardTimeTermsTitle" class="inventory-dashboard-title">Inventory By Time Terms</h3>
                        </div>
                        <span class="inventory-dashboard-icon inventory-dashboard-accent-trend" aria-hidden="true"><i class="bi bi-clock-history"></i></span>
                    </div>
                    <div class="inventory-dashboard-location-layout">
                        <div id="inventoryDashboardTimeTermsDonut" class="inventory-dashboard-donut inventory-dashboard-location-donut inventory-dashboard-accent-trend">
                            <canvas id="inventoryDashboardTimeTermsCanvas" aria-hidden="true"></canvas>
                            <div class="inventory-dashboard-donut-center">
                                <span id="inventoryDashboardTimeTermsTotal" class="inventory-dashboard-number">0</span>
                                <span id="inventoryDashboardTimeTermsCenterLabel" class="inventory-dashboard-center-label">Vehicles</span>
                            </div>
                        </div>
                        <div id="inventoryDashboardTimeTermsLegend" class="inventory-dashboard-legend"></div>
                    </div>
                </article>

                <article class="inventory-dashboard-card inventory-dashboard-graph-card inventory-dashboard-trend-card" aria-labelledby="inventoryDashboardStatusTrendTitle">
                    <div class="inventory-dashboard-card-header">
                        <div>
                            <h3 id="inventoryDashboardStatusTrendTitle" class="inventory-dashboard-title">Inventory dynamics</h3>
                        </div>
                        <span class="inventory-dashboard-icon inventory-dashboard-accent-trend" aria-hidden="true"><i class="bi bi-graph-up-arrow"></i></span>
                    </div>
                    <div class="inventory-dashboard-trend-panel">
                        <div id="inventoryDashboardStatusTrendChart" class="inventory-dashboard-trend-chart" role="img" aria-label="Inventory dynamics over time"></div>
                    </div>
                </article>
            </div>
        </div>

        <div class="col-12 inventory-dashboard-detail-column">
            <article class="inventory-dashboard-card inventory-dashboard-grid-card inventory-dashboard-grid-shell" aria-labelledby="inventoryDashboardStatusGridTitle">
                <div class="inventory-dashboard-grid-header">
                    <div class="inventory-dashboard-grid-title-wrap">
                        <h2 id="inventoryDashboardStatusGridTitle" class="inventory-dashboard-title">Inventory Detail</h2>
                    </div>
                    <div class="inventory-dashboard-grid-actions">
                        <div id="inventoryDashboardSummary" class="inventory-dashboard-summary shadow-sm" aria-live="polite">
                            <span class="inventory-dashboard-summary-label">Vehicles</span>
                            <span id="inventoryDashboardCount" class="badge bg-secondary shadow">0</span>
                        </div>
                        @Html.Partial("~/Views/Shared/_FilterByTerm.cshtml", new GTX.Models.BaseModel())
                    </div>
                </div>
                <div class="inventory-dashboard-grid-wrap table-responsive">
                    <table id="inventoryDashboardStatusTable" class="table align-middle m-0">
                        <colgroup>
                            <col class="inventory-dashboard-col-expand" />
                            <col class="inventory-dashboard-col-image" />
                            <col class="inventory-dashboard-col-vehicle" />
                            <col class="inventory-dashboard-col-status" />
                            <col class="inventory-dashboard-col-location" />
                            <col class="inventory-dashboard-col-days" />
                            <col class="inventory-dashboard-col-details" />
                        </colgroup>
                        <thead>
                            <tr>
                                <th class="inventory-dashboard-col-expand" aria-label="Expand"></th>
                                <th class="inventory-dashboard-col-image">Image</th>
                                <th class="inventory-dashboard-sortable-th inventory-dashboard-col-vehicle" data-dashboard-sort-column="vehicle" aria-sort="none">Vehicle <i class="bi bi-arrow-down-up inventory-dashboard-sort-indicator" aria-hidden="true"></i></th>
                                <th class="inventory-dashboard-col-status text-center">Status</th>
                                <th class="inventory-dashboard-sortable-th inventory-dashboard-col-location text-center" data-dashboard-sort-column="location" aria-sort="none">Location <i class="bi bi-arrow-down-up inventory-dashboard-sort-indicator" aria-hidden="true"></i></th>
                                <th class="inventory-dashboard-sortable-th inventory-dashboard-col-days text-end" data-dashboard-sort-column="days" aria-sort="none">Days <i class="bi bi-arrow-down-up inventory-dashboard-sort-indicator" aria-hidden="true"></i></th>
                                <th class="inventory-dashboard-col-details text-center">Details</th>
                            </tr>
                        </thead>
                        <tbody id="inventoryDashboardStatusBody"></tbody>
                    </table>
                </div>
                <div id="inventoryDashboardStatusEmpty" class="p-4 text-center text-muted d-none">
                    No vehicles match the selected filter.
                </div>
            </article>
        </div>
    </div>
</section>

@Html.Partial("~/Views/InventoryManagement/_DashboardVehicleDetailsModal.cshtml")

<script type="application/json" id="inventoryDashboardData">@Html.Raw(dashboardsJson)</script>
<script src="~/Scripts/majordome.js?v=@(System.IO.File.GetLastWriteTimeUtc(Server.MapPath("~/Scripts/majordome.js")).Ticks)"></script>
<script src="~/Scripts/inventory-history.js?v=@(System.IO.File.GetLastWriteTimeUtc(Server.MapPath("~/Scripts/inventory-history.js")).Ticks)"></script>
@Html.Partial("~/Views/Majordome/_Majordome-VehicleCellsScript.cshtml")

@section scripts {
    <script src="~/Scripts/chartjs/chart.umd.min.js?v=@(System.IO.File.GetLastWriteTimeUtc(Server.MapPath("~/Scripts/chartjs/chart.umd.min.js")).Ticks)"></script>
    <script>
        (function ($) {
            function readDashboardData() {
                const dashboardDataNode = document.getElementById("inventoryDashboardData");
                if (!dashboardDataNode) return {};

                try {
                    return JSON.parse(dashboardDataNode.textContent || "{}");
                } catch (error) {
                    return {};
                }
            }

            const dashboards = readDashboardData();
            let dashboardRequest = null;
            let currentDashboardDays = "7";
            let activeStatusCode = null;
            let activeLocationCode = null;
            let activeTimeTermKey = null;
            let activeTrendDateKey = null;
            let activeDashboardSearchText = "";
            let activeGridSortKey = null;
            let activeGridSortDirection = "asc";
            let dashboardStatusChart = null;
            let dashboardLocationChart = null;
            let dashboardTimeTermsChart = null;
            let dashboardStatusTrendChart = null;
            const dashboardHistoryCache = {};
            const dashboardHistoryRequests = {};
            const expandedDashboardStocks = {};
            const skippedStatusCode = 0;
            const addedStatusCode = 1;
            const removedStatusCode = 2;
            const updatedStatusCode = 3;
            const stalledTrendStatusCode = skippedStatusCode + addedStatusCode + updatedStatusCode;
            const locationColors = [
                "#0d6efd",
                "#198754",
                "#fd7e14",
                "#6f42c1",
                "#20c997",
                "#dc3545",
                "#0dcaf0",
                "#6c757d",
                "#b7791f",
                "#d63384"
            ];
            const statusColors = {
                "Added": "#198754",
                "Existing": "#6c757d",
                "Skipped": "#6c757d",
                "Stalled": "#6c757d",
                "Sold": "#dc3545",
                "Removed": "#dc3545",
                "Updated": "#0d6efd"
            };
            const locationBadgeColors = {
                "is-gtx-x": "#1d4ed8",
                "is-gtx-t": "#b91c1c",
                "is-gtx-g": "#198754"
            };
            const timeTerms = [
                { key: "under-90", label: "Under 90 days", min: 0, max: 89, color: "#198754" },
                { key: "90-181", label: "90-181 days", min: 90, max: 181, color: "#0d6efd" },
                { key: "182-364", label: "182-364 days", min: 182, max: 364, color: "#fd7e14" },
                { key: "365-plus", label: "365+ days", min: 365, max: null, color: "#dc3545" }
            ];

            function valueOf(source, name, fallback) {
                if (!source) return fallback;
                if (source[name] !== undefined && source[name] !== null) return source[name];
                const camel = name.charAt(0).toLowerCase() + name.slice(1);
                return source[camel] !== undefined && source[camel] !== null ? source[camel] : fallback;
            }

            function escapeDashboardHtml(value) {
                return (value == null ? "" : value.toString())
                    .replace(/&/g, "&amp;")
                    .replace(/</g, "&lt;")
                    .replace(/>/g, "&gt;")
                    .replace(/"/g, "&quot;")
                    .replace(/'/g, "&#39;");
            }

            function statusLabel(value) {
                const label = (value || "Status").toString().trim();
                const normalized = label.toLowerCase();
                if (normalized === "skip" || normalized === "skipped" || normalized === "stall" || normalized === "stalled" || normalized === "existing") {
                    return "Stalled";
                }
                if (normalized === "remove" || normalized === "removed") {
                    return "Sold";
                }
                return label || "Status";
            }

            function statusColor(status, index) {
                const label = statusLabel(valueOf(status, "StatusText", "Status"));
                return statusColors[label] || locationColors[index % locationColors.length];
            }

            function normalizeStatusCode(value) {
                const number = parseInt(value, 10);
                return Number.isFinite(number) ? number : null;
            }

            function getStatusCode(status) {
                return normalizeStatusCode(valueOf(status, "Status", null));
            }

            function normalizeLocationFilterCode(value) {
                const normalized = (value || "").toString().trim().toUpperCase();
                return normalized || "N/A";
            }

            function normalizeStockKey(value) {
                return (value || "").toString().trim().toUpperCase();
            }

            function locationBadgeInfo(value, fallbackIndex) {
                const label = (value || "").toString().trim();
                const normalized = label.toUpperCase();
                let toneClass = "";

                if (normalized.startsWith("X")) {
                    toneClass = "is-gtx-x";
                } else if (normalized.startsWith("T")) {
                    toneClass = "is-gtx-t";
                } else if (normalized.startsWith("G")) {
                    toneClass = "is-gtx-g";
                }

                return {
                    label: label || "N/A",
                    toneClass: toneClass,
                    color: locationBadgeColors[toneClass] || locationColors[fallbackIndex % locationColors.length]
                };
            }

            function dashboardRoot() {
                return typeof root !== "undefined" ? root : "/";
            }

            function asNumber(value) {
                const number = parseInt(value, 10);
                return Number.isFinite(number) ? number : 0;
            }

            function formatNumber(value) {
                return new Intl.NumberFormat(undefined, { maximumFractionDigits: 0 }).format(asNumber(value));
            }

            function dashboardChartsAvailable() {
                return typeof window.Chart === "function";
            }

            function destroyDashboardChart(chart) {
                if (chart && typeof chart.destroy === "function") {
                    chart.destroy();
                }
                return null;
            }

            function dashboardChartFont(size, weight) {
                return {
                    family: window.getComputedStyle(document.body).fontFamily,
                    size: size,
                    weight: weight || "600"
                };
            }

            function dashboardChartSameKey(left, right) {
                if (left === null || left === undefined || right === null || right === undefined) return false;
                return left.toString() === right.toString();
            }

            function ensureDashboardCanvas(containerSelector, canvasId) {
                const $container = $(containerSelector);
                let canvas = document.getElementById(canvasId);

                if (!canvas || !$container[0] || !$.contains($container[0], canvas)) {
                    $container.children("canvas").remove();
                    canvas = document.createElement("canvas");
                    canvas.id = canvasId;
                    canvas.setAttribute("aria-hidden", "true");
                    $container.prepend(canvas);
                }

                return canvas;
            }

            function renderDashboardDoughnutChart(chart, containerSelector, canvasId, labels, values, colors, keys, activeKey, onSelect, fallbackBackground) {
                chart = destroyDashboardChart(chart);
                const $container = $(containerSelector);
                const canvas = ensureDashboardCanvas(containerSelector, canvasId);
                const numericValues = values.map(asNumber);
                const hasData = numericValues.some(function (value) {
                    return value > 0;
                });
                const chartLabels = hasData ? labels : ["No data"];
                const chartValues = hasData ? numericValues : [1];
                const chartColors = hasData ? colors : ["#e9eef5"];
                const chartKeys = hasData ? keys : [null];

                if (!dashboardChartsAvailable()) {
                    $container.css("background", fallbackBackground || "#e9eef5");
                    return null;
                }

                $container.css("background", "transparent");

                return new window.Chart(canvas.getContext("2d"), {
                    type: "doughnut",
                    data: {
                        labels: chartLabels,
                        datasets: [{
                            data: chartValues,
                            backgroundColor: chartColors,
                            borderColor: "#fff",
                            borderWidth: 2,
                            hoverOffset: hasData ? 5 : 0,
                            offset: chartKeys.map(function (key) {
                                return dashboardChartSameKey(key, activeKey) ? 8 : 0;
                            })
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        cutout: "68%",
                        animation: false,
                        plugins: {
                            legend: { display: false },
                            tooltip: {
                                enabled: hasData,
                                callbacks: {
                                    label: function (context) {
                                        return `${context.label}: ${formatNumber(context.parsed)}`;
                                    }
                                }
                            }
                        },
                        onClick: function (event, elements) {
                            if (!hasData || !elements.length || typeof onSelect !== "function") return;
                            const selectedKey = chartKeys[elements[0].index];
                            if (selectedKey !== null && selectedKey !== undefined) {
                                onSelect(selectedKey);
                            }
                        }
                    }
                });
            }

            function formatDate(value) {
                if (!value) return "";
                const msJsonDate = /^\/Date\((-?\d+)(?:[+-]\d+)?\)\/$/.exec(value.toString());
                const date = msJsonDate ? new Date(parseInt(msJsonDate[1], 10)) : new Date(value);
                if (Number.isNaN(date.getTime())) return "";
                return date.toLocaleDateString(undefined, { month: "short", day: "numeric", year: "numeric" });
            }

            function formatDateTime(value) {
                if (!value) return "";
                const msJsonDate = /^\/Date\((-?\d+)(?:[+-]\d+)?\)\/$/.exec(value.toString());
                const date = msJsonDate ? new Date(parseInt(msJsonDate[1], 10)) : new Date(value);
                if (Number.isNaN(date.getTime())) return "";
                return date.toLocaleString(undefined, {
                    month: "short",
                    day: "numeric",
                    year: "numeric",
                    hour: "numeric",
                    minute: "2-digit"
                });
            }

            function dashboardText(value) {
                if (value === null || value === undefined) return "";
                return value.toString();
            }

            function normalizeDashboardSearchText(value) {
                if (window.gtxInventorySearch) {
                    return window.gtxInventorySearch.normalize(value);
                }

                return dashboardText(value).trim().replace(/\s+/g, " ").toLowerCase();
            }

            function parseDashboardDate(value) {
                if (!value) return null;
                const text = value.toString();
                const msJsonDate = /^\/Date\((-?\d+)(?:[+-]\d+)?\)\/$/.exec(text);
                const isoDate = /^(\d{4})-(\d{2})-(\d{2})$/.exec(text);
                const date = msJsonDate
                    ? new Date(parseInt(msJsonDate[1], 10))
                    : (isoDate
                        ? new Date(parseInt(isoDate[1], 10), parseInt(isoDate[2], 10) - 1, parseInt(isoDate[3], 10))
                        : new Date(value));
                return Number.isNaN(date.getTime()) ? null : date;
            }

            function formatDashboardShortDate(value) {
                const date = parseDashboardDate(value);
                if (!date) return dashboardText(value);
                const month = date.getMonth() + 1;
                const day = date.getDate();
                return `${month < 10 ? `0${month}` : month}/${day < 10 ? `0${day}` : day}/${date.getFullYear()}`;
            }

            function formatDashboardInteger(value, useGrouping) {
                const text = dashboardText(value).trim();
                if (!text) return "";

                const numeric = Number(text.replace(/[$,\s]/g, ""));
                if (!Number.isFinite(numeric)) return text;

                return new Intl.NumberFormat(undefined, {
                    maximumFractionDigits: 0,
                    useGrouping: useGrouping !== false
                }).format(numeric);
            }

            function formatDashboardCurrency(value) {
                const text = dashboardText(value).trim();
                if (!text) return "";

                const numeric = Number(text.replace(/[$,\s]/g, ""));
                if (!Number.isFinite(numeric)) return text;

                return new Intl.NumberFormat(undefined, {
                    style: "currency",
                    currency: "USD",
                    maximumFractionDigits: 0
                }).format(numeric);
            }

            function formatDashboardChangeValue(field, value) {
                const fieldName = dashboardText(field);

                if (fieldName === "Retail price" || fieldName === "Internet price") {
                    return formatDashboardCurrency(value);
                }

                if (fieldName === "Mileage" || fieldName === "Weight") {
                    return formatDashboardInteger(value);
                }

                if (fieldName === "Year" || fieldName === "Cylinders" || fieldName === "Transmission speed") {
                    return formatDashboardInteger(value, false);
                }

                if (fieldName === "Purchase date" || fieldName === "Arrival date") {
                    return formatDashboardShortDate(value);
                }

                return dashboardText(value);
            }

            function isDashboardNumericChangeValue(field, value) {
                const fieldName = dashboardText(field);

                if (fieldName === "Retail price" || fieldName === "Internet price" ||
                    fieldName === "Mileage" || fieldName === "Weight" ||
                    fieldName === "Year" || fieldName === "Cylinders" || fieldName === "Transmission speed") {
                    return true;
                }

                return /^-?\$?\s*\d[\d,\s]*(?:\.\d+)?$/.test(dashboardText(value).trim());
            }

            function dashboardFor(days) {
                return dashboards[String(days)] || dashboards[days] || {};
            }

            function cacheDashboard(days, data) {
                if (!data) return;
                dashboards[String(days)] = data;
            }

            function setDashboardBusy(isBusy) {
                $("#inventoryDashboardPeriod").prop("disabled", isBusy);
                $(".inventory-dashboard-card").toggleClass("opacity-75", isBusy);
                $(".inventory-dashboard-grid-shell").toggleClass("opacity-75", isBusy);
            }

            function locationGradient(locations, total) {
                if (!locations.length || total <= 0) {
                    return "conic-gradient(#e9eef5 0deg 360deg)";
                }

                let cursor = 0;
                const segments = locations.map(function (location, index) {
                    const count = asNumber(valueOf(location, "VehicleCount", 0));
                    const end = index === locations.length - 1 ? 360 : cursor + (count / total * 360);
                    const color = locationBadgeInfo(valueOf(location, "LocationCode", "N/A"), index).color;
                    const segment = `${color} ${cursor.toFixed(2)}deg ${end.toFixed(2)}deg`;
                    cursor = end;
                    return segment;
                });

                return `conic-gradient(${segments.join(", ")})`;
            }

            function statusGradient(statuses, total) {
                if (!statuses.length || total <= 0) {
                    return "conic-gradient(#e9eef5 0deg 360deg)";
                }

                let cursor = 0;
                const segments = statuses.map(function (status, index) {
                    const count = asNumber(valueOf(status, "VehicleCount", 0));
                    const end = index === statuses.length - 1 ? 360 : cursor + (count / total * 360);
                    const color = statusColor(status, index);
                    const segment = `${color} ${cursor.toFixed(2)}deg ${end.toFixed(2)}deg`;
                    cursor = end;
                    return segment;
                });

                return `conic-gradient(${segments.join(", ")})`;
            }

            function getDashboardStatuses(data) {
                const statuses = getDashboardCurrentStatuses(data).slice();
                const removedStatus = getDashboardRemovedStatus(data);
                if (removedStatus) {
                    statuses.push(removedStatus);
                }
                return statuses;
            }

            function getDashboardRawStatuses(data) {
                return valueOf(data, "StatusCounts", []) || [];
            }

            function getDashboardCurrentStatuses(data) {
                return getDashboardRawStatuses(data).filter(function (status) {
                    return getStatusCode(status) !== removedStatusCode;
                });
            }

            function getDashboardRemovedStatus(data) {
                const rawRemovedStatus = getDashboardRawStatuses(data).find(function (status) {
                    return getStatusCode(status) === removedStatusCode;
                });
                const removedCount = rawRemovedStatus
                    ? asNumber(valueOf(rawRemovedStatus, "VehicleCount", 0))
                    : asNumber(valueOf(data, "RemovedCount", 0));

                if (removedCount <= 0) {
                    return null;
                }

                return rawRemovedStatus || {
                    Status: removedStatusCode,
                    StatusText: "Sold",
                    VehicleCount: removedCount
                };
            }

            function getDashboardVehicles(data) {
                return valueOf(data, "Vehicles", []) || [];
            }

            function getDashboardStatusTrend(data) {
                return valueOf(data, "StatusTrend", []) || [];
            }

            function dashboardDayKey(date) {
                if (!date) return "";
                const year = date.getFullYear();
                const month = date.getMonth() + 1;
                const day = date.getDate();
                return `${year}-${month < 10 ? `0${month}` : month}-${day < 10 ? `0${day}` : day}`;
            }

            function dashboardTrendPointDayKey(point) {
                const dateKey = dashboardText(valueOf(point, "DateKey", "")).trim();
                if (dateKey) return dateKey;

                const pointDate = parseDashboardDate(valueOf(point, "DateUtc", ""));
                return dashboardDayKey(pointDate);
            }

            function isActiveDashboardTrendBar(statusCode, dateKey) {
                return activeTrendDateKey !== null &&
                    activeStatusCode === normalizeStatusCode(statusCode) &&
                    activeTrendDateKey === dashboardText(dateKey).trim();
            }

            function getDashboardTrendDays(data) {
                const dashboardDays = asNumber(valueOf(data, "Days", currentDashboardDays)) || asNumber(currentDashboardDays) || 7;
                const periodEnd = parseDashboardDate(valueOf(data, "PeriodEndUtc", "")) || new Date();
                const periodStart = parseDashboardDate(valueOf(data, "PeriodStartUtc", ""));
                const end = new Date(periodEnd.getFullYear(), periodEnd.getMonth(), periodEnd.getDate());
                const start = periodStart
                    ? new Date(periodStart.getFullYear(), periodStart.getMonth(), periodStart.getDate())
                    : new Date(end);

                if (!periodStart) {
                    start.setDate(end.getDate() - Math.max(1, dashboardDays) + 1);
                }

                const days = [];
                for (let cursor = new Date(start); cursor <= end; cursor.setDate(cursor.getDate() + 1)) {
                    days.push(new Date(cursor));
                }
                return days;
            }

            function formatDashboardTrendDate(value) {
                const date = parseDashboardDate(value);
                if (!date) return dashboardText(value);
                return date.toLocaleDateString(undefined, { month: "short", day: "numeric" });
            }

            function dashboardStatusLabelFromCode(statusCode, data) {
                const normalized = normalizeStatusCode(statusCode);
                if (normalized === stalledTrendStatusCode) return "Stalled";

                const status = getDashboardStatuses(data)
                    .concat(getDashboardStatusTrend(data))
                    .find(function (candidate) {
                        return getStatusCode(candidate) === normalized;
                    });
                if (status) {
                    return statusLabel(valueOf(status, "StatusText", "Status"));
                }
                if (normalized === addedStatusCode) return "Added";
                if (normalized === updatedStatusCode) return "Updated";
                if (normalized === removedStatusCode) return "Sold";
                return "Stalled";
            }

            function dashboardStatusTrendSort(statusCode) {
                const normalized = normalizeStatusCode(statusCode);
                if (normalized === addedStatusCode) return 0;
                if (normalized === removedStatusCode) return 1;
                if (normalized === stalledTrendStatusCode) return 2;
                if (normalized === updatedStatusCode) return 3;
                return 4;
            }

            function dashboardStatusTrendColor(statusCode, data, index) {
                return statusColor({
                    Status: statusCode,
                    StatusText: dashboardStatusLabelFromCode(statusCode, data)
                }, index);
            }

            function isDashboardTrendStatus(statusCode) {
                const normalized = normalizeStatusCode(statusCode);
                return normalized === addedStatusCode ||
                    normalized === stalledTrendStatusCode ||
                    normalized === removedStatusCode;
            }

            function isDefaultDashboardTrendStatus(statusCode) {
                const normalized = normalizeStatusCode(statusCode);
                return normalized === addedStatusCode || normalized === removedStatusCode;
            }

            function dashboardTrendSeriesStatusCode(statusCode) {
                const normalized = normalizeStatusCode(statusCode);
                return normalized === skippedStatusCode ? stalledTrendStatusCode : normalized;
            }

            function isDashboardStalledTrendEventStatus(statusCode) {
                const normalized = normalizeStatusCode(statusCode);
                return normalized === skippedStatusCode ||
                    normalized === addedStatusCode ||
                    normalized === updatedStatusCode;
            }

            function isDashboardStalledTrendSeries(statusCode) {
                return normalizeStatusCode(statusCode) === stalledTrendStatusCode;
            }

            function buildDashboardStatusTrendSeries(data, days) {
                const trend = getDashboardStatusTrend(data);
                const dayIndexes = {};
                const activeTrendStatusCode = dashboardTrendSeriesStatusCode(activeStatusCode);
                days.forEach(function (day, index) {
                    dayIndexes[dashboardDayKey(day)] = index;
                });

                const filteredTrend = trend.filter(function (point) {
                    const statusCode = getStatusCode(point);
                    if (!isDashboardTrendStatus(statusCode)) {
                        return false;
                    }
                    if (activeTrendStatusCode !== null && statusCode !== activeTrendStatusCode) {
                        return false;
                    }
                    if (activeLocationCode !== null &&
                        normalizeLocationFilterCode(valueOf(point, "LocationCode", "N/A")) !== activeLocationCode) {
                        return false;
                    }
                    return dayIndexes[dashboardTrendPointDayKey(point)] !== undefined;
                });

                const statusCodes = activeTrendStatusCode !== null && isDashboardTrendStatus(activeTrendStatusCode)
                    ? [activeTrendStatusCode]
                    : (activeStatusCode !== null ? [] : filteredTrend
                        .map(getStatusCode)
                        .filter(function (statusCode, index, source) {
                            return isDefaultDashboardTrendStatus(statusCode) && source.indexOf(statusCode) === index;
                        })
                        .sort(function (left, right) {
                            return dashboardStatusTrendSort(left) - dashboardStatusTrendSort(right);
                        }));

                return statusCodes.map(function (statusCode, index) {
                    const values = days.map(function () { return 0; });
                    filteredTrend.forEach(function (point) {
                        if (getStatusCode(point) !== statusCode) return;
                        const dayIndex = dayIndexes[dashboardTrendPointDayKey(point)];
                        if (dayIndex === undefined) return;
                        values[dayIndex] += asNumber(valueOf(point, "VehicleCount", 0));
                    });

                    return {
                        statusCode: statusCode,
                        label: dashboardStatusLabelFromCode(statusCode, data),
                        color: dashboardStatusTrendColor(statusCode, data, index),
                        dateKeys: days.map(dashboardDayKey),
                        values: values,
                        total: values.reduce(function (sum, value) { return sum + value; }, 0)
                    };
                });
            }

            function renderDashboardStatusTrendChart(days, series) {
                dashboardStatusTrendChart = destroyDashboardChart(dashboardStatusTrendChart);

                if (!dashboardChartsAvailable()) {
                    return false;
                }

                const $chart = $("#inventoryDashboardStatusTrendChart").empty();
                const canvas = document.createElement("canvas");
                canvas.id = "inventoryDashboardStatusTrendCanvas";
                canvas.setAttribute("aria-hidden", "true");
                $chart.append(canvas);

                dashboardStatusTrendChart = new window.Chart(canvas.getContext("2d"), {
                    type: "bar",
                    data: {
                        labels: days.map(formatDashboardTrendDate),
                        datasets: series.map(function (item) {
                            if (isDashboardStalledTrendSeries(item.statusCode)) {
                                return {
                                    type: "line",
                                    label: item.label,
                                    data: item.values,
                                    dateKeys: item.dateKeys,
                                    borderColor: item.color,
                                    backgroundColor: "transparent",
                                    borderWidth: 3,
                                    tension: .28,
                                    fill: false,
                                    pointBackgroundColor: item.values.map(function (value, index) {
                                        return isActiveDashboardTrendBar(item.statusCode, item.dateKeys[index]) ? "#0f172a" : item.color;
                                    }),
                                    pointBorderColor: "#fff",
                                    pointBorderWidth: 2,
                                    pointRadius: item.values.map(function (value) {
                                        return asNumber(value) > 0 ? 4 : 0;
                                    }),
                                    pointHoverRadius: item.values.map(function (value) {
                                        return asNumber(value) > 0 ? 5 : 0;
                                    }),
                                    statusCode: item.statusCode
                                };
                            }

                            return {
                                label: item.label,
                                data: item.values,
                                dateKeys: item.dateKeys,
                                borderColor: item.values.map(function (value, index) {
                                    return isActiveDashboardTrendBar(item.statusCode, item.dateKeys[index]) ? "#0f172a" : item.color;
                                }),
                                backgroundColor: item.values.map(function () {
                                    return item.color;
                                }),
                                borderWidth: item.values.map(function (value, index) {
                                    return isActiveDashboardTrendBar(item.statusCode, item.dateKeys[index]) ? 2 : 1;
                                }),
                                borderSkipped: false,
                                borderRadius: 5,
                                maxBarThickness: 52,
                                categoryPercentage: .92,
                                barPercentage: .95,
                                statusCode: item.statusCode
                            };
                        })
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        animation: false,
                        onClick: function (event, elements) {
                            if (!elements || !elements.length) return;

                            const element = elements[0];
                            const dataset = series[element.datasetIndex];
                            if (!dataset) return;

                            const value = dataset.values[element.index];
                            if (asNumber(value) <= 0) return;

                            setActiveTrendFilter(dataset.statusCode, dataset.dateKeys[element.index]);
                        },
                        onHover: function (event, elements) {
                            const target = event && event.native ? event.native.target : null;
                            if (target) {
                                target.style.cursor = elements && elements.length ? "pointer" : "default";
                            }
                        },
                        interaction: {
                            mode: "nearest",
                            intersect: true
                        },
                        plugins: {
                            legend: { display: false },
                            tooltip: {
                                callbacks: {
                                    title: function (items) {
                                        return items && items.length ? items[0].label : "";
                                    },
                                    label: function (context) {
                                        return `${context.dataset.label}: ${formatNumber(context.parsed.y)}`;
                                    }
                                }
                            }
                        },
                        scales: {
                            x: {
                                grid: { color: "rgba(148, 163, 184, .18)" },
                                stacked: false,
                                ticks: {
                                    color: "#64748b",
                                    font: dashboardChartFont(11, "700"),
                                    maxRotation: 0,
                                    autoSkip: true,
                                    maxTicksLimit: 6
                                }
                            },
                            y: {
                                beginAtZero: true,
                                stacked: false,
                                grid: { color: "rgba(148, 163, 184, .24)" },
                                ticks: {
                                    color: "#64748b",
                                    precision: 0,
                                    font: dashboardChartFont(11, "700"),
                                    callback: function (value) {
                                        return formatNumber(value);
                                    }
                                }
                            }
                        }
                    }
                });

                return true;
            }

            function updateDashboardSummary(filteredCount, totalCount) {
                const filteredText = formatNumber(filteredCount);
                const totalText = formatNumber(totalCount);
                const countText = asNumber(filteredCount) === asNumber(totalCount) ? filteredText : `${filteredText} / ${totalText}`;
                let summaryLabel = "Vehicles";

                if (activeTrendDateKey !== null && activeStatusCode !== null) {
                    summaryLabel = `${dashboardStatusLabelFromCode(activeStatusCode, dashboardFor(currentDashboardDays))} ${formatDashboardTrendDate(activeTrendDateKey)}`;
                }

                $("#inventoryDashboardSummary .inventory-dashboard-summary-label").text(summaryLabel);
                $("#inventoryDashboardCount").text(countText);
            }

            function renderStatusTrend(data) {
                const days = getDashboardTrendDays(data);
                const series = buildDashboardStatusTrendSeries(data, days);
                const hasActivity = series.some(function (item) {
                    return item.total > 0;
                });

                if (!days.length || !series.length || !hasActivity) {
                    dashboardStatusTrendChart = destroyDashboardChart(dashboardStatusTrendChart);
                    $("#inventoryDashboardStatusTrendChart").html(
                        `<div class="inventory-dashboard-trend-empty">No status activity for this filter.</div>`);
                    return;
                }

                if (renderDashboardStatusTrendChart(days, series)) {
                    return;
                }

                const width = 640;
                const height = 220;
                const padding = { top: 18, right: 18, bottom: 40, left: 46 };
                const plotWidth = width - padding.left - padding.right;
                const plotHeight = height - padding.top - padding.bottom;
                const maxValue = Math.max.apply(null, series.reduce(function (values, item) {
                    return values.concat(item.values);
                }, [1]));
                const yTicks = [maxValue, Math.round(maxValue / 2), 0]
                    .filter(function (value, index, source) {
                        return source.indexOf(value) === index;
                    });
                const xLabelIndexes = [0, Math.floor((days.length - 1) / 2), days.length - 1]
                    .filter(function (value, index, source) {
                        return value >= 0 && source.indexOf(value) === index;
                    });
                const groupWidth = plotWidth / Math.max(days.length, 1);
                const barGap = Math.max(1, groupWidth * .015);
                const barGroupWidth = Math.max(4, groupWidth * .9);
                const barWidth = Math.max(2, (barGroupWidth - (Math.max(series.length - 1, 0) * barGap)) / Math.max(series.length, 1));
                const usedBarWidth = (barWidth * series.length) + (barGap * Math.max(series.length - 1, 0));
                const xForIndex = function (index) {
                    return padding.left + (groupWidth * index) + (groupWidth / 2);
                };
                const xForBar = function (dayIndex, seriesIndex) {
                    return padding.left +
                        (groupWidth * dayIndex) +
                        ((groupWidth - usedBarWidth) / 2) +
                        ((barWidth + barGap) * seriesIndex);
                };
                const yForValue = function (value) {
                    return padding.top + ((maxValue - value) / maxValue * plotHeight);
                };
                const baseline = height - padding.bottom;

                const gridHtml = yTicks.map(function (tick) {
                    const y = yForValue(tick);
                    return `
                        <line class="inventory-dashboard-trend-grid" x1="${padding.left}" y1="${y.toFixed(2)}" x2="${(width - padding.right).toFixed(2)}" y2="${y.toFixed(2)}"></line>
                        <text class="inventory-dashboard-trend-label" x="${(padding.left - 10).toFixed(2)}" y="${(y + 4).toFixed(2)}" text-anchor="end">${escapeDashboardHtml(formatNumber(tick))}</text>`;
                }).join("");
                const xLabelsHtml = xLabelIndexes.map(function (index) {
                    const x = xForIndex(index);
                    return `<text class="inventory-dashboard-trend-label" x="${x.toFixed(2)}" y="${height - 12}" text-anchor="middle">${escapeDashboardHtml(formatDashboardTrendDate(days[index]))}</text>`;
                }).join("");
                const seriesHtml = series.map(function (item, seriesIndex) {
                    if (isDashboardStalledTrendSeries(item.statusCode)) {
                        const points = item.values.map(function (value, index) {
                            return `${xForIndex(index).toFixed(2)},${yForValue(value).toFixed(2)}`;
                        }).join(" ");
                        const circles = item.values.map(function (value, index) {
                            if (asNumber(value) <= 0) return "";

                            const dateKey = item.dateKeys[index];
                            const isActive = isActiveDashboardTrendBar(item.statusCode, dateKey);
                            const label = `${item.label} ${formatNumber(value)} on ${formatDashboardTrendDate(days[index])}`;

                            return `
                                <circle class="inventory-dashboard-trend-bar ${isActive ? "is-active" : ""}"
                                        cx="${xForIndex(index).toFixed(2)}"
                                        cy="${yForValue(value).toFixed(2)}"
                                        r="4.25"
                                        fill="${escapeDashboardHtml(item.color)}"
                                        stroke="#fff"
                                        stroke-width="2"
                                        role="button"
                                        tabindex="0"
                                        aria-label="${escapeDashboardHtml(label)}"
                                        data-dashboard-trend-status="${escapeDashboardHtml(item.statusCode)}"
                                        data-dashboard-trend-date="${escapeDashboardHtml(dateKey)}"
                                        data-dashboard-trend-value="${escapeDashboardHtml(value)}">
                                    <title>${escapeDashboardHtml(label)}</title>
                                </circle>`;
                        }).join("");

                        return `
                            <polyline points="${points}"
                                      fill="none"
                                      stroke="${escapeDashboardHtml(item.color)}"
                                      stroke-width="3"
                                      stroke-linecap="round"
                                      stroke-linejoin="round"
                                      opacity=".9"></polyline>
                            ${circles}`;
                    }

                    return item.values.map(function (value, index) {
                        if (asNumber(value) <= 0) return "";

                        const dateKey = item.dateKeys[index];
                        const y = yForValue(value);
                        const barHeight = Math.max(1, baseline - y);
                        const isActive = isActiveDashboardTrendBar(item.statusCode, dateKey);
                        const label = `${item.label} ${formatNumber(value)} on ${formatDashboardTrendDate(days[index])}`;

                        return `
                            <rect class="inventory-dashboard-trend-bar ${isActive ? "is-active" : ""}"
                                  x="${xForBar(index, seriesIndex).toFixed(2)}"
                                  y="${y.toFixed(2)}"
                                  width="${barWidth.toFixed(2)}"
                                  height="${barHeight.toFixed(2)}"
                                  rx="4"
                                  fill="${escapeDashboardHtml(item.color)}"
                                  role="button"
                                  tabindex="0"
                                  aria-label="${escapeDashboardHtml(label)}"
                                  data-dashboard-trend-status="${escapeDashboardHtml(item.statusCode)}"
                                  data-dashboard-trend-date="${escapeDashboardHtml(dateKey)}"
                                  data-dashboard-trend-value="${escapeDashboardHtml(value)}">
                                <title>${escapeDashboardHtml(label)}</title>
                            </rect>`;
                    }).join("");
                }).join("");
                const chartHtml = `
                    <svg viewBox="0 0 ${width} ${height}" preserveAspectRatio="none" aria-label="Inventory dynamics over time" focusable="false">
                        ${gridHtml}
                        <line class="inventory-dashboard-trend-axis" x1="${padding.left}" y1="${padding.top}" x2="${padding.left}" y2="${height - padding.bottom}"></line>
                        <line class="inventory-dashboard-trend-axis" x1="${padding.left}" y1="${height - padding.bottom}" x2="${width - padding.right}" y2="${height - padding.bottom}"></line>
                        ${seriesHtml}
                        ${xLabelsHtml}
                    </svg>`;
                if (window.gtxSecurity && typeof window.gtxSecurity.setSafeHtml === "function") {
                    window.gtxSecurity.setSafeHtml($("#inventoryDashboardStatusTrendChart"), chartHtml);
                } else {
                    $("#inventoryDashboardStatusTrendChart").html(chartHtml);
                }
            }

            function statusExists(statuses, statusCode) {
                if (statusCode === null) return true;
                return statuses.some(function (status) {
                    return getStatusCode(status) === statusCode;
                });
            }

            function clearMissingStatusFilter(statuses) {
                if (activeTrendDateKey !== null && isDashboardTrendStatus(activeStatusCode)) {
                    return;
                }

                if (!statusExists(statuses, activeStatusCode)) {
                    activeStatusCode = null;
                    activeTrendDateKey = null;
                }
            }

            function locationExists(locations, locationCode) {
                if (activeLocationCode === null) return true;
                return locations.some(function (location) {
                    return normalizeLocationFilterCode(valueOf(location, "LocationCode", "N/A")) === locationCode;
                });
            }

            function clearMissingLocationFilter(locations) {
                if (!locationExists(locations, activeLocationCode)) {
                    activeLocationCode = null;
                }
            }

            function trendFilterExists(data) {
                if (activeTrendDateKey === null || activeStatusCode === null) return true;

                return getDashboardStatusTrend(data).some(function (point) {
                    const locationMatched = activeLocationCode === null ||
                        normalizeLocationFilterCode(valueOf(point, "LocationCode", "N/A")) === activeLocationCode;

                    return getStatusCode(point) === activeStatusCode &&
                        dashboardTrendPointDayKey(point) === activeTrendDateKey &&
                        asNumber(valueOf(point, "VehicleCount", 0)) > 0 &&
                        locationMatched;
                });
            }

            function clearMissingTrendFilter(data) {
                if (!trendFilterExists(data)) {
                    activeTrendDateKey = null;
                }
            }

            function renderStatusBreakdown(data) {
                const statuses = getDashboardStatuses(data);
                const currentStatuses = getDashboardCurrentStatuses(data);
                const currentTotal = currentStatuses.reduce(function (sum, status) {
                    return sum + asNumber(valueOf(status, "VehicleCount", 0));
                }, 0);
                const graphTotal = statuses.reduce(function (sum, status) {
                    return sum + asNumber(valueOf(status, "VehicleCount", 0));
                }, 0);
                clearMissingStatusFilter(statuses);
                let centerStatusCount = currentTotal;
                let centerStatusLabel = "Vehicles";
                if (activeStatusCode !== null) {
                    const activeStatus = statuses.find(function (status) {
                        return getStatusCode(status) === activeStatusCode;
                    });

                    if (activeStatus) {
                        centerStatusCount = asNumber(valueOf(activeStatus, "VehicleCount", 0));
                        centerStatusLabel = statusLabel(valueOf(activeStatus, "StatusText", "Status"));
                    }
                }

                $("#inventoryDashboardStatusTotal").text(formatNumber(centerStatusCount));
                $("#inventoryDashboardStatusCenterLabel").text(centerStatusLabel);
                $("#inventoryDashboardStatusDonut")
                    .toggleClass("is-clickable", statuses.length > 0)
                    .attr("role", statuses.length > 0 ? "button" : null)
                    .attr("tabindex", statuses.length > 0 ? "0" : null)
                    .attr("title", statuses.length > 0 ? "Filter the grid by status" : "");
                dashboardStatusChart = renderDashboardDoughnutChart(
                    dashboardStatusChart,
                    "#inventoryDashboardStatusDonut",
                    "inventoryDashboardStatusCanvas",
                    statuses.map(function (status) {
                        return statusLabel(valueOf(status, "StatusText", "Status"));
                    }),
                    statuses.map(function (status) {
                        return asNumber(valueOf(status, "VehicleCount", 0));
                    }),
                    statuses.map(function (status, index) {
                        return statusColor(status, index);
                    }),
                    statuses.map(getStatusCode),
                    activeStatusCode,
                    setActiveStatus,
                    statusGradient(statuses, graphTotal));

                const $legend = $("#inventoryDashboardStatusLegend").empty();
                if (!statuses.length) {
                    $("<div></div>")
                        .addClass("text-muted")
                        .text("No status data for this period.")
                        .appendTo($legend);
                    return;
                }

                statuses.forEach(function (status, index) {
                    const label = statusLabel(valueOf(status, "StatusText", "Status"));
                    const count = asNumber(valueOf(status, "VehicleCount", 0));
                    const color = statusColor(status, index);
                    const statusCode = getStatusCode(status);
                    const $item = $("<button></button>")
                        .attr("type", "button")
                        .attr("data-status-code", statusCode)
                        .addClass("inventory-dashboard-legend-item")
                        .toggleClass("is-active", activeStatusCode === statusCode)
                        .toggleClass("selected", activeStatusCode === statusCode)
                        .css("--dashboard-location-color", color);
                    const $label = $("<span></span>").addClass("inventory-dashboard-location-label");

                    $("<span></span>")
                        .addClass("inventory-dashboard-swatch")
                        .css("--dashboard-location-color", color)
                        .appendTo($label);
                    $("<span></span>")
                        .addClass("inventory-dashboard-location-code")
                        .text(label)
                        .appendTo($label);

                    $label.appendTo($item);
                    $("<span></span>")
                        .addClass("inventory-dashboard-location-count")
                        .text(formatNumber(count))
                        .appendTo($item);
                    $item.appendTo($legend);
                });
            }

            function renderLocations(data) {
                const locations = valueOf(data, "LocationCounts", []) || [];
                const total = locations.reduce(function (sum, location) {
                    return sum + asNumber(valueOf(location, "VehicleCount", 0));
                }, 0);
                clearMissingLocationFilter(locations);
                let centerLocationCount = total;
                let centerLocationLabel = "Vehicles";
                if (activeLocationCode !== null) {
                    const activeLocation = locations.find(function (location) {
                        return normalizeLocationFilterCode(valueOf(location, "LocationCode", "N/A")) === activeLocationCode;
                    });

                    if (activeLocation) {
                        centerLocationCount = asNumber(valueOf(activeLocation, "VehicleCount", 0));
                        centerLocationLabel = normalizeLocationFilterCode(valueOf(activeLocation, "LocationCode", "N/A"));
                    }
                }

                $("#inventoryDashboardLocationTotal").text(formatNumber(centerLocationCount));
                $("#inventoryDashboardLocationCenterLabel").text(centerLocationLabel);
                $("#inventoryDashboardLocationDonut")
                    .toggleClass("is-clickable", locations.length > 0)
                    .attr("role", locations.length > 0 ? "button" : null)
                    .attr("tabindex", locations.length > 0 ? "0" : null)
                    .attr("title", locations.length > 0 ? "Filter the grid by location" : "");
                dashboardLocationChart = renderDashboardDoughnutChart(
                    dashboardLocationChart,
                    "#inventoryDashboardLocationDonut",
                    "inventoryDashboardLocationCanvas",
                    locations.map(function (location, index) {
                        return locationBadgeInfo(valueOf(location, "LocationCode", "N/A"), index).label;
                    }),
                    locations.map(function (location) {
                        return asNumber(valueOf(location, "VehicleCount", 0));
                    }),
                    locations.map(function (location, index) {
                        return locationBadgeInfo(valueOf(location, "LocationCode", "N/A"), index).color;
                    }),
                    locations.map(function (location) {
                        return normalizeLocationFilterCode(valueOf(location, "LocationCode", "N/A"));
                    }),
                    activeLocationCode,
                    setActiveLocation,
                    locationGradient(locations, total));

                const $legend = $("#inventoryDashboardLocationLegend").empty();
                if (!locations.length) {
                    $("<div></div>")
                        .addClass("text-muted")
                        .text("No location data for this period.")
                        .appendTo($legend);
                    return;
                }

                locations.forEach(function (location, index) {
                    const badge = locationBadgeInfo(valueOf(location, "LocationCode", "N/A"), index);
                    const code = badge.label;
                    const locationCode = normalizeLocationFilterCode(code);
                    const count = asNumber(valueOf(location, "VehicleCount", 0));
                    const color = badge.color;
                    const $item = $("<button></button>")
                        .attr("type", "button")
                        .attr("data-location-code", locationCode)
                        .addClass("inventory-dashboard-legend-item")
                        .toggleClass("is-active", activeLocationCode === locationCode)
                        .css("--dashboard-location-color", color);
                    const $label = $("<span></span>").addClass("inventory-dashboard-location-label");

                    $("<span></span>")
                        .addClass("inventory-dashboard-swatch")
                        .css("--dashboard-location-color", color)
                        .appendTo($label);
                    $("<span></span>")
                        .addClass("inventory-dashboard-location-code")
                        .text(code)
                        .appendTo($label);

                    $label.appendTo($item);
                    $("<span></span>")
                        .addClass("inventory-dashboard-location-count")
                        .text(formatNumber(count))
                        .appendTo($item);
                    $item.appendTo($legend);
                });
            }

            function vehicleTimeTermKey(vehicle) {
                const rawDays = valueOf(vehicle, "DaysInInventory", null);
                if (rawDays === null || rawDays === undefined || rawDays === "") return null;
                const days = parseInt(rawDays, 10);
                if (!Number.isFinite(days) || days < 0) return null;

                const term = timeTerms.find(function (item) {
                    return days >= item.min && (item.max === null || days <= item.max);
                });
                return term ? term.key : null;
            }

            function setActiveTimeTerm(termKey) {
                const normalized = (termKey || "").toString();
                if (!timeTerms.some(function (term) { return term.key === normalized; })) return;
                activeTimeTermKey = activeTimeTermKey === normalized ? null : normalized;
                renderDashboard(currentDashboardDays);
            }

            function renderTimeTerms(data) {
                const vehicles = getDashboardVehicles(data).filter(isDashboardVehicleCurrent);
                const terms = timeTerms.map(function (term) {
                    return {
                        key: term.key,
                        label: term.label,
                        color: term.color,
                        count: vehicles.filter(function (vehicle) { return vehicleTimeTermKey(vehicle) === term.key; }).length
                    };
                });
                const total = terms.reduce(function (sum, term) { return sum + term.count; }, 0);
                const activeTerm = terms.find(function (term) { return term.key === activeTimeTermKey; });

                $("#inventoryDashboardTimeTermsTotal").text(formatNumber(activeTerm ? activeTerm.count : total));
                $("#inventoryDashboardTimeTermsCenterLabel").text(activeTerm ? activeTerm.label : "Vehicles");
                $("#inventoryDashboardTimeTermsDonut")
                    .toggleClass("is-clickable", total > 0)
                    .attr("role", total > 0 ? "button" : null)
                    .attr("tabindex", total > 0 ? "0" : null)
                    .attr("title", total > 0 ? "Filter the grid by days in inventory" : "");

                dashboardTimeTermsChart = renderDashboardDoughnutChart(
                    dashboardTimeTermsChart,
                    "#inventoryDashboardTimeTermsDonut",
                    "inventoryDashboardTimeTermsCanvas",
                    terms.map(function (term) { return term.label; }),
                    terms.map(function (term) { return term.count; }),
                    terms.map(function (term) { return term.color; }),
                    terms.map(function (term) { return term.key; }),
                    activeTimeTermKey,
                    setActiveTimeTerm,
                    "#e9eef5");

                const $legend = $("#inventoryDashboardTimeTermsLegend").empty();
                terms.forEach(function (term) {
                    const $item = $("<button></button>")
                        .attr("type", "button")
                        .attr("data-time-term", term.key)
                        .addClass("inventory-dashboard-legend-item")
                        .toggleClass("is-active", activeTimeTermKey === term.key)
                        .css("--dashboard-location-color", term.color);
                    const $label = $("<span></span>").addClass("inventory-dashboard-location-label");
                    $("<span></span>").addClass("inventory-dashboard-swatch").css("--dashboard-location-color", term.color).appendTo($label);
                    $("<span></span>").addClass("inventory-dashboard-location-code").text(term.label).appendTo($label);
                    $label.appendTo($item);
                    $("<span></span>").addClass("inventory-dashboard-location-count").text(formatNumber(term.count)).appendTo($item);
                    $item.appendTo($legend);
                });
            }

            function normalizeDashboardVehicle(vehicle) {
                const row = vehicle || {};
                row.Stock = valueOf(row, "Stock", "");
                row.Year = valueOf(row, "Year", "");
                row.Make = valueOf(row, "Make", "");
                row.Model = valueOf(row, "Model", "");
                row.VIN = valueOf(row, "VIN", "");
                row.VehicleStyle = valueOf(row, "VehicleStyle", "");
                row.LocationCode = valueOf(row, "LocationCode", "");
                row.Image = valueOf(row, "Image", "");
                row.Status = valueOf(row, "Status", null);
                row.StatusText = statusLabel(valueOf(row, "StatusText", "Status"));
                row.Statuses = getVehicleStatusCodes(row);
                row.HistoryStatuses = getVehicleHistoryStatusCodes(row);
                row.StatusEvents = getVehicleStatusEvents(row);
                row.DateCreated = valueOf(row, "DateCreated", "");
                row.DaysInInventory = valueOf(row, "DaysInInventory", null);
                row.InventoryStartDate = valueOf(row, "InventoryStartDate", "");
                row.InventoryStartSource = valueOf(row, "InventoryStartSource", "");
                return row;
            }

            function getVehicleStatusCodes(vehicle) {
                const statuses = valueOf(vehicle, "Statuses", null);
                if (Array.isArray(statuses) && statuses.length) {
                    return statuses
                        .map(normalizeStatusCode)
                        .filter(function (statusCode) {
                            return statusCode !== null;
                        });
                }

                const statusCode = normalizeStatusCode(valueOf(vehicle, "Status", null));
                return statusCode === null ? [] : [statusCode];
            }

            function getVehicleHistoryStatusCodes(vehicle) {
                const statuses = valueOf(vehicle, "HistoryStatuses", null);
                const source = Array.isArray(statuses) && statuses.length ? statuses : [];
                const seen = {};
                return source
                    .map(normalizeStatusCode)
                    .filter(function (statusCode) {
                        if (statusCode !== addedStatusCode &&
                            statusCode !== updatedStatusCode &&
                            statusCode !== removedStatusCode) {
                            return false;
                        }

                        if (seen[statusCode]) return false;
                        seen[statusCode] = true;
                        return true;
                    })
                    .sort(function (left, right) {
                        return getDashboardHistoryStatusSort(left) - getDashboardHistoryStatusSort(right);
                    });
            }

            function getVehicleStatusEvents(vehicle) {
                const events = valueOf(vehicle, "StatusEvents", null);
                if (!Array.isArray(events) || !events.length) {
                    return [];
                }

                return events.map(function (entry) {
                    return {
                        Status: getStatusCode(entry),
                        StatusText: statusLabel(valueOf(entry, "StatusText", "Status")),
                        DateKey: dashboardTrendPointDayKey(entry),
                        LocationCode: normalizeLocationFilterCode(valueOf(entry, "LocationCode", "N/A"))
                    };
                }).filter(function (entry) {
                    return entry.Status !== null && entry.DateKey;
                });
            }

            function dashboardVehicleMatchesTrendFilter(vehicle) {
                if (activeTrendDateKey === null || activeStatusCode === null) {
                    return true;
                }

                return getVehicleStatusEvents(vehicle).some(function (entry) {
                    const locationMatched = activeLocationCode === null || entry.LocationCode === activeLocationCode;
                    const statusMatched = activeStatusCode === stalledTrendStatusCode
                        ? isDashboardStalledTrendEventStatus(entry.Status)
                        : entry.Status === activeStatusCode;
                    return statusMatched &&
                        entry.DateKey === activeTrendDateKey &&
                        locationMatched;
                });
            }

            function getDashboardHistoryStatusSort(statusCode) {
                if (statusCode === addedStatusCode) return 0;
                if (statusCode === updatedStatusCode) return 1;
                if (statusCode === removedStatusCode) return 2;
                return 3;
            }

            function dashboardStatusDotInfo(statusCode) {
                if (statusCode === addedStatusCode) return { label: "Added", className: "is-added" };
                if (statusCode === updatedStatusCode) return { label: "Updated", className: "is-updated" };
                if (statusCode === removedStatusCode) return { label: "Sold", className: "is-removed" };
                return { label: "", className: "" };
            }

            function renderDashboardStatusDots(statusCodes) {
                const codes = Array.isArray(statusCodes) ? statusCodes : [];
                if (!codes.length) {
                    return `<span class="inventory-dashboard-status-empty">-</span>`;
                }

                const label = codes
                    .map(function (statusCode) {
                        return dashboardStatusDotInfo(statusCode).label;
                    })
                    .filter(Boolean)
                    .join(", ");
                const dots = codes.map(function (statusCode) {
                    const info = dashboardStatusDotInfo(statusCode);
                    return `<span class="inventory-dashboard-status-dot ${info.className}" title="${escapeDashboardHtml(info.label)}" aria-label="${escapeDashboardHtml(info.label)}"></span>`;
                }).join("");

                return `<span class="inventory-dashboard-status-dots" title="${escapeDashboardHtml(label)}">${dots}</span>`;
            }

            function getDashboardSearchTerms() {
                if (window.gtxInventorySearch) {
                    return window.gtxInventorySearch.splitTerms(activeDashboardSearchText);
                }

                const searchText = normalizeDashboardSearchText(activeDashboardSearchText);
                return searchText ? searchText.split(" ") : [];
            }

            function getDashboardVehicleSearchObject(vehicle) {
                const row = normalizeDashboardVehicle(vehicle);
                const fields = {
                    Stock: row.Stock,
                    Year: row.Year,
                    Make: row.Make,
                    Model: row.Model,
                    VIN: row.VIN,
                    VehicleStyle: row.VehicleStyle,
                    LocationCode: row.LocationCode,
                    Status: row.Status,
                    StatusText: row.StatusText,
                    DaysInInventory: row.DaysInInventory,
                    InventoryStartSource: row.InventoryStartSource
                };

                return window.gtxInventorySearch
                    ? window.gtxInventorySearch.vehicleObject(fields)
                    : fields;
            }

            function getDashboardVehicleSearchText(vehicle) {
                const row = normalizeDashboardVehicle(vehicle);
                const historyStatusLabels = row.HistoryStatuses.map(function (statusCode) {
                    return dashboardStatusDotInfo(statusCode).label;
                }).join(" ");
                const searchValues = [
                    row.Stock,
                    row.Year,
                    row.Make,
                    row.Model,
                    row.VIN,
                    row.VehicleStyle,
                    row.LocationCode,
                    normalizeLocationFilterCode(row.LocationCode),
                    row.Status,
                    row.StatusText,
                    row.DaysInInventory,
                    row.InventoryStartSource,
                    formatDate(row.InventoryStartDate),
                    historyStatusLabels
                ];

                if (window.gtxInventorySearch) {
                    return window.gtxInventorySearch.buildVehicleSearch(getDashboardVehicleSearchObject(row), [
                        normalizeLocationFilterCode(row.LocationCode),
                        formatDate(row.InventoryStartDate),
                        historyStatusLabels
                    ]).text;
                }

                return normalizeDashboardSearchText(searchValues.join(" "));
            }

            function getDashboardVehicleTokenSearchText(vehicle) {
                const row = normalizeDashboardVehicle(vehicle);

                if (window.gtxInventorySearch) {
                    return window.gtxInventorySearch.buildVehicleSearch(getDashboardVehicleSearchObject(row)).tokens;
                }

                return normalizeDashboardSearchText([
                    `@@YR ${row.Year}`,
                    `@@MK ${row.Make}`,
                    `@@MD ${row.Model}`,
                    `@@OW ${row.LocationCode}`
                ].join(" "));
            }

            function dashboardVehicleMatchesSearch(vehicle, searchTerms) {
                if (!searchTerms.length) return true;

                if (window.gtxInventorySearch) {
                    return window.gtxInventorySearch.matches(
                        getDashboardVehicleSearchText(vehicle),
                        activeDashboardSearchText,
                        getDashboardVehicleTokenSearchText(vehicle));
                }

                const searchText = getDashboardVehicleSearchText(vehicle);
                return searchTerms.every(function (term) {
                    return searchText.indexOf(term) !== -1;
                });
            }

            function isDashboardVehicleCurrent(vehicle) {
                return valueOf(vehicle, "IsCurrent", true) !== false;
            }

            function dashboardHistoryRowId(stockKey, index) {
                const normalized = (stockKey || "stock").replace(/[^A-Z0-9_-]/g, "-");
                return `inventoryDashboardHistory-${normalized}-${index}`;
            }

            function historyStatusClass(label) {
                const normalized = (label || "").toString().trim().toLowerCase();
                if (normalized === "added") return "is-added";
                if (normalized === "removed" || normalized === "sold") return "is-removed";
                if (normalized === "updated") return "is-updated";
                if (normalized === "purchased") return "is-purchased";
                return "";
            }

            function dashboardHistoryChangeRowId(stockKey, index) {
                const normalized = (normalizeStockKey(stockKey) || "stock").replace(/[^A-Z0-9_-]/g, "-");
                return `inventoryDashboardHistoryChange-${normalized}-${index}`;
            }

            function getDashboardHistoryChanges(entry) {
                const changes = valueOf(entry, "Changes", []);
                return Array.isArray(changes) ? changes : [];
            }

            function renderDashboardHistoryChanges(entry, dateText) {
                if (!valueOf(entry, "HasPreviousState", false)) {
                    return `<div class="inventory-dashboard-change-detail-panel text-muted">No previous logged state exists for this stock number.</div>`;
                }

                const rowsHtml = getDashboardHistoryChanges(entry).map(function (change) {
                    const field = valueOf(change, "Field", "");
                    const previousValue = valueOf(change, "PreviousValue", "");
                    const currentValue = valueOf(change, "CurrentValue", "");
                    const previousClass = isDashboardNumericChangeValue(field, previousValue) ? ` class="inventory-dashboard-change-number"` : "";
                    const currentClass = isDashboardNumericChangeValue(field, currentValue) ? ` class="inventory-dashboard-change-number"` : "";

                    return `
                        <tr>
                            <td class="fw-semibold">${escapeDashboardHtml(field)}</td>
                            <td${previousClass}>${escapeDashboardHtml(formatDashboardChangeValue(field, previousValue))}</td>
                            <td${currentClass}>${escapeDashboardHtml(formatDashboardChangeValue(field, currentValue))}</td>
                            <td>${escapeDashboardHtml(dateText)}</td>
                        </tr>`;
                }).join("");

                if (!rowsHtml) {
                    return `<div class="inventory-dashboard-change-detail-panel text-muted">No field-level differences were found in the logged values.</div>`;
                }

                return `
                    <div class="inventory-dashboard-change-detail-panel">
                        <div class="table-responsive">
                            <table class="table table-sm inventory-dashboard-change-table">
                                <thead>
                                    <tr>
                                        <th>Field</th>
                                        <th>Previous</th>
                                        <th>New</th>
                                        <th>Date updated</th>
                                    </tr>
                                </thead>
                                <tbody>${rowsHtml}</tbody>
                            </table>
                        </div>
                    </div>`;
            }

            function renderDashboardHistoryRows(history, stockKey) {
                if (window.gtxInventoryHistory) {
                    return window.gtxInventoryHistory.renderRows(history, stockKey, {
                        escapeHtml: escapeDashboardHtml,
                        formatDateTime: formatDateTime,
                        formatChangeValue: formatDashboardChangeValue,
                        isNumericChangeValue: isDashboardNumericChangeValue,
                        statusLabel: statusLabel,
                        valueOf: valueOf
                    });
                }
                const rows = Array.isArray(history) ? history : [];
                if (!rows.length) {
                    return `<div class="text-muted small">No inventory history found for this stock.</div>`;
                }

                const body = rows.map(function (entry, index) {
                    const status = statusLabel(valueOf(entry, "StatusText", "Status"));
                    const dateText = valueOf(entry, "DateText", "") || formatDateTime(valueOf(entry, "DateCreated", ""));
                    const isUpdated = status.toLowerCase() === "updated";
                    const changeRowId = dashboardHistoryChangeRowId(stockKey || valueOf(entry, "Stock", ""), index);
                    const toggleHtml = isUpdated
                        ? `<button type="button"
                                   class="inventory-dashboard-history-change-toggle"
                                   aria-expanded="false"
                                   aria-controls="${escapeDashboardHtml(changeRowId)}"
                                   data-history-change-target="${escapeDashboardHtml(changeRowId)}"
                                   title="Show updated values">
                               <i class="bi bi-chevron-right" aria-hidden="true"></i>
                               <span class="visually-hidden">Show updated values</span>
                           </button>`
                        : "";

                    return `
                        <tr>
                            <td class="inventory-dashboard-history-toggle-cell">${toggleHtml}</td>
                            <td>${escapeDashboardHtml(dateText || "-")}</td>
                            <td><span class="inventory-dashboard-history-status ${historyStatusClass(status)}">${escapeDashboardHtml(status)}</span></td>
                        </tr>
                        ${isUpdated
                            ? `<tr id="${escapeDashboardHtml(changeRowId)}" class="inventory-dashboard-history-change-row d-none">
                                   <td class="inventory-dashboard-change-detail-cell" colspan="3">
                                       ${renderDashboardHistoryChanges(entry, dateText)}
                                   </td>
                               </tr>`
                            : ""}`;
                }).join("");

                return `
                    <div class="table-responsive">
                        <table class="table inventory-dashboard-history-table">
                            <thead>
                                <tr>
                                    <th class="inventory-dashboard-history-toggle-cell"></th>
                                    <th>Date</th>
                                    <th>Status</th>
                                </tr>
                            </thead>
                            <tbody>${body}</tbody>
                        </table>
                    </div>
                `;
            }

            function renderDashboardHistoryPanel(stockKey) {
                const cached = dashboardHistoryCache[stockKey];
                return `
                    <div class="inventory-dashboard-history-panel">
                        <div class="inventory-dashboard-history-content" data-stock-key="${escapeDashboardHtml(stockKey)}">
                            ${cached ? renderDashboardHistoryRows(cached, stockKey) : `<div class="text-muted small">Loading history...</div>`}
                        </div>
                    </div>
                `;
            }

            function getDashboardDaysToneClass(daysValue) {
                if (daysValue === null || daysValue === undefined || daysValue === "") {
                    return "";
                }
                const days = asNumber(daysValue);
                if (days >= 365) {
                    return "badge bg-danger border border-light shadow-sm";
                }
                if (days >= 182) {
                    return "badge inventory-dashboard-days-badge-182 border shadow-sm";
                }
                if (days >= 90) {
                    return "badge bg-primary border border-light shadow-sm";
                }
                return "badge bg-success border border-light shadow-sm";
            }

            function getDashboardDaysIconClass(daysValue) {
                if (daysValue === null || daysValue === undefined || daysValue === "") return "";
                const days = asNumber(daysValue);
                if (days >= 365) return "bi-alarm";
                if (days >= 182) return "bi-exclamation-circle";
                if (days >= 90) return "bi-clock-history";
                return "bi-hourglass-split";
            }

            function renderDashboardVehicleRow(vehicle, index) {
                const row = normalizeDashboardVehicle(vehicle);
                const statusCodes = getVehicleStatusCodes(row);
                const locationCode = normalizeLocationFilterCode(row.LocationCode);
                const stockKey = normalizeStockKey(row.Stock);
                const rowId = dashboardHistoryRowId(stockKey, index);
                const isExpanded = !!expandedDashboardStocks[stockKey];
                const daysValue = row.DaysInInventory;
                const rowToneClass = index % 2 === 1 ? "is-alt" : "";
                const daysText = daysValue === null || daysValue === undefined || daysValue === ""
                    ? "-"
                    : formatNumber(daysValue);
                const daysToneClass = getDashboardDaysToneClass(daysValue);
                const daysIconClass = getDashboardDaysIconClass(daysValue);
                const startDate = formatDate(row.InventoryStartDate);
                const startSource = (row.InventoryStartSource || "").toString().trim();
                const daysTitle = startDate
                    ? `${daysText} day${asNumber(daysValue) === 1 ? "" : "s"} from ${startSource || "start"} ${startDate}`
                    : "No inventory start date";
                const imageCell = typeof window.renderMajordomeVehicleImageCell === "function"
                    ? window.renderMajordomeVehicleImageCell(row)
                    : `<td>${escapeDashboardHtml(row.Image)}</td>`;
                const detailsCell = typeof window.renderMajordomeVehicleDetailsCell === "function"
                    ? window.renderMajordomeVehicleDetailsCell(row)
                    : `<td>${escapeDashboardHtml([row.Year, row.Make, row.Model].join(" "))}</td>`;
                const locationBadge = locationBadgeInfo(locationCode, 0);
                const vehicleTitle = [row.Year, row.Make, row.Model, row.Stock]
                    .filter(function (part) {
                        return part !== null && part !== undefined && part.toString().trim() !== "";
                    })
                    .join(" ");

                return `
                    <tr class="inventory-dashboard-main-row ${rowToneClass} ${isExpanded ? "is-expanded" : ""}"
                        data-status-code="${escapeDashboardHtml(statusCodes.join(","))}"
                        data-location-code="${escapeDashboardHtml(locationCode)}"
                        data-stock="${escapeDashboardHtml(row.Stock)}"
                        data-stock-key="${escapeDashboardHtml(stockKey)}"
                        data-history-target="${escapeDashboardHtml(rowId)}"
                        aria-expanded="${isExpanded ? "true" : "false"}">
                        <td class="inventory-dashboard-expand-cell">
                            <button type="button"
                                    class="inventory-dashboard-expand-button"
                                    aria-expanded="${isExpanded ? "true" : "false"}"
                                    aria-controls="${escapeDashboardHtml(rowId)}"
                                    title="Show inventory history">
                                <i class="bi bi-chevron-right" aria-hidden="true"></i>
                                <span class="visually-hidden">Show inventory history</span>
                            </button>
                        </td>
                        ${imageCell}
                        ${detailsCell}
                        <td class="inventory-dashboard-status-dot-cell">${renderDashboardStatusDots(row.HistoryStatuses)}</td>
                        <td class="inventory-dashboard-main-location-cell">
                            <span class="inventory-dashboard-gtx-code ${locationBadge.toneClass}">${escapeDashboardHtml(locationBadge.label)}</span>
                        </td>
                        <td class="inventory-dashboard-days-cell" title="${escapeDashboardHtml(daysTitle)}">
                            <span class="inventory-dashboard-days-number ${daysToneClass}">
                                ${daysIconClass ? `<i class="bi ${daysIconClass}" aria-hidden="true"></i>` : ""}
                                <span>${escapeDashboardHtml(daysText)}</span>
                            </span>
                        </td>
                        <td class="inventory-dashboard-details-cell">
                            <button type="button"
                                    class="btn btn-outline-secondary inventory-dashboard-details-button"
                                    data-dashboard-details-stock="${escapeDashboardHtml(row.Stock)}"
                                    data-dashboard-details-title="${escapeDashboardHtml(vehicleTitle)}"
                                    title="Show vehicle details">
                                <i class="bi bi-card-list" aria-hidden="true"></i>
                                <span class="visually-hidden">Show vehicle details</span>
                            </button>
                        </td>
                    </tr>
                    <tr id="${escapeDashboardHtml(rowId)}"
                        class="inventory-dashboard-history-row ${rowToneClass} ${isExpanded ? "" : "d-none"}"
                        data-history-row-for="${escapeDashboardHtml(stockKey)}">
                        <td colspan="7">${renderDashboardHistoryPanel(stockKey)}</td>
                    </tr>
                `;
            }

            function getDashboardGridSortValue(vehicle, key) {
                const row = normalizeDashboardVehicle(vehicle);
                if (key === "days") {
                    const days = asNumber(row.DaysInInventory);
                    return row.DaysInInventory === null || row.DaysInInventory === undefined || row.DaysInInventory === ""
                        ? Number.NEGATIVE_INFINITY
                        : days;
                }

                if (key === "vehicle") {
                    return [
                        row.Make,
                        row.Model,
                        row.Year,
                        row.Stock,
                        row.VIN
                    ].join(" ").toLowerCase();
                }

                if (key === "location") {
                    return normalizeLocationFilterCode(row.LocationCode).toLowerCase();
                }

                return "";
            }

            function compareDashboardGridValues(left, right, key) {
                const leftValue = getDashboardGridSortValue(left, key);
                const rightValue = getDashboardGridSortValue(right, key);

                if (typeof leftValue === "number" && typeof rightValue === "number") {
                    return leftValue - rightValue;
                }

                return leftValue.toString().localeCompare(rightValue.toString(), undefined, {
                    numeric: true,
                    sensitivity: "base"
                });
            }

            function sortDashboardGridVehicles(vehicles) {
                const rows = vehicles.slice();
                if (!activeGridSortKey) {
                    return rows;
                }

                rows.sort(function (left, right) {
                    const result = compareDashboardGridValues(left, right, activeGridSortKey);
                    return activeGridSortDirection === "desc" ? -result : result;
                });
                return rows;
            }

            function renderDashboardGridSortHeaders() {
                $("#inventoryDashboardStatusTable [data-dashboard-sort-column]").each(function () {
                    const $header = $(this);
                    const key = $header.attr("data-dashboard-sort-column");
                    const isActive = key === activeGridSortKey;
                    const direction = isActive ? activeGridSortDirection : "none";
                    const $icon = $header.find(".inventory-dashboard-sort-indicator");

                    $header.toggleClass("is-active", isActive);
                    $icon.removeClass("bi-arrow-down-up bi-arrow-up bi-arrow-down");
                    $icon.addClass(!isActive ? "bi-arrow-down-up" : (activeGridSortDirection === "asc" ? "bi-arrow-down" : "bi-arrow-up"));
                    $header.attr("aria-sort", direction === "none" ? "none" : (direction === "asc" ? "ascending" : "descending"));
                });
            }

            function renderStatusGrid(data) {
                const vehicles = getDashboardVehicles(data);
                const currentVehicles = vehicles.filter(isDashboardVehicleCurrent);
                const removedVehicles = vehicles.filter(function (vehicle) {
                    return !isDashboardVehicleCurrent(vehicle) && getVehicleStatusCodes(vehicle).indexOf(removedStatusCode) !== -1;
                });
                const searchTerms = getDashboardSearchTerms();
                const filteredVehicles = vehicles.filter(function (vehicle) {
                    const statusCodes = getVehicleStatusCodes(vehicle);
                    const locationCode = normalizeLocationFilterCode(valueOf(vehicle, "LocationCode", ""));
                    const isCurrent = isDashboardVehicleCurrent(vehicle);
                    let statusMatched = false;

                    if (activeTrendDateKey !== null) {
                        statusMatched = dashboardVehicleMatchesTrendFilter(vehicle);
                    } else if (activeStatusCode === removedStatusCode) {
                        statusMatched = statusCodes.indexOf(removedStatusCode) !== -1;
                    } else if (activeStatusCode === null) {
                        statusMatched = isCurrent;
                    } else {
                        statusMatched = isCurrent && statusCodes.indexOf(activeStatusCode) !== -1;
                    }

                    const locationMatched = activeTrendDateKey !== null ||
                        activeLocationCode === null ||
                        locationCode === activeLocationCode;
                    const searchMatched = dashboardVehicleMatchesSearch(vehicle, searchTerms);
                    const timeTermMatched = activeTimeTermKey === null || vehicleTimeTermKey(vehicle) === activeTimeTermKey;
                    return statusMatched && locationMatched && timeTermMatched && searchMatched;
                });
                const total = activeTrendDateKey !== null
                    ? vehicles.filter(dashboardVehicleMatchesTrendFilter).length
                    : (activeStatusCode === removedStatusCode
                        ? removedVehicles.length
                        : currentVehicles.length);
                const filteredTotal = filteredVehicles.length;
                const searchFilterText = activeDashboardSearchText.trim();
                const sortedVehicles = sortDashboardGridVehicles(filteredVehicles);
                const rowsHtml = sortedVehicles.map(function (vehicle, index) {
                    return renderDashboardVehicleRow(vehicle, index);
                }).join("");

                updateDashboardSummary(filteredTotal, total);
                $("#inventoryDashboardClearStatus").toggleClass("d-none", activeStatusCode === null && activeLocationCode === null && activeTimeTermKey === null && activeTrendDateKey === null && !searchFilterText);
                if (window.gtxSecurity && typeof window.gtxSecurity.setSafeHtml === "function") {
                    window.gtxSecurity.setSafeHtml($("#inventoryDashboardStatusBody"), rowsHtml);
                } else {
                    $("#inventoryDashboardStatusBody").html(rowsHtml);
                }
                $("#inventoryDashboardStatusEmpty").text(searchFilterText
                    ? "No vehicles match the selected filters or search."
                    : (activeTrendDateKey !== null
                        ? "No vehicles match the selected status and date."
                        : "No vehicles match the selected filter."));
                $("#inventoryDashboardStatusEmpty").toggleClass("d-none", filteredTotal > 0);
                $("#inventoryDashboardStatusTable").toggleClass("d-none", filteredTotal === 0);
                renderDashboardGridSortHeaders();
                hydrateExpandedDashboardHistoryRows();
            }

            function dashboardHistoryContents(stockKey) {
                const normalizedStockKey = normalizeStockKey(stockKey);
                return $(".inventory-dashboard-history-content").filter(function () {
                    return normalizeStockKey($(this).attr("data-stock-key")) === normalizedStockKey;
                });
            }

            function loadDashboardVehicleHistory(stockKey) {
                const normalizedStockKey = normalizeStockKey(stockKey);
                const $contents = dashboardHistoryContents(normalizedStockKey);
                if (!normalizedStockKey || !$contents.length) return;

                if (dashboardHistoryCache[normalizedStockKey]) {
                    $contents.each(function () {
                        const html = renderDashboardHistoryRows(dashboardHistoryCache[normalizedStockKey], normalizedStockKey);
                        if (window.gtxSecurity && typeof window.gtxSecurity.setSafeHtml === "function") {
                            window.gtxSecurity.setSafeHtml($(this), html);
                        } else {
                            $(this).html(html);
                        }
                    });
                    return;
                }

                if (dashboardHistoryRequests[normalizedStockKey]) return;

                dashboardHistoryRequests[normalizedStockKey] = $.get(`${dashboardRoot()}InventoryManagement/GetInventoryDashboardVehicleHistory`, {
                    stock: normalizedStockKey
                })
                    .done(function (payload) {
                        const history = payload && payload.success !== false
                            ? (valueOf(payload, "history", []) || [])
                            : [];
                        dashboardHistoryCache[normalizedStockKey] = history;
                        dashboardHistoryContents(normalizedStockKey).each(function () {
                            const html = renderDashboardHistoryRows(history, normalizedStockKey);
                            if (window.gtxSecurity && typeof window.gtxSecurity.setSafeHtml === "function") {
                                window.gtxSecurity.setSafeHtml($(this), html);
                            } else {
                                $(this).html(html);
                            }
                        });
                    })
                    .fail(function () {
                        dashboardHistoryContents(normalizedStockKey).html(
                            `<div class="text-danger small">Unable to load inventory history.</div>`);
                    })
                    .always(function () {
                        delete dashboardHistoryRequests[normalizedStockKey];
                    });
            }

            function hydrateExpandedDashboardHistoryRows() {
                $("#inventoryDashboardStatusBody .inventory-dashboard-main-row.is-expanded").each(function () {
                    loadDashboardVehicleHistory($(this).attr("data-stock-key"));
                });
            }

            function collapseOtherDashboardHistoryRows(activeStockKey) {
                const normalizedActiveStockKey = normalizeStockKey(activeStockKey);

                Object.keys(expandedDashboardStocks).forEach(function (stockKey) {
                    if (normalizeStockKey(stockKey) !== normalizedActiveStockKey) {
                        delete expandedDashboardStocks[stockKey];
                    }
                });

                $("#inventoryDashboardStatusBody .inventory-dashboard-main-row.is-expanded").each(function () {
                    const $otherRow = $(this);
                    const otherStockKey = normalizeStockKey($otherRow.attr("data-stock-key"));
                    if (otherStockKey === normalizedActiveStockKey) return;

                    const otherTargetId = $otherRow.attr("data-history-target");
                    $otherRow
                        .removeClass("is-expanded")
                        .attr("aria-expanded", "false")
                        .find(".inventory-dashboard-expand-button")
                        .attr("aria-expanded", "false");
                    $(`#${otherTargetId}`).addClass("d-none");
                });
            }

            function setDashboardHistoryExpanded($row, isExpanded) {
                const stockKey = normalizeStockKey($row.attr("data-stock-key"));
                const targetId = $row.attr("data-history-target");
                const $historyRow = $(`#${targetId}`);
                if (!stockKey || !$historyRow.length) return;

                if (isExpanded) {
                    collapseOtherDashboardHistoryRows(stockKey);
                    expandedDashboardStocks[stockKey] = true;
                    $row.addClass("is-expanded").attr("aria-expanded", "true");
                    $row.find(".inventory-dashboard-expand-button").attr("aria-expanded", "true");
                    $historyRow.removeClass("d-none");
                    loadDashboardVehicleHistory(stockKey);
                } else {
                    delete expandedDashboardStocks[stockKey];
                    $row.removeClass("is-expanded").attr("aria-expanded", "false");
                    $row.find(".inventory-dashboard-expand-button").attr("aria-expanded", "false");
                    $historyRow.addClass("d-none");
                }
            }

            function toggleDashboardHistoryRow($row) {
                setDashboardHistoryExpanded($row, !$row.hasClass("is-expanded"));
            }

            function setDashboardHistoryChangeExpanded($button, isExpanded) {
                const targetId = $button.attr("data-history-change-target");
                const $changeRow = $(`#${targetId}`);
                if (!$changeRow.length) return;

                if (isExpanded) {
                    $("#inventoryDashboardStatusBody .inventory-dashboard-history-change-toggle.is-expanded").each(function () {
                        if (this !== $button[0]) {
                            setDashboardHistoryChangeExpanded($(this), false);
                        }
                    });
                }

                $button
                    .toggleClass("is-expanded", isExpanded)
                    .attr("aria-expanded", isExpanded ? "true" : "false");
                $changeRow.toggleClass("d-none", !isExpanded);
            }

            function toggleDashboardHistoryChange($button) {
                setDashboardHistoryChangeExpanded($button, !$button.hasClass("is-expanded"));
            }

            function setDashboardGridSort(key) {
                if (activeGridSortKey === key) {
                    // Cycle through states based on column
                    if (key === "days") {
                        // Days column: desc → asc → native
                        if (activeGridSortDirection === "desc") {
                            activeGridSortDirection = "asc";
                        } else if (activeGridSortDirection === "asc") {
                            activeGridSortKey = null;
                            activeGridSortDirection = "asc";
                        }
                    } else {
                        // Other columns: asc → desc → native
                        if (activeGridSortDirection === "asc") {
                            activeGridSortDirection = "desc";
                        } else if (activeGridSortDirection === "desc") {
                            activeGridSortKey = null;
                            activeGridSortDirection = "asc";
                        }
                    }
                } else {
                    activeGridSortKey = key;
                    activeGridSortDirection = key === "days" ? "desc" : "asc";
                }

                renderDashboard(currentDashboardDays);
            }

            function applyDashboardFilterTerm(term) {
                activeDashboardSearchText = dashboardText(term);
                if (window.gtxInventorySearch) {
                    window.gtxInventorySearch.writeStoredTerm(activeDashboardSearchText);
                }
                renderDashboard(currentDashboardDays);
            }

            function setActiveStatus(statusCode) {
                const normalized = normalizeStatusCode(statusCode);
                if (normalized === null) return;

                activeStatusCode = activeStatusCode === normalized ? null : normalized;
                activeTrendDateKey = null;
                renderDashboard(currentDashboardDays);
            }

            function setActiveTrendFilter(statusCode, dateKey) {
                const normalizedStatus = normalizeStatusCode(statusCode);
                const normalizedDateKey = dashboardText(dateKey).trim();
                if (normalizedStatus === null || !normalizedDateKey) return;

                if (activeStatusCode === normalizedStatus && activeTrendDateKey === normalizedDateKey) {
                    activeStatusCode = null;
                    activeTrendDateKey = null;
                } else {
                    activeStatusCode = normalizedStatus;
                    activeTrendDateKey = normalizedDateKey;
                }

                renderDashboard(currentDashboardDays);
            }

            function setActiveLocation(locationCode) {
                const normalized = normalizeLocationFilterCode(locationCode);
                activeLocationCode = activeLocationCode === normalized ? null : normalized;
                renderDashboard(currentDashboardDays);
            }

            function getClickedStatusCode(event, statuses) {
                const total = statuses.reduce(function (sum, status) {
                    return sum + asNumber(valueOf(status, "VehicleCount", 0));
                }, 0);
                if (!statuses.length || total <= 0) return null;

                const rect = event.currentTarget.getBoundingClientRect();
                const x = event.clientX - rect.left - (rect.width / 2);
                const y = event.clientY - rect.top - (rect.height / 2);
                const angle = (Math.atan2(y, x) * 180 / Math.PI + 450) % 360;
                let cursor = 0;

                for (let index = 0; index < statuses.length; index++) {
                    const status = statuses[index];
                    const count = asNumber(valueOf(status, "VehicleCount", 0));
                    const end = index === statuses.length - 1 ? 360 : cursor + (count / total * 360);
                    if (angle >= cursor && angle <= end) {
                        return getStatusCode(status);
                    }
                    cursor = end;
                }

                return null;
            }

            function getClickedLocationCode(event, locations) {
                const total = locations.reduce(function (sum, location) {
                    return sum + asNumber(valueOf(location, "VehicleCount", 0));
                }, 0);
                if (!locations.length || total <= 0) return null;

                const rect = event.currentTarget.getBoundingClientRect();
                const x = event.clientX - rect.left - (rect.width / 2);
                const y = event.clientY - rect.top - (rect.height / 2);
                const angle = (Math.atan2(y, x) * 180 / Math.PI + 450) % 360;
                let cursor = 0;

                for (let index = 0; index < locations.length; index++) {
                    const location = locations[index];
                    const count = asNumber(valueOf(location, "VehicleCount", 0));
                    const end = index === locations.length - 1 ? 360 : cursor + (count / total * 360);
                    if (angle >= cursor && angle <= end) {
                        return normalizeLocationFilterCode(valueOf(location, "LocationCode", "N/A"));
                    }
                    cursor = end;
                }

                return null;
            }

            function renderDashboard(days) {
                currentDashboardDays = (days || "7").toString();
                const data = dashboardFor(days);
                const start = formatDate(valueOf(data, "PeriodStartUtc", ""));
                const end = formatDate(valueOf(data, "PeriodEndUtc", ""));

                clearMissingLocationFilter(valueOf(data, "LocationCounts", []) || []);
                clearMissingTrendFilter(data);
                $("#inventoryDashboardRange").text(start && end ? `${start} - ${end}` : "");
                renderStatusBreakdown(data);
                renderStatusTrend(data);
                renderLocations(data);
                renderTimeTerms(data);
                renderStatusGrid(data);
            }

            function loadDashboard(days, forceRefresh) {
                const selectedDays = (days || "7").toString();
                if (!forceRefresh && dashboardFor(selectedDays)) {
                    renderDashboard(selectedDays);
                    return;
                }

                if (dashboardRequest) {
                    dashboardRequest.abort();
                }

                setDashboardBusy(true);
                dashboardRequest = $.get(`${dashboardRoot()}InventoryManagement/GetInventoryDashboard`, {
                    days: selectedDays
                })
                    .done(function (payload) {
                        if (!payload || payload.success === false) {
                            renderDashboard(selectedDays);
                            $("#inventoryDashboardRange").text("Unable to load this period.");
                            return;
                        }

                        const dashboard = valueOf(payload, "dashboard", null);
                        cacheDashboard(selectedDays, dashboard);
                        renderDashboard(selectedDays);
                    })
                    .fail(function (xhr, statusText) {
                        if (statusText === "abort") return;

                        renderDashboard(selectedDays);
                        $("#inventoryDashboardRange").text("Unable to refresh this period.");
                    })
                    .always(function () {
                        dashboardRequest = null;
                        setDashboardBusy(false);
                    });
            }

            $(function () {
                const $period = $("#inventoryDashboardPeriod");
                const $filterTerm = $("#filterTerm");
                window.applyMajordomeInventoryFilter = applyDashboardFilterTerm;

                if (window.gtxInventorySearch) {
                    activeDashboardSearchText = window.gtxInventorySearch.readStoredTerm();
                    $filterTerm.val(activeDashboardSearchText);
                }

                $period.on("change", function () {
                    activeTrendDateKey = null;
                    loadDashboard(this.value, true);
                });
                $("#inventoryDashboardStatusLegend").on("click", ".inventory-dashboard-legend-item", function () {
                    setActiveStatus($(this).attr("data-status-code"));
                });
                $("#inventoryDashboardLocationLegend").on("click", ".inventory-dashboard-legend-item", function () {
                    setActiveLocation($(this).attr("data-location-code"));
                });
                $("#inventoryDashboardTimeTermsLegend").on("click", ".inventory-dashboard-legend-item", function () {
                    setActiveTimeTerm($(this).attr("data-time-term"));
                });
                $("#inventoryDashboardStatusTrendChart").on("click", ".inventory-dashboard-trend-bar", function () {
                    if (asNumber($(this).attr("data-dashboard-trend-value")) <= 0) return;

                    setActiveTrendFilter(
                        $(this).attr("data-dashboard-trend-status"),
                        $(this).attr("data-dashboard-trend-date"));
                }).on("keydown", ".inventory-dashboard-trend-bar", function (event) {
                    if (event.key !== "Enter" && event.key !== " ") return;
                    if (asNumber($(this).attr("data-dashboard-trend-value")) <= 0) return;

                    event.preventDefault();
                    setActiveTrendFilter(
                        $(this).attr("data-dashboard-trend-status"),
                        $(this).attr("data-dashboard-trend-date"));
                });
                $("#inventoryDashboardStatusBody").on("click", ".inventory-dashboard-history-change-toggle", function (event) {
                    event.preventDefault();
                    event.stopPropagation();
                    toggleDashboardHistoryChange($(this));
                });
                $("#inventoryDashboardStatusBody").on("click", ".inventory-dashboard-main-row", function (event) {
                    if ($(event.target).closest("a").length) return;
                    toggleDashboardHistoryRow($(this));
                });
                $("#inventoryDashboardStatusBody").on("keydown", ".inventory-dashboard-expand-button", function (event) {
                    if (event.key !== "Enter" && event.key !== " ") return;

                    event.preventDefault();
                    toggleDashboardHistoryRow($(this).closest(".inventory-dashboard-main-row"));
                });
                $("#inventoryDashboardStatusTable").on("click", "th.inventory-dashboard-sortable-th", function () {
                    setDashboardGridSort($(this).attr("data-dashboard-sort-column"));
                }).on("keydown", "th.inventory-dashboard-sortable-th", function (event) {
                    if (event.key !== "Enter" && event.key !== " ") return;
                    event.preventDefault();
                    setDashboardGridSort($(this).attr("data-dashboard-sort-column"));
                });
                $("#inventoryDashboardStatusDonut").on("click", function (event) {
                    if (dashboardChartsAvailable()) return;
                    const statusCode = getClickedStatusCode(event, getDashboardStatuses(dashboardFor(currentDashboardDays)));
                    if (statusCode !== null) {
                        setActiveStatus(statusCode);
                    }
                }).on("keydown", function (event) {
                    if (event.key !== "Enter" && event.key !== " ") return;
                    const statuses = getDashboardStatuses(dashboardFor(currentDashboardDays));
                    if (!statuses.length) return;

                    event.preventDefault();
                    const firstStatusCode = activeStatusCode === null
                        ? getStatusCode(statuses[0])
                        : activeStatusCode;
                    setActiveStatus(firstStatusCode);
                });
                $("#inventoryDashboardLocationDonut").on("click", function (event) {
                    if (dashboardChartsAvailable()) return;
                    const locationCode = getClickedLocationCode(event, valueOf(dashboardFor(currentDashboardDays), "LocationCounts", []) || []);
                    if (locationCode !== null) {
                        setActiveLocation(locationCode);
                    }
                }).on("keydown", function (event) {
                    if (event.key !== "Enter" && event.key !== " ") return;
                    const locations = valueOf(dashboardFor(currentDashboardDays), "LocationCounts", []) || [];
                    if (!locations.length) return;

                    event.preventDefault();
                    const firstLocationCode = activeLocationCode === null
                        ? normalizeLocationFilterCode(valueOf(locations[0], "LocationCode", "N/A"))
                        : activeLocationCode;
                    setActiveLocation(firstLocationCode);
                });
                $("#inventoryDashboardTimeTermsDonut").on("keydown", function (event) {
                    if (event.key !== "Enter" && event.key !== " ") return;
                    event.preventDefault();
                    setActiveTimeTerm(activeTimeTermKey === null ? timeTerms[0].key : activeTimeTermKey);
                });
                $("#inventoryDashboardClearStatus").on("click", function () {
                    activeStatusCode = null;
                    activeLocationCode = null;
                    activeTimeTermKey = null;
                    activeTrendDateKey = null;
                    activeDashboardSearchText = "";
                    $filterTerm.val("");
                    if (window.gtxInventorySearch) {
                        window.gtxInventorySearch.writeStoredTerm("");
                    }
                    renderDashboard(currentDashboardDays);
                });
                loadDashboard($period.val() || "7", false);
            });
        })(jQuery);
    </script>
}
