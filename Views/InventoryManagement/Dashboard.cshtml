    }

        .inventory-dashboard-donut.is-clickable {
            cursor: pointer;
        }

        .inventory-dashboard-donut.is-clickable:focus-visible {
            outline: .18rem solid rgba(13, 110, 253, .35);
            outline-offset: .25rem;
        }

        .inventory-dashboard-donut::after {
            content: "";
