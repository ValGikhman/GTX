<div class="modal fade" id="inventoryDashboardDetailsModal" tabindex="-1" aria-labelledby="inventoryDashboardDetailsModalTitle" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="inventoryDashboardDetailsModalTitle">Vehicle Details</h5>
                <button type="button" class="btn-close inventory-dashboard-details-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div id="inventoryDashboardDetailsModalBody" class="modal-body inventory-dashboard-details-modal-body">
                <div class="inventory-dashboard-details-loading text-muted">Loading details...</div>
            </div>
        </div>
    </div>
</div>

<script type="text/javascript">
    (function (window, $) {
        if (!$) return;

        function dashboardDetailsRoot() {
            return typeof root !== "undefined" ? root : "/";
        }

        function showDashboardDetailsModal() {
            const modalElement = document.getElementById("inventoryDashboardDetailsModal");
            if (window.bootstrap && window.bootstrap.Modal && modalElement) {
                window.bootstrap.Modal.getOrCreateInstance(modalElement).show();
            } else if ($.fn.modal) {
                $("#inventoryDashboardDetailsModal").modal("show");
            } else {
                $("#inventoryDashboardDetailsModal").addClass("show").show();
            }
        }

        window.loadDashboardVehicleDetails = function (stock, title) {
            const stockText = (stock || "").toString().trim();
            if (!stockText) return;

            $("#inventoryDashboardDetailsModalTitle").text(title || `Vehicle ${stockText}`);
            $("#inventoryDashboardDetailsModalBody").html(`<div class="inventory-dashboard-details-loading text-muted">Loading details...</div>`);
            showDashboardDetailsModal();

            $.get(`${dashboardDetailsRoot()}InventoryManagement/GetInventoryDashboardVehicleDetails`, {
                stock: stockText
            })
                .done(function (html) {
                    const $body = $("#inventoryDashboardDetailsModalBody").html(html);
                    if (window.bootstrap && window.bootstrap.Carousel) {
                        $body.find(".carousel").each(function () {
                            window.bootstrap.Carousel.getOrCreateInstance(this);
                        });
                    }
                })
                .fail(function () {
                    $("#inventoryDashboardDetailsModalBody").html(`<div class="alert alert-warning mb-0">Unable to load vehicle details.</div>`);
                });
        };

        $(function () {
            $("#inventoryDashboardStatusBody, #majordomeManagementBody")
                .off("click.inventoryDashboardDetails", ".inventory-dashboard-details-button")
                .on("click.inventoryDashboardDetails", ".inventory-dashboard-details-button", function (event) {
                    event.preventDefault();
                    event.stopPropagation();
                    const $button = $(this);
                    window.loadDashboardVehicleDetails(
                        $button.attr("data-dashboard-details-stock"),
                        $button.attr("data-dashboard-details-title"));
                });

            $("#inventoryDashboardDetailsModal")
                .off("hidden.bs.modal.inventoryDashboardDetails")
                .on("hidden.bs.modal.inventoryDashboardDetails", function () {
                    $("#inventoryDashboardDetailsModalBody").html(`<div class="inventory-dashboard-details-loading text-muted">Loading details...</div>`);
                });
        });
    })(window, window.jQuery);
</script>
