@{
    ViewBag.Title = "Health";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    body {
        background: #eef2f7;
    }

    .wrap {
        max-width: 90%;
        margin-left: auto;
        margin-right: auto;
    }

    .card-elev {
        border: 0;
        border-radius: 18px;
        box-shadow: 0 10px 30px rgba(0,0,0,.06);
    }

    .health-page-head {
        border: 1px solid rgba(15, 23, 42, .08);
        border-radius: 22px;
        background: linear-gradient(135deg, #ffffff 0%, #f8fafc 52%, #edf7ff 100%);
        box-shadow: 0 20px 52px rgba(15, 23, 42, .11), 0 3px 12px rgba(15, 23, 42, .06);
        padding: 1.15rem 1.25rem;
    }

    .health-page-icon {
        width: 3.15rem;
        height: 3.15rem;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border-radius: 1rem;
        color: #fff;
        background: linear-gradient(135deg, #0f766e, #2563eb);
        box-shadow: 0 1rem 2rem rgba(37, 99, 235, .22);
        font-size: 1.45rem;
        flex: 0 0 auto;
    }

    .health-cards-row {
        display: flex;
        flex-wrap: wrap;
        gap: 1rem;
    }

    .health-card-col {
        flex: 1 1 240px;
        min-width: 240px;
    }

    .health-card {
        position: relative;
        overflow: hidden;
        border: 1px solid rgba(15, 23, 42, .08);
        border-radius: 22px !important;
        background: linear-gradient(180deg, #ffffff 0%, #fbfdff 100%);
        box-shadow: 0 18px 45px rgba(15, 23, 42, .12), 0 2px 8px rgba(15, 23, 42, .06) !important;
        transition: transform .18s ease, box-shadow .18s ease, border-color .18s ease;
    }

    .health-card:hover {
        transform: translateY(-2px);
        border-color: rgba(37, 99, 235, .2);
        box-shadow: 0 24px 58px rgba(15, 23, 42, .16), 0 4px 16px rgba(37, 99, 235, .09) !important;
    }

    .health-card::before {
        content: "";
        position: absolute;
        inset: 0 0 auto 0;
        height: 4px;
        background: linear-gradient(90deg, #2563eb, #0f766e);
    }

    .health-card-iis::before {
        background: linear-gradient(90deg, #2563eb, #06b6d4);
    }

    .health-card-cpu::before {
        background: linear-gradient(90deg, #f97316, #ef4444);
    }

    .health-card-memory::before {
        background: linear-gradient(90deg, #7c3aed, #2563eb);
    }

    .health-card-sessions::before {
        background: linear-gradient(90deg, #16a34a, #0f766e);
    }

    .health-card-maintenance::before {
        background: linear-gradient(90deg, #64748b, #334155);
    }

    .health-card-head {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: .85rem;
        margin-bottom: 1rem;
    }

    .health-card-title {
        display: flex;
        align-items: center;
        gap: .8rem;
        min-width: 0;
    }

    .health-icon {
        width: 2.85rem;
        height: 2.85rem;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border-radius: .9rem;
        color: #fff;
        box-shadow: 0 .85rem 1.7rem rgba(15, 23, 42, .18);
        font-size: 1.25rem;
        flex: 0 0 auto;
    }

    .health-icon-iis {
        background: linear-gradient(135deg, #2563eb, #06b6d4);
    }

    .health-icon-cpu {
        background: linear-gradient(135deg, #f97316, #ef4444);
    }

    .health-icon-memory {
        background: linear-gradient(135deg, #7c3aed, #2563eb);
    }

    .health-icon-sessions {
        background: linear-gradient(135deg, #16a34a, #0f766e);
    }

    .health-icon-maintenance {
        background: linear-gradient(135deg, #475569, #111827);
    }

    .health-card-maintenance {
        border: 1px solid rgba(0, 0, 0, .08);
        transition: background-color .2s ease, border-color .2s ease, box-shadow .2s ease;
    }

    .health-card-maintenance.is-offline {
        background: linear-gradient(180deg, #fff5f5 0%, #ffe3e3 100%);
        border-color: rgba(220, 53, 69, .6);
        box-shadow: 0 22px 54px rgba(220, 53, 69, .22), 0 4px 18px rgba(220, 53, 69, .12) !important;
    }

    .health-card-maintenance.is-offline::before {
        background: linear-gradient(90deg, #dc3545, #f97316);
    }

    .health-card-maintenance.is-offline .health-icon-maintenance {
        background: linear-gradient(135deg, #dc3545, #f97316);
        box-shadow: 0 .85rem 1.7rem rgba(220, 53, 69, .25);
    }

    .health-card-maintenance.is-offline .kpi-label,
    .health-card-maintenance.is-offline .kpi-sub,
    .health-card-maintenance.is-offline .kpi-value {
        color: #842029 !important;
    }

    .health-card-maintenance.is-offline #offlineStatusText {
        color: #b02a37 !important;
        font-weight: 800;
    }

    .kpi-label {
        font-size: .8rem;
        color: rgba(33,37,41,.65);
        letter-spacing: .02em;
    }

    .kpi-value {
        font-size: 2rem;
        font-weight: 800;
        letter-spacing: -0.03em;
        line-height: 1.1;
    }

    .kpi-sub {
        font-size: .85rem;
        color: rgba(33,37,41,.65);
    }

    .mono {
        font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;
    }

    .pill {
        border-radius: 999px;
    }

    .progress {
        height: 10px;
        border-radius: 999px;
        background: rgba(0,0,0,.06);
    }

    .progress-bar {
        border-radius: 999px;
    }

    .table thead th {
        font-size: .8rem;
        color: rgba(33,37,41,.65);
        font-weight: 700;
        border-bottom: 1px solid rgba(0,0,0,.06);
        white-space: nowrap;
    }

    .table td {
        padding-top: 14px;
        padding-bottom: 14px;
    }

    .cell-metric {
        display: flex;
        align-items: baseline;
        justify-content: space-between;
        gap: 10px;
    }

        .cell-metric .val {
            font-weight: 800;
            letter-spacing: -0.01em;
        }

        .cell-metric .unit {
            font-size: .8rem;
            color: rgba(33,37,41,.6);
        }

    /* Optional: slightly tighter padding on very small screens */
    @@media (max-width: 575.98px) {
        .health-card {
            padding: 1.25rem !important;
        }
        /* ~p-4 */
        .kpi-value {
            font-size: 1.75rem;
        }
    }

    /* Bigger Bootstrap switch */
    .big-switch.form-check-input {
        width: 3.4rem;
        height: 1.8rem;
        margin-top: 0;
        cursor: pointer;
    }

        /* Improve thumb size/position for the bigger switch */
        .big-switch.form-check-input:checked {
            background-position: right center;
        }

    /* Optional: slightly bigger label next to it */
    .form-check-label {
        cursor: pointer;
    }
</style>

<div class="container py-4 wrap">

    <!-- Header -->
    <div class="health-page-head d-flex flex-column flex-md-row align-items-md-center justify-content-between gap-3 mb-3">
        <div class="d-flex align-items-center gap-3">
            <div class="health-page-icon">
                <i class="bi bi-activity"></i>
            </div>
            <div>
                <div class="d-flex align-items-center gap-2 flex-wrap">
                    <h2 class="mb-0" style="font-weight:850; letter-spacing:-.03em;">Health</h2>
                    <span id="statusBadge" class="badge text-bg-secondary pill">Idle</span>
                </div>
                <div class="text-secondary small">
                    <i class="bi bi-clock-history me-1"></i>Updated: <span class="mono" id="updated">—</span>
                </div>
            </div>
        </div>
    </div>

    <!-- ROW: Cards -->
    <div class="health-cards-row">

        <!-- IIS Card -->
        <div class="health-card-col">
            <div class="h-100 well p-4 health-card health-card-iis">
                <div class="health-card-head">
                    <div class="health-card-title">
                        <div class="health-icon health-icon-iis">
                            <i class="bi bi-hdd-network"></i>
                        </div>
                        <div>
                            <div class="kpi-label">IIS</div>
                            <div class="kpi-sub">App pool process</div>
                        </div>
                    </div>
                </div>

                <div class="mt-3">
                    <div class="d-flex align-items-end justify-content-between">
                        <div class="kpi-value" id="iisCpu">—</div>
                        <div class="kpi-sub">CPU</div>
                    </div>
                    <div class="progress mt-2">
                        <div id="iisCpuBar" class="progress-bar" style="width:0%"></div>
                    </div>
                </div>

                <div class="mt-4">
                    <div class="d-flex align-items-end justify-content-between">
                        <div class="kpi-value" id="iisMem">—</div>
                        <div class="kpi-sub">Memory</div>
                    </div>
                    <div class="progress mt-2">
                        <div id="iisMemBar" class="progress-bar" style="width:0%"></div>
                    </div>
                </div>

                <div class="kpi-sub mt-4">
                    PID: <span class="mono" id="iisPid">—</span><br />
                    Working Set: <span class="mono" id="iisWs">—</span>
                </div>
            </div>
        </div>

        <!-- Total CPU Card -->
        <div class="health-card-col">
            <div class="h-100 well p-4 health-card health-card-cpu">
                <div class="health-card-head">
                    <div class="health-card-title">
                        <div class="health-icon health-icon-cpu">
                            <i class="bi bi-cpu"></i>
                        </div>
                        <div>
                            <div class="kpi-label">Total CPU</div>
                            <div class="kpi-sub">System load</div>
                        </div>
                    </div>
                </div>
                <div class="d-flex align-items-end justify-content-between mt-1 flex-wrap gap-2">
                    <div class="kpi-value" id="totCpu">—</div>
                    <div class="kpi-sub" id="statusText">Polling every 2 seconds</div>
                </div>
                <div class="progress mt-2">
                    <div id="totCpuBar" class="progress-bar" style="width:0%"></div>
                </div>
                <div class="kpi-sub mt-2">System-wide usage</div>
            </div>
        </div>

        <!-- Total Memory Card -->
        <div class="health-card-col">
            <div class="h-100 well p-4 health-card health-card-memory">
                <div class="health-card-head">
                    <div class="health-card-title">
                        <div class="health-icon health-icon-memory">
                            <i class="bi bi-memory"></i>
                        </div>
                        <div>
                            <div class="kpi-label">Total Memory Used</div>
                            <div class="kpi-sub">Server memory</div>
                        </div>
                    </div>
                </div>
                <div class="d-flex align-items-end justify-content-between mt-1 flex-wrap gap-2">
                    <div class="kpi-value" id="totMem">—</div>
                    <div class="kpi-sub mono" id="updated2">—</div>
                </div>
                <div class="progress mt-2">
                    <div id="totMemBar" class="progress-bar" style="width:0%"></div>
                </div>
                <div class="kpi-sub mt-2" id="totRam">—</div>
                <div class="kpi-sub mt-1" id="totMemLoad" style="display:none;"></div>
            </div>
        </div>

        <!-- Active Sessions Card -->
        <div class="health-card-col">
            <div class="h-100 well p-4 health-card health-card-sessions">
                <div class="health-card-head">
                    <div class="health-card-title">
                        <div class="health-icon health-icon-sessions">
                            <i class="bi bi-people-fill"></i>
                        </div>
                        <div>
                            <div class="kpi-label">Active Sessions</div>
                            <div class="kpi-sub">IIS app pool</div>
                        </div>
                    </div>
                </div>

                <div class="d-flex align-items-end justify-content-between mt-1">
                    <div class="kpi-value" id="activeSessions">—</div>
                </div>

                <div class="kpi-sub mt-2">
                    Session-based (IIS app pool)
                </div>
            </div>
        </div>

        <!-- Offline / Maintenance Mode Card -->
        <div class="health-card-col">
            <div id="maintenanceCard" class="h-100 well p-4 health-card health-card-maintenance">
                <div class="health-card-head">
                    <div class="health-card-title">
                        <div class="health-icon health-icon-maintenance">
                            <i class="bi bi-shield-exclamation"></i>
                        </div>
                        <div>
                            <div class="kpi-label mb-0">Maintenance</div>
                            <div class="kpi-sub mt-1" id="offlineStatusText">Online</div>
                        </div>
                    </div>

                    <!-- Bigger switch (top row) -->
                    <div class="form-check form-switch m-0 d-flex align-items-center gap-2">
                        <input class="form-check-input big-switch" type="checkbox" id="chkOffline" role="switch">
                        <label class="form-check-label kpi-sub user-select-none mb-0" for="chkOffline">
                            Enable
                        </label>
                    </div>
                </div>

                <!-- Body -->
                <div class="mt-4">
                    <div class="kpi-value">Offline</div>
                    <div class="kpi-sub mt-2">
                        When enabled, visitors are redirected to the out-of-service page.
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    const healthUrl = '@Url.Action("HealthJson", "Health")';
    const getOfflineUrl = '@Url.Action("GetOffline", "Health")';
    const setOfflineUrl = '@Url.Action("SetOffline", "Health")';
    const POLL_VISIBLE_MS = 2000;

    let pollTimer = null;
    let requestInFlight = false;
    let disposed = false;

    function fmtBytes(b) {
        if (b === null || b === undefined) return "—";
        const u = ["B", "KB", "MB", "GB", "TB"];
        let i = 0, n = Number(b);
        while (n >= 1024 && i < u.length - 1) { n /= 1024; i++; }
        return (i === 0 ? n.toFixed(0) : n.toFixed(2)) + " " + u[i];
    }

    function fmtPct(v) {
        if (v === null || v === undefined || isNaN(v)) return "—";
        return Number(v).toFixed(1);
    }

    function fmtPctWithSymbol(v) {
        const pct = fmtPct(v);
        return pct === "—" ? pct : pct + "%";
    }

    function clampPct(v) {
        v = Number(v);
        if (isNaN(v)) return 0;
        if (v < 0) return 0;
        if (v > 100) return 100;
        return v;
    }

    function setBar($bar, pct) {
        $bar.css("width", clampPct(pct).toFixed(1) + "%");
    }

    function setStatus(state, text) {
        const $badge = dom.statusBadge;
        const $statusText = dom.statusText;

        $badge.removeClass("text-bg-secondary text-bg-success text-bg-warning text-bg-danger");

        if (state === "ok") { $badge.addClass("text-bg-success").text("OK"); }
        else if (state === "loading") { $badge.addClass("text-bg-warning").text("Loading"); }
        else if (state === "error") { $badge.addClass("text-bg-danger").text("Error"); }
        else { $badge.addClass("text-bg-secondary").text("Idle"); }

        $statusText.text(text || "");
    }

    function safeGet(obj, path, fallback) {
        try { return path.split(".").reduce((o, k) => o && o[k], obj) ?? fallback; }
        catch { return fallback; }
    }

    function parseNetDate(v) {
        if (!v) return null;
        const iso = new Date(v);
        if (!isNaN(iso)) return iso;
        const m = /\/Date\((\d+)(?:[+-]\d+)?\)\//.exec(v);
        if (m) return new Date(parseInt(m[1], 10));
        return null;
    }

    function scheduleNextPoll(immediate) {
        if (disposed) return;
        if (pollTimer) {
            clearTimeout(pollTimer);
        }

        const delay = immediate ? 0 : POLL_VISIBLE_MS;
        pollTimer = setTimeout(refreshNow, delay);
    }

    const dom = {};

    function refreshNow() {
        if (disposed || document.visibilityState === "hidden") {
            return;
        }

        if (requestInFlight) {
            scheduleNextPoll(false);
            return;
        }

        requestInFlight = true;
        setStatus("loading", "Refreshing…");

        $.ajax({
            url: healthUrl,
            method: "GET",
            cache: false,
            dataType: "json",
            timeout: 8000,
            success: function (data) {
                const totCpu = safeGet(data, "Totals.CpuPercentTotal", 0);
                const totMem = safeGet(data, "Totals.MemoryPercentTotal", 0);
                const totalPhys = safeGet(data, "Totals.TotalPhysBytes", null);
                const availPhys = safeGet(data, "Totals.AvailPhysBytes", null);

                dom.totCpu.text(fmtPctWithSymbol(totCpu));
                dom.totMem.text(fmtPctWithSymbol(totMem));
                setBar(dom.totCpuBar, totCpu);
                setBar(dom.totMemBar, totMem);

                dom.totRam.text(`${fmtBytes(totalPhys)} total / ${fmtBytes(availPhys)} free`);

                const memLoad = safeGet(data, "Totals.MemoryLoadPercent", null);
                if (memLoad !== null && memLoad !== undefined) {
                    dom.totMemLoad.show().text(`Windows MemoryLoad: ${memLoad}%`);
                } else {
                    dom.totMemLoad.hide();
                }

                const stRaw = safeGet(data, "ServerTime", null);
                const st = parseNetDate(stRaw);
                const timeText = st ? st.toLocaleTimeString() : "—";
                dom.updated.text(timeText);
                dom.updated2.text(timeText);

                const iis = safeGet(data, "IIS", null);
                dom.iisPid.text(safeGet(iis, "Pid", "—"));
                dom.iisCpu.text(fmtPctWithSymbol(safeGet(iis, "CpuPercent", null)));
                dom.iisMem.text(fmtPctWithSymbol(safeGet(iis, "MemoryPercent", null)));
                dom.iisWs.text(fmtBytes(safeGet(iis, "WorkingSetBytes", null)));
                setBar(dom.iisCpuBar, safeGet(iis, "CpuPercent", 0));
                setBar(dom.iisMemBar, safeGet(iis, "MemoryPercent", 0));

                const act = safeGet(data, "ActiveSessions", null);
                dom.activeSessions.text(act === null ? "—" : act);

                setStatus("ok", "Live");
            },
            error: function (xhr) {
                setStatus("error", "HTTP " + (xhr && xhr.status ? xhr.status : "error"));
            },
            complete: function () {
                requestInFlight = false;
                scheduleNextPoll(false);
            }
        });
    }

    $(function () {
        dom.statusBadge = $("#statusBadge");
        dom.statusText = $("#statusText");
        dom.updated = $("#updated");
        dom.updated2 = $("#updated2");
        dom.totCpu = $("#totCpu");
        dom.totMem = $("#totMem");
        dom.totCpuBar = $("#totCpuBar");
        dom.totMemBar = $("#totMemBar");
        dom.totRam = $("#totRam");
        dom.totMemLoad = $("#totMemLoad");
        dom.iisPid = $("#iisPid");
        dom.iisCpu = $("#iisCpu");
        dom.iisMem = $("#iisMem");
        dom.iisWs = $("#iisWs");
        dom.iisCpuBar = $("#iisCpuBar");
        dom.iisMemBar = $("#iisMemBar");
        dom.activeSessions = $("#activeSessions");
        dom.chkOffline = $("#chkOffline");
        dom.offlineStatusText = $("#offlineStatusText");
        dom.maintenanceCard = $("#maintenanceCard");
        let offlineState = false;
        let offlineConfirmationPending = false;

        function setUi(isOffline) {
            offlineState = !!isOffline;
            dom.chkOffline.prop("checked", isOffline);
            dom.offlineStatusText.text(isOffline ? "Offline (redirecting users)" : "Online");
            dom.maintenanceCard.toggleClass("is-offline", isOffline);
        }

        // Load current state
        $.get(getOfflineUrl, function (r) {
            setUi(!!r.isOffline);
        });

        // Toggle
        dom.chkOffline.on("change", async function () {
            if (offlineConfirmationPending) return;

            const on = this.checked;
            const previous = offlineState;
            offlineConfirmationPending = true;
            dom.chkOffline.prop("disabled", true);

            const confirmed = await window.gtxConfirm({
                title: on ? "Enable maintenance mode" : "Disable maintenance mode",
                message: on
                    ? "Enable offline mode? Visitors will be redirected to the out-of-service page."
                    : "Disable offline mode? Visitors will be able to browse the site again.",
                confirmText: on ? "Enable" : "Disable",
                variant: on ? "warning" : "primary"
            });

            if (!confirmed) {
                setUi(previous);
                offlineConfirmationPending = false;
                dom.chkOffline.prop("disabled", false);
                return;
            }

            setUi(on);

            $.post(setOfflineUrl, { isOffline: on })
                .done(function (r) {
                    setUi(!!(r && r.isOffline));
                })
                .fail(function (xhr) {
                    // If server rejects, revert UI
                    setUi(previous);
                    alert("Failed to update maintenance mode.\n" + xhr.status + " " + xhr.statusText);
                })
                .always(function () {
                    offlineConfirmationPending = false;
                    dom.chkOffline.prop("disabled", false);
                });
        });

        $(document).on("visibilitychange.health", function () {
            if (document.visibilityState === "visible") {
                scheduleNextPoll(true);
            } else if (pollTimer) {
                clearTimeout(pollTimer);
                pollTimer = null;
            }
        });

        $(window).on("pagehide.health beforeunload.health", function () {
            disposed = true;
            if (pollTimer) {
                clearTimeout(pollTimer);
                pollTimer = null;
            }
        });

        scheduleNextPoll(true);
    });
</script>
