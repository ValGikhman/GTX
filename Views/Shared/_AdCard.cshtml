@model GTX.Models.GTX
@{
    const string photosInventoryImagesBaseUrl = "https://photos.usedcarscincinnati.com/Images";

    string ExtractPathFromInventoryImageUrl(string source)
    {
        var value = (source ?? string.Empty).Trim();
        if (string.IsNullOrWhiteSpace(value))
        {
            return null;
        }

        var queryIndex = value.IndexOf('?');
        if (queryIndex < 0 || queryIndex >= value.Length - 1)
        {
            return null;
        }

        var query = System.Web.HttpUtility.ParseQueryString(value.Substring(queryIndex));
        var pathValue = query["path"];
        if (string.IsNullOrWhiteSpace(pathValue))
        {
            return null;
        }

        return System.Web.HttpUtility.UrlDecode(pathValue);
    }

    string NormalizeInventoryImagePath(string source)
    {
        var value = (source ?? string.Empty).Trim().Replace('\\', '/');
        if (string.IsNullOrWhiteSpace(value))
        {
            return null;
        }

        if (value.StartsWith("/InventoryImages/Get", StringComparison.OrdinalIgnoreCase) ||
            value.StartsWith("InventoryImages/Get", StringComparison.OrdinalIgnoreCase))
        {
            var pathFromQuery = ExtractPathFromInventoryImageUrl(value);
            if (!string.IsNullOrWhiteSpace(pathFromQuery))
            {
                value = pathFromQuery.Trim().Replace('\\', '/');
            }
        }

        value = value.TrimStart('/');

        const string legacyPrefix = "GTXImages/Inventory/";
        const string picturesPrefix = "Pictures/";
        const string imagesPrefix = "Images/";

        if (value.StartsWith(legacyPrefix, StringComparison.OrdinalIgnoreCase))
        {
            return value.Substring(legacyPrefix.Length);
        }

        if (value.StartsWith(picturesPrefix, StringComparison.OrdinalIgnoreCase))
        {
            return value.Substring(picturesPrefix.Length);
        }

        if (value.StartsWith(imagesPrefix, StringComparison.OrdinalIgnoreCase))
        {
            return value.Substring(imagesPrefix.Length);
        }

        return value;
    }

    string BuildPhotosImageUrl(string relativePath)
    {
        var normalized = (relativePath ?? string.Empty).Trim().Replace('\\', '/').Trim('/');
        if (string.IsNullOrWhiteSpace(normalized))
        {
            return string.Empty;
        }

        var encodedPath = string.Join(
            "/",
            normalized
                .Split(new[] { '/' }, StringSplitOptions.RemoveEmptyEntries)
                .Select(Uri.EscapeDataString)
        );

        return photosInventoryImagesBaseUrl + "/" + encodedPath;
    }

    string BuildAdCardImageUrl(string source)
    {
        var value = (source ?? string.Empty).Trim();
        if (string.IsNullOrWhiteSpace(value))
        {
            return value;
        }

        if (value.StartsWith("http://", StringComparison.OrdinalIgnoreCase) ||
            value.StartsWith("https://", StringComparison.OrdinalIgnoreCase))
        {
            return value;
        }

        var normalizedPath = NormalizeInventoryImagePath(value);
        if (string.IsNullOrWhiteSpace(normalizedPath))
        {
            return value;
        }

        return BuildPhotosImageUrl(normalizedPath);
    }

    var detailsUrl = Url.Action("Details", "Inventory", new { stock = Model.Stock });
    var adCardImageUrl = BuildAdCardImageUrl(Model.Image);
    var adCardTitle = $"{Model.Year} {Model.Make} {Model.Model} {Model.VehicleStyle}".Trim();
}

<div id="@Model.Stock"
    class="btn btn-light hover-bw"
    title="Click here to see details."
    data-url="@detailsUrl"
    data-year="@Model.Year"
    data-stock="@Model.Stock.ToUpper()"
    data-make="@Model.Make.ToUpper()"
    data-model="@Model.Model.ToUpper()"
    data-style="@Model.VehicleStyle.ToUpper()"
    data-type="@Model.VehicleType.ToUpper()">

    <a class="d-flex align-items-center btn btn-outline-light text-start" style="text-decoration: none;">
        <!-- Image Left -->
        <img src="@adCardImageUrl"
             alt="@adCardTitle"
             class="rounded-3 me-3"
             style="width: 100px; height: auto; object-fit: cover; max-height: 76px;"
             loading="lazy"
             decoding="async"
             fetchpriority="low">

        <!-- Details Right -->
        <div class="flex-grow-1 p-0">
            <h6>
                <strong>@Model.Year @Model.Make</strong>
            </h6>
            <div>
                <h8 class="fw-bold mb-1">
                    @Model.Model - @Model.VehicleStyle
                </h8>
            </div>
            <div>
                <h8 class="fw-bold mb-1">
                    <strong>@I18n.R("All_Price"): </strong>@Model.InternetPrice.ToString("C0", new System.Globalization.CultureInfo("en-US"))
                </h8>
            </div>
            <div>
                <h8 class="fw-bold mb-1">
                    <strong>@I18n.R("All_Miles"): </strong>@Model.Mileage.ToString("N0")
                </h8>
            </div>
        </div>
    </a>
</div>
