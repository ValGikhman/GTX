@model GTX.Models.BaseModel

@helper FilterPanel(string panelId, string title, string icon, string field, string[] values, string emptyText = null)
{
    var safeValues = (values ?? new string[0])
        .Where(v => !string.IsNullOrWhiteSpace(v))
        .Distinct()
        .OrderBy(v => v)
        .ToArray();

    if (safeValues.Length == 0)
    {
        return;
    }

    <section class="inventory-filter-panel" data-filter-panel-field="@field">
        <button class="inventory-filter-panel-toggle collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#@panelId" aria-expanded="false" aria-controls="@panelId">
            <span class="inventory-filter-panel-title text-shadow-small">
                <i class="bi @icon"></i>
                <span>@title</span>
            </span>
            <span class="inventory-filter-panel-count">@safeValues.Length</span>
        </button>
        @if (!string.IsNullOrWhiteSpace(emptyText))
        {
            <div class="inventory-dependent-empty inventory-dependent-panel-empty" data-empty-panel-for="@field">
                @emptyText
            </div>
        }
        <div id="@panelId" class="collapse">
            <div class="inventory-filter-panel-body">
                @foreach (var value in safeValues)
                {
                    var id = "inv-filter-" + field + "-" + HttpUtility.UrlEncode(value).Replace("%", string.Empty).Replace("+", "-");
                    <label class="inventory-check-row" for="@id">
                        <input class="form-check-input inventory-filter-check"
                               type="checkbox"
                               id="@id"
                               data-field="@field"
                               data-value="@value.ToUpperInvariant()" />
                        <span class="inventory-check-label text-shadow-small">@value</span>
                        <span class="inventory-check-hit shadow" data-count-field="@field" data-count-value="@value.ToUpperInvariant()"></span>
                    </label>
                }
            </div>
        </div>
    </section>
}

@helper RangePanel(string panelId, string title, string icon, string field, decimal min, decimal max, decimal step, string format)
{
    if (max <= 0)
    {
        return;
    }

    var minText = min.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture);
    var maxText = max.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture);
    var stepText = step.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture);

    <section class="inventory-filter-panel inventory-range-filter"
             data-range-field="@field"
             data-range-min="@minText"
             data-range-max="@maxText"
             data-range-step="@stepText"
             data-range-format="@format">
        <button class="inventory-filter-panel-toggle collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#@panelId" aria-expanded="false" aria-controls="@panelId">
            <span class="inventory-filter-panel-title text-shadow-small">
                <i class="bi @icon"></i>
                <span>@title</span>
            </span>
        </button>
        <div id="@panelId" class="collapse">
            <div class="inventory-filter-panel-body inventory-range-panel-body">
                <div class="inventory-range-values">
                    <output class="inventory-range-output shadow" for="@($"{panelId}Min")" data-range-value-label-min="@field"></output>
                    <span class="inventory-range-separator">-</span>
                    <output class="inventory-range-output shadow" for="@($"{panelId}Max")" data-range-value-label-max="@field"></output>
                </div>
                <div id="@($"{panelId}Slider")" class="inventory-dual-range-slider" data-range-slider></div>
                <input id="@($"{panelId}Min")"
                       class="inventory-range-input inventory-range-min-input"
                       type="hidden"
                       min="@minText"
                       max="@maxText"
                       step="@stepText"
                       value="@minText"
                       data-range-field="@field"
                       data-range-bound="min" />
                <input id="@($"{panelId}Max")"
                       class="inventory-range-input inventory-range-max-input"
                       type="hidden"
                       min="@minText"
                       max="@maxText"
                       step="@stepText"
                       value="@maxText"
                       data-range-field="@field"
                       data-range-bound="max" />
            </div>
        </div>
    </section>
}

@{
    var vehicles = Model.Inventory?.Vehicles ?? Enumerable.Empty<GTX.Models.GTX>();
    var yearValues = vehicles.Select(v => (decimal)v.Year).ToArray();
    var mileValues = vehicles.Select(v => (decimal)v.Mileage).ToArray();
    var priceValues = vehicles.Select(v => Convert.ToDecimal(v.InternetPrice)).ToArray();

    var minYear = yearValues.Any() ? yearValues.Min() : 0;
    var maxYear = yearValues.Any() ? yearValues.Max() : 0;
    var minMiles = mileValues.Any() ? Math.Floor(mileValues.Min() / 1000m) * 1000m : 0;
    var maxMiles = mileValues.Any() ? Math.Ceiling(mileValues.Max() / 1000m) * 1000m : 0;
    var minPrice = priceValues.Any() ? Math.Floor(priceValues.Min() / 1000m) * 1000m : 0;
    var maxPrice = priceValues.Any() ? Math.Ceiling(priceValues.Max() / 1000m) * 1000m : 0;
}

<aside id="inventoryFilterRail" class="inventory-filter-rail">
    <div class="inventory-filter-shell">
        <div class="inventory-filter-stats text-dark">
            <div class="inventory-filter-match">
                <span id="inventoryFilterCount">0</span>
                <span>matching vehicle(s)</span>
            </div>
            <div class="inventory-filter-actions">
                <button type="button" id="inventoryClearFiltersDesktop" class="btn btn-sm btn-gradient-grey border-dark rounded-3 shadow text-black fw-bold inventory-clear-btn d-none d-lg-inline-flex">
                    <i class="bi bi-eraser-fill"></i>
                    <span>Clear</span>
                </button>
                <button type="button" id="inventoryMobileCloseCanvas" class="btn btn-sm btn-gradient-grey border-dark rounded-3 shadow text-black fw-bold inventory-clear-btn d-lg-none">
                    <i class="bi bi-binoculars"></i>
                    <span>Search</span>
                </button>
            </div>
        </div>

        <div class="inventory-filter-scroll">
            @RangePanel("invFilterYearRange", "Year", "bi-calendar3", "year", minYear, maxYear, 1m, "year")
            @FilterPanel("invFilterMakes", I18n.R("All_Makes"), "bi-building", "make", Model.Filters?.Makes)
            @FilterPanel("invFilterModels", I18n.R("All_Models"), "bi-car-front", "model", Model.Filters?.Models, "Choose a make to see available models.")
            @FilterPanel("invFilterBody", I18n.R("All_Body"), "bi-truck-front", "body", Model.Filters?.BodyTypes)
            @FilterPanel("invFilterType", I18n.R("All_Type"), "bi-car-front-fill", "type", Model.Filters?.VehicleTypes)
            @FilterPanel("invFilterFuel", I18n.R("All_Fuel"), "bi-fuel-pump", "fuel", Model.Filters?.FuelTypes)
            @FilterPanel("invFilterDrive", I18n.R("All_Drive"), "bi-gear", "drive", Model.Filters?.DriveTrains)
            @FilterPanel("invFilterTransmission", I18n.R("All_Transm"), "bi-shuffle", "transmission", Model.Filters?.Transmissions)
            @FilterPanel("invFilterCylinders", I18n.R("All_Cylinders"), "bi-speedometer", "cylinders", Model.Filters?.Cylinders)
            @RangePanel("invFilterMilesRange", I18n.R("All_Miles"), "bi-speedometer2", "miles", minMiles, maxMiles, 1000m, "number")
            @RangePanel("invFilterPriceRange", I18n.R("All_Price"), "bi-currency-dollar", "price", minPrice, maxPrice, 1000m, "currency")
        </div>
    </div>
</aside>

<style>
    .inventory-split {
        --inventory-sidebar-width: 340px;
        display: flex;
        align-items: stretch;
        gap: 0;
        height: 100%;
        min-height: 0;
        margin-left: 0 !important;
        padding-left: 0 !important;
    }

    .inventory-sidebar-pane {
        width: var(--inventory-sidebar-width);
        flex: 0 0 var(--inventory-sidebar-width);
        min-width: 260px;
        max-width: 520px;
        height: 100%;
        min-height: 0;
        margin-left: 0;
        padding-left: 0;
        transition: flex-basis .18s ease, width .18s ease, opacity .18s ease;
    }

    .inventory-filter-rail {
        width: 100%;
        height: 100%;
        max-height: none;
        position: relative;
        z-index: 4;
        margin-left: 0;
        padding-left: 0;
    }

    .inventory-filter-shell {
        display: flex;
        flex-direction: column;
        height: 95%;
        max-height: none;
        overflow: hidden;
        background: #f8fafc;
    }

    .inventory-split-divider {
        position: relative;
        height: 100%;
        min-height: 0;
        box-sizing: border-box;
        left: 15px;
        opacity: 1;
        cursor: col-resize;
        touch-action: none;
    }

    .inventory-split-divider::before {
        content: "";
        position: absolute;
        top: .75rem;
        bottom: .75rem;
        left: 50%;
        width: 2px;
        transform: translateX(-50%);
        border-radius: 999px;
        background: rgba(255, 255, 255, .32);
        box-shadow: 0 0 0 1px rgba(0, 0, 0, .18), 0 10px 24px rgba(15, 23, 42, .16);
        transition: width .15s ease, box-shadow .15s ease, opacity .15s ease;
    }

    .inventory-split-divider::after {
        content: "";
        position: absolute;
        top: 50%;
        left: 50%;
        width: .2rem;
        height: 3.25rem;
        transform: translate(-50%, -50%);
        border-radius: 999px;
        background-image: radial-gradient(circle, rgba(255, 255, 255, .72) 1.5px, transparent 2px);
        background-size: .2rem .55rem;
        background-position: center;
        opacity: .92;
        pointer-events: none;
    }

    .inventory-split-divider:hover::before,
    body.inventory-split-resizing .inventory-split-divider::before {
        width: 4px;
    }

    .inventory-sidebar-toggle {
        position: absolute;
        top: 50%;
        left: 50%;
        z-index: 2;
        width: 1.65rem;
        height: 1.65rem;
        padding: 0;
        transform: translate(-50%, -50%);
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border-radius: 999px;
        color: #111827;
        background: linear-gradient(180deg, rgb(255 255 255), #AAAAB3);
        transition: transform .15s ease, box-shadow .15s ease;
    }

    .inventory-sidebar-toggle:hover,
    .inventory-sidebar-toggle:focus {
        transform: translate(-50%, -50%) scale(1.06);
        box-shadow: 0 12px 26px rgba(15, 23, 42, .28) !important;
    }

    .inventory-sidebar-collapsed .inventory-sidebar-pane {
        width: 0;
        flex-basis: 0;
        min-width: 0;
        overflow: hidden;
        opacity: 0;
    }

    body.inventory-split-resizing,
    body.inventory-split-resizing * {
        cursor: col-resize !important;
        user-select: none !important;
    }

    .inventory-filter-stats {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: .5rem;
        padding: .65rem .95rem;
        border-bottom: 1px solid rgba(0, 0, 0, .12);
        color: #fff;
        font-weight: 700;
        box-shadow: 0 .55rem 1.1rem rgba(15, 23, 42, .13);
    }

    .inventory-filter-match {
        display: inline-flex;
        align-items: baseline;
        justify-content: center;
        gap: .35rem;
        min-width: 0;
        white-space: nowrap;
    }

    .inventory-clear-btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: .35rem;
        line-height: 1.2;
    }

    .inventory-filter-actions {
        display: inline-flex;
        align-items: center;
        gap: .45rem;
    }

    .inventory-filter-scroll {
        flex: 1 1 auto;
        min-height: 0;
        overflow-y: auto;
        padding: .55rem .55rem 5rem;
        scroll-padding-bottom: 5rem;
        background: linear-gradient(180deg, #f8fafc 0%, #eef2f7 100%);
        scrollbar-width: thin;
    }

    #inventorySidebarPane .inventory-filter-scroll {
        padding-bottom: 5rem;
        scroll-padding-bottom: 5rem;
    }

    .inventory-filter-scroll::-webkit-scrollbar {
        width: .55rem;
    }

    .inventory-filter-scroll::-webkit-scrollbar-track {
        background: #eef2f7;
    }

    .inventory-filter-scroll::-webkit-scrollbar-thumb {
        background: #9ca3af;
        border-radius: 999px;
        border: 2px solid #eef2f7;
    }


    .inventory-filter-panel {
        margin-bottom: .5rem;
        border: 1px solid rgba(15, 23, 42, .12);
        border-radius: .5rem;
        overflow: hidden;
        background: #fff;
        box-shadow: 0 .35rem 1rem rgba(15, 23, 42, .08);
    }

    .inventory-filter-panel-toggle {
        width: 100%;
        border: 0 !important;
        background: linear-gradient(180deg, #ffffff 0%, #eef2f7 100%);
        color: #111827;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: .75rem;
        position: relative;
        padding: .65rem .75rem;
        font-weight: 600;
        text-align: left;
        box-shadow: inset 0 1px 0 rgba(255, 255, 255, .78);
        transition: filter .14s ease, box-shadow .14s ease;
    }

    .inventory-filter-panel-toggle::before {
        content: "";
        position: absolute;
        inset: 0 auto 0 0;
        width: .25rem;
        background: var(--gtx-grad, linear-gradient(180deg, rgba(21, 90, 150, 1) 43%, rgba(30, 115, 190, 1) 94%));
    }

    .inventory-filter-panel-toggle:hover,
    .inventory-filter-panel-toggle:focus {
        filter: brightness(1.03);
        box-shadow: inset 0 1px 0 rgba(255, 255, 255, .9), 0 3px 10px rgba(15, 23, 42, .14);
    }

    .inventory-filter-panel-toggle::after {
        content: "-";
        width: 1.45rem;
        height: 1.45rem;
        border-radius: 999px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(180deg, #ffffff, #e5e7eb);
        color: #111827;
        border: 1px solid rgba(0, 0, 0, .15);
        font-size: 1rem;
        font-weight: 900;
        line-height: 1;
        order: 3;
        text-shadow: none;
        box-shadow: 0 2px 7px rgba(15, 23, 42, .18);
    }

    .inventory-filter-panel-toggle.collapsed::after {
        content: "+";
    }

    .inventory-filter-panel-title {
        display: inline-flex;
        align-items: center;
        gap: .5rem;
        min-width: 0;
    }

    .inventory-filter-panel-count {
        margin-left: auto;
        color: #1f2937;
        font-size: .78rem;
        font-weight: 900;
    }

    .inventory-check-row .form-check-input:checked {
        background-color: #155a96;
        border-color: #155a96;
    }

    html.theme-grey .inventory-check-row .form-check-input:checked,
    html.theme-dark .inventory-check-row .form-check-input:checked {
        background-color: #757575;
        border-color: #757575;
    }

    html.theme-pink .inventory-check-row .form-check-input:checked {
        background-color: #c52674;
        border-color: #c52674;
    }

    html.theme-deep-purple .inventory-check-row .form-check-input:checked {
        background-color: #3a145e;
        border-color: #3a145e;
    }

    html.theme-metallica .inventory-check-row .form-check-input:checked {
        background-color: #747d88;
        border-color: #747d88;
    }

    .inventory-filter-panel-body {
        padding: .35rem .55rem .7rem;
        background: #fff;
    }

    .inventory-range-panel-body {
        padding-top: .45rem;
    }

    .inventory-range-values {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: .32rem;
        margin-bottom: .35rem;
        color: #1f2937;
        font-size: .72rem;
        font-weight: 900;
    }

    .inventory-range-separator {
        flex: 0 0 auto;
        color: #6b7280;
    }

    .inventory-range-output {
        flex: 1 1 0;
        min-width: 0;
        max-width: 6.4rem;
        padding: .08rem .32rem;
        border-radius: .38rem;
        background: #e5e7eb;
        color: #1f2937;
        text-align: center;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .inventory-range-input {
        display: none;
    }

    .inventory-dual-range-slider {
        min-height: 6px;
        margin: .05rem .28rem 0;
        touch-action: none;
    }

    .inventory-dual-range-slider.noUi-target {
        height: 2px;
        border: 1px solid rgba(15, 23, 42, .14);
        border-radius: 999px;
        background: #e5e7eb;
        box-shadow: inset 0 1px 2px rgba(15, 23, 42, .12);
    }

    .inventory-dual-range-slider .noUi-connect {
        background: #155a96;
    }

    .inventory-dual-range-slider .noUi-handle {
        width: 14px;
        height: 14px;
        right: -7px;
        top: -7px;
        border-radius: 999px;
        border: 1px solid rgba(15, 23, 42, .22);
        background: linear-gradient(180deg, #ffffff, #e5e7eb);
        box-shadow: 0 1px 4px rgba(15, 23, 42, .28);
        cursor: pointer;
        touch-action: none;
    }

    .inventory-dual-range-slider .noUi-handle::before,
    .inventory-dual-range-slider .noUi-handle::after {
        display: none;
    }

    .inventory-dual-range-slider .noUi-touch-area {
        width: 100%;
        height: 100%;
    }

    html.theme-grey .inventory-dual-range-slider .noUi-connect,
    html.theme-dark .inventory-dual-range-slider .noUi-connect {
        background-color: #757575;
    }

    html.theme-pink .inventory-dual-range-slider .noUi-connect {
        background-color: #c52674;
    }

    html.theme-deep-purple .inventory-dual-range-slider .noUi-connect {
        background-color: #3a145e;
    }

    html.theme-metallica .inventory-dual-range-slider .noUi-connect {
        background-color: #747d88;
    }

    .inventory-check-row {
        display: flex;
        align-items: center;
        gap: .55rem;
        min-height: 2.1rem;
        padding: .32rem .45rem;
        border-radius: .45rem;
        cursor: pointer;
        color: #1f2937;
        font-weight: 600;
    }

    .inventory-check-row:hover {
        background: #eef2f7;
    }

    .inventory-check-row .form-check-input {
        flex: 0 0 auto;
        margin: 0;
        cursor: pointer;
    }

    .inventory-check-label {
        min-width: 0;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .inventory-check-hit {
        margin-left: auto;
        min-width: 1.75rem;
        padding: .08rem .35rem;
        border-radius: .45rem;
        background: #e5e7eb;
        color: #4b5563;
        font-size: .72rem;
        font-weight: 900;
        text-align: center;
    }

    .inventory-dependent-empty {
        margin: .35rem .2rem;
        padding: .65rem .7rem;
        border: 1px dashed rgba(17, 24, 39, .22);
        border-radius: .45rem;
        background: #fff;
        color: #6b7280;
        font-size: .82rem;
        font-weight: 800;
        text-align: center;
    }

    .inventory-results-zone {
        display: flex;
        flex-direction: column;
        height: 100%;
        min-height: 0;
        min-width: 0;
        flex: 1 1 auto;
    }

    .inventory-results-zone #inventory > .card {
        height: auto;
        align-self: flex-start;
    }

    .inventory-empty-filter {
        display: none;
        border: 1px dashed rgba(0, 0, 0, .2);
        border-radius: .5rem;
        background: #fff;
        color: #4b5563;
        font-weight: 800;
    }

    @@media (max-width: 991.98px) {
        .inventory-layout,
        .inventory-split {
            flex-direction: column;
            height: 100%;
            min-height: 0;
            overflow: hidden;
        }

        .inventory-sidebar-pane {
            width: 100%;
            flex-basis: auto;
            max-width: none;
            height: auto;
            min-width: 0;
            opacity: 1;
        }

        .inventory-sidebar-collapsed .inventory-sidebar-pane {
            width: 100%;
            flex-basis: auto;
            min-width: 0;
            opacity: 1;
        }

        .inventory-filter-rail {
            width: 100%;
            height: 100%;
            max-height: none;
        }

        .inventory-filter-shell {
            height: 100%;
            max-height: none;
        }

        .inventory-split-divider {
            display: none;
        }

        .inventory-filter-scroll {
            max-height: none;
            padding-bottom: calc(5rem + env(safe-area-inset-bottom));
            scroll-padding-bottom: calc(5rem + env(safe-area-inset-bottom));
        }

        #inventorySidebarPane .inventory-filter-scroll {
            padding-bottom: calc(5rem + env(safe-area-inset-bottom));
            scroll-padding-bottom: calc(5rem + env(safe-area-inset-bottom));
        }

        .inventory-results-zone {
            height: 100%;
            min-height: 0;
            overflow: hidden;
        }

        .inventory-results-zone #inventory {
            overflow-y: auto;
        }

    }
</style>
